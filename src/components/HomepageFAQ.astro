---
import FAQAccordion from './FAQAccordion.astro';

interface FAQ {
  q: string;
  a: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---

<section class="home-faq" aria-labelledby="home-faq-heading">
  <div class="container">
    <div class="home-faq__header" data-animate>
      <span class="eyebrow eyebrow--line">Common Questions</span>
      <h2 class="section-title" id="home-faq-heading">Frequently Asked.</h2>
    </div>
    <div data-animate data-delay="1">
      <FAQAccordion faqs={faqs} />
    </div>
  </div>
</section>

<style>
  .home-faq {
    background: var(--color-warm-white);
    padding: var(--sp-9) 0;
    border-top: 1px solid var(--color-border-light, #E2DED9);
  }

  .home-faq__header {
    max-width: 480px;
    margin-bottom: var(--sp-7);
  }

  @media (max-width: 1024px) {
    .home-faq {
      padding: var(--sp-7) 0;
    }
    .home-faq__header {
      margin-bottom: var(--sp-5);
    }
  }
</style>
