---
const categories = [
  {
    href:        '/products/non-woven-carpet',
    name:        'Non Woven Carpet',
    sub:         '29 shades — bulk expo flooring',
    img:         '/images/catalogue/nw-roll-macro.webp',
    srcset:      '/images/catalogue/nw-roll-macro-640w.webp 640w, /images/catalogue/nw-roll-macro.webp 900w',
    placeholder: false,
    imgPos:      '58% center',
  },
  {
    href:        '/products/ribbed-carpet',
    name:        'Ribbed Carpet',
    sub:         '7 shades — high-footfall trade fair floors',
    img:         '/images/catalogue/ribbed-carpet.webp',
    srcset:      '/images/catalogue/ribbed-carpet-640w.webp 640w, /images/catalogue/ribbed-carpet.webp 1440w',
    placeholder: false,
    imgPos:      '68% center',
  },
  {
    href:        '/products/velour-carpet',
    name:        'Velour Carpet',
    sub:         '11 shades — premium pavilion finish',
    img:         '/images/catalogue/velour-hero.webp',
    srcset:      '/images/catalogue/velour-hero-640w.webp 640w, /images/catalogue/velour-hero.webp 1200w',
    placeholder: false,
    imgPos:      '55% 60%',
  },
  {
    href:        '/products/loop-pile-carpet',
    name:        'Loop Pile',
    sub:         '6 shades — architectural cut-loop texture',
    img:         '/images/catalogue/lp-macro.webp',
    srcset:      '/images/catalogue/lp-macro-640w.webp 640w, /images/catalogue/lp-macro.webp 896w',
    placeholder: false,
    imgPos:      'center 62%',
  },
  {
    href:        '/products/caution-carpet',
    name:        'Caution Carpet',
    sub:         'Safety Flooring · Cable Tray Coverage',
    img:         '/images/catalogue/caution-carpet-1.webp',
    srcset:      '/images/catalogue/caution-carpet-1-640w.webp 640w, /images/catalogue/caution-carpet-1.webp 1440w',
    placeholder: false,
    imgPos:      'center 62%',
  },
  {
    href:        '/products/designer-carpet',
    name:        'Designer Carpet',
    sub:         'Custom Artwork · Brand Identity · Event Themes',
    img:         '/images/designer-carpet/anuga-blue-wave.webp',
    srcset:      '/images/designer-carpet/anuga-blue-wave-640w.webp 640w, /images/designer-carpet/anuga-blue-wave-1280w.webp 1280w, /images/designer-carpet/anuga-blue-wave.webp 1920w',
    placeholder: false,
    imgPos:      'center 58%',
  },
  {
    href:        '/products/grass-carpet',
    name:        'Grass Carpet',
    sub:         'Synthetic grass for themed exhibition environments',
    img:         '/images/catalogue/grass-carpet-hero.webp',
    srcset:      '/images/catalogue/grass-carpet-hero-640w.webp 640w, /images/catalogue/grass-carpet-hero.webp 1200w',
    placeholder: false,
    imgPos:      'center 35%',
  },
  {
    href:        '/products/coir-carpet',
    name:        'Coir Carpet',
    sub:         'Natural coconut fibre for eco & organic pavilions',
    img:         '/images/coir/coir-3608.webp',
    srcset:      '/images/coir/coir-3608-640w.webp 640w, /images/coir/coir-3608.webp 1280w',
    placeholder: false,
    imgPos:      'center 50%',
  },
];
---

<style>
  /* object-position driven by per-element CSS vars set in the style attribute.
     Fallback chain: mobile var → desktop var → center (global.css default). */
  .cat-card__img {
    object-position: var(--obj-pos, center);
  }
  @media (max-width: 768px) {
    .cat-card__img {
      object-position: var(--obj-pos-mobile, var(--obj-pos, center));
    }
  }

</style>

<section class="categories" aria-labelledby="categories-heading">
  <div class="container">
    <div class="categories__header" data-animate>
      <div>
        <span class="eyebrow eyebrow--line">Product Range</span>
        <h2 class="section-title" id="categories-heading">
          Exhibition Carpets<br />for Every Application.
        </h2>
      </div>
      <a href="/products" class="categories__link-all">
        View All
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
          <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.4"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="categories__grid">
      {categories.map((cat, i) => (
        <a
          href={cat.href}
          class={`cat-card${cat.placeholder ? ' cat-card--blank' : ''}`}
          data-animate
          data-delay={String(i + 1)}
          aria-label={`Explore ${cat.name}`}
        >
          <div class={`cat-card__img-wrap${cat.placeholder ? ' cat-card__img-wrap--blank' : ''}`}>
            {!cat.placeholder && cat.img && (
              <img
                src={cat.img}
                srcset={cat.srcset}
                sizes="(max-width: 1024px) calc(50vw - 24px), calc(25vw - 16px)"
                alt={cat.name}
                class="cat-card__img"
                loading="lazy"
                decoding="async"
                width="600"
                height="750"
                style={`--obj-pos:${cat.imgPos};${cat.mobileImgPos ? `--obj-pos-mobile:${cat.mobileImgPos}` : ''}`}
              />
            )}
          </div>
          <div class="cat-card__overlay" aria-hidden="true"></div>
          <div class="cat-card__info">
            <div>
              <div class="cat-card__name">{cat.name}</div>
              <div class="cat-card__sub">{cat.sub}</div>
            </div>
            <div class="cat-card__arrow" aria-hidden="true">
              <svg width="12" height="10" viewBox="0 0 12 10" fill="none">
                <path d="M1 5h10M7 1l4 4-4 4" stroke="white" stroke-width="1.3"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
