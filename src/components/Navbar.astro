---
const products = [
  { href: '/products/non-woven-carpet',  label: 'Non Woven Carpet',  sub: 'Regular & Premium Shade'   },
  { href: '/products/ribbed-carpet',     label: 'Ribbed Carpet',     sub: null                        },
  { href: '/products/velour-carpet',     label: 'Velour Carpet',     sub: null                        },
  { href: '/products/loop-pile-carpet',  label: 'Loop Pile Carpet',  sub: null                        },
  { href: '/products/caution-carpet',    label: 'Caution Carpet',    sub: 'Safety & Access Flooring'  },
  { href: '/products/designer-carpet',   label: 'Designer Carpet',   sub: 'Custom & Branded Flooring' },
];
---

<nav class="navbar">
  <div class="navbar__inner container">
    <a href="/" class="navbar__logo" aria-label="Sanchi Enterprises">
      <img src="/logo.png" alt="Sanchi Enterprises" width="156" height="50" />
    </a>

    <ul class="navbar__links" role="list">
      <li><a href="/" class="navbar__link">Home</a></li>
      <li class="navbar__item">
        <a href="/products" class="navbar__link">
          Products
          <svg width="9" height="5" viewBox="0 0 9 5" fill="none" aria-hidden="true"
            style="margin-left:5px;vertical-align:middle;opacity:0.3">
            <path d="M1 1l3.5 3.5L8 1" stroke="currentColor" stroke-width="1.2"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="navbar__dropdown" role="menu">
          <span class="navbar__dropdown-sub">Categories</span>
          {products.map((p) => (
            <a href={p.href} class="navbar__dropdown-link" role="menuitem">
              {p.label}
              {p.sub && (
                <span style="display:block;font-size:11px;color:rgba(247,246,243,0.3);margin-top:2px;">
                  {p.sub}
                </span>
              )}
            </a>
          ))}
        </div>
      </li>
      <li><a href="/projects" class="navbar__link">Projects</a></li>
      <li><a href="/about"    class="navbar__link">About</a></li>
      <li><a href="/contact"  class="navbar__link">Contact</a></li>
    </ul>

    <div class="navbar__actions">
      <a
        href="https://wa.me/919958132189"
        class="navbar__enquire"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp us"
      >
        Enquire
      </a>

      <button class="navbar__hamburger" aria-label="Open navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile overlay -->
<div class="navbar__mobile" role="dialog" aria-label="Navigation" aria-modal="true">
  <div class="mobile-menu__header container">
    <a href="/" class="mobile-menu__logo" aria-label="Sanchi Enterprises">
      <img src="/logo.png" alt="Sanchi Enterprises" width="120" height="38" />
    </a>
    <button class="mobile-menu__close" aria-label="Close navigation">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <nav class="mobile-menu__nav container">
    <a href="/"         class="mobile-menu__link">Home</a>
    <div class="mobile-menu__group">
      <span class="mobile-menu__group-label">Products</span>
      {products.map((p) => (
        <a href={p.href} class="mobile-menu__sub-link">{p.label}</a>
      ))}
    </div>
    <a href="/projects" class="mobile-menu__link">Projects</a>
    <a href="/about"    class="mobile-menu__link">About</a>
    <a href="/contact"  class="mobile-menu__link">Contact</a>
  </nav>

  <div class="mobile-menu__cta container">
    <a
      href="https://wa.me/919958132189"
      class="btn btn--whatsapp"
      style="width:100%;justify-content:center;"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp Us — +91 99581 32189
    </a>
  </div>
</div>
