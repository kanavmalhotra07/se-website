---

<section class="home-bridge" aria-hidden="true">
  <div class="home-bridge__strip">
    <div class="home-bridge__video-wrap" data-animate="image">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="/images/bridge/afterhero-2-poster-1280w.webp"
        class="home-bridge__video"
        data-lazy-src="/videos/afterhero-2.mp4"
      >
        <img
          src="/images/bridge/afterhero-2-poster.webp"
          srcset="/images/bridge/afterhero-2-poster-640w.webp 640w, /images/bridge/afterhero-2-poster-1280w.webp 1280w, /images/bridge/afterhero-2-poster.webp 1920w"
          sizes="100vw"
          alt="" width="1920" height="1080" loading="lazy" decoding="async"
        />
      </video>
      <div class="home-bridge__veil"></div>
    </div>
    <p class="home-bridge__caption" data-animate>On-site installation — India's trade fairs &amp; exhibitions</p>
  </div>
</section>
