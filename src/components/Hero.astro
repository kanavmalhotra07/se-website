---
---

<section class="hero" aria-label="Hero">
  <div class="hero__bg" aria-hidden="true">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/images/hero/design-mumbai-poster.webp"
      class="hero__bg-video"
    >
      <source src="/videos/design-mumbai-hero.mp4" type="video/mp4" />
      <img
        src="/images/hero/design-mumbai-poster.webp"
        srcset="/images/hero/design-mumbai-poster-640w.webp 640w, /images/hero/design-mumbai-poster-1280w.webp 1280w, /images/hero/design-mumbai-poster.webp 1920w"
        sizes="100vw"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </video>
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__text-mask" aria-hidden="true"></div>

  <div class="hero__content container">
    <div class="hero__inner">
      <span class="hero__eyebrow">Exhibition Flooring · India</span>
      <h1 class="hero__headline">
        The Floor Beneath<br />India's Exhibitions.
      </h1>
      <p class="hero__sub">
        Non woven, ribbed, velour, and custom exhibition carpet —
        supplied and installed for trade fairs, expos, and
        conventions across India.
      </p>
      <div class="hero__actions">
        <a href="/products" class="btn btn--hero-primary">View Catalogue</a>
        <a href="/contact" class="hero__cta-link">
          Get a Quote
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
            <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
  </div>
</section>
