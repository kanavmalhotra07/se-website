---
import '../styles/global.css';
import 'lenis/dist/lenis.css';

interface BreadcrumbItem {
  name: string;
  item: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const siteBase = 'https://www.sanchienterprises.com';

const {
  title = 'Sanchi Enterprises — Exhibition Flooring & Carpet Solutions, India',
  description = 'Premium exhibition carpets and flooring solutions for trade fairs, expos, and conventions across India. Non-woven, ribbed, and velour carpets supplied in bulk.',
  ogImage = `${siteBase}/images/products/non-woven/nw-hero-poster.jpg`,
  ogImageWidth = '1200',
  ogImageHeight = '675',
  breadcrumbs = [],
} = Astro.props;

const rawPath = Astro.url.pathname;
const canonicalUrl = `${siteBase}${rawPath === '/' ? '/' : rawPath.replace(/\/$/, '')}`;

const allBreadcrumbs: BreadcrumbItem[] = [
  { name: 'Home', item: `${siteBase}/` },
  ...breadcrumbs,
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0C1230" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:site_name"   content="Sanchi Enterprises" />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width"  content={ogImageWidth} />
  <meta property="og:image:height" content={ogImageHeight} />
  <meta property="og:locale"      content="en_IN" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- ── Copyright & Ownership ────────────────────────────────────────────── -->
  <meta name="copyright"   content={`© ${new Date().getFullYear()} Sanchi Enterprises. All rights reserved.`} />
  <meta name="author"      content="Sanchi Enterprises" />
  <meta name="owner"       content="Sanchi Enterprises" />
  <meta name="publisher"   content="Sanchi Enterprises" />
  <meta name="web_author"  content="Sanchi Enterprises" />
  <meta name="reply-to"    content="kanav@sanchienterprises.com" />

  <!-- ── Dublin Core Metadata (DC Elements 1.1) ───────────────────────────── -->
  <!--
    Dublin Core is a W3C-endorsed metadata standard (ISO 15836) widely recognised
    by archival systems, legal registries, and content-rights databases.
    Declaring it here creates a machine-readable chain of ownership over all
    original works on this website.
  -->
  <link rel="schema.DC"      href="http://purl.org/dc/elements/1.1/" />
  <link rel="schema.DCTERMS" href="http://purl.org/dc/terms/" />
  <meta name="DC.title"       content={title} />
  <meta name="DC.creator"     content="Sanchi Enterprises" />
  <meta name="DC.subject"     content="Exhibition carpets, flooring solutions, trade fair carpets, non-woven carpet, ribbed carpet, velour carpet, India" />
  <meta name="DC.description" content={description} />
  <meta name="DC.publisher"   content="Sanchi Enterprises" />
  <meta name="DC.contributor" content="Sanchi Enterprises" />
  <meta name="DC.date"        content={new Date().getFullYear().toString()} scheme="DCTERMS.W3CDTF" />
  <meta name="DC.type"        content="Text" scheme="DCTERMS.DCMIType" />
  <meta name="DC.format"      content="text/html" scheme="DCTERMS.IMT" />
  <meta name="DC.identifier"  content="https://www.sanchienterprises.com" scheme="DCTERMS.URI" />
  <meta name="DC.language"    content="en" scheme="DCTERMS.RFC4646" />
  <meta name="DC.coverage"    content="India" />
  <meta name="DC.rights"      content={`© ${new Date().getFullYear()} Sanchi Enterprises. All text, graphics, code, and layout are original intellectual property of Sanchi Enterprises. Unauthorised reproduction, AI scraping, data mining, and automated harvesting are strictly prohibited without prior written consent. Full policy: https://www.sanchienterprises.com/terms`} />

  <!-- ── AI Crawler & Automated Scraper Restrictions ──────────────────────── -->
  <!--
    noai / noimageai: emerging directives respected by AI image and text
    training crawlers (Midjourney, Adobe Firefly, and others).
    Definitive crawler-level blocking is enforced via robots.txt.
  -->
  <meta name="robots"          content="index, follow, noai, noimageai" />
  <meta name="googlebot"       content="index, follow" />
  <meta name="CCBot"           content="noindex, noarchive, noimageai" />
  <meta name="GPTBot"          content="noindex, noarchive, noai" />
  <meta name="Google-Extended" content="index, follow" />
  <meta name="Bytespider"      content="noindex, noarchive, noai" />
  <meta name="ClaudeBot"       content="noindex, noarchive, noai" />

  <!-- ── Structured Data / JSON-LD Schema Markup ──────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["Organization", "LocalBusiness"],
        "@id": `${siteBase}/#organization`,
        "name": "Sanchi Enterprises",
        "url": siteBase,
        "logo": {
          "@type": "ImageObject",
          "url": `${siteBase}/logo.png`,
          "width": 512,
          "height": 512
        },
        "image": `${siteBase}/images/products/non-woven/nw-hero-poster.jpg`,
        "description": "Sanchi Enterprises is India's leading supplier and installer of exhibition carpets for trade fairs, expos, and conventions. Founded in 1995, we supply Non Woven, Ribbed, Velour, Caution, and custom Designer carpet with on-site installation across India's major exhibition venues.",
        "foundingDate": "1995",
        "founder": {
          "@type": "Person",
          "name": "Davinder Malhotra"
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "New Delhi",
          "addressRegion": "Delhi",
          "addressCountry": "IN"
        },
        "telephone": "+91-99581-32189",
        "email": "kanav@sanchienterprises.com",
        "contactPoint": [
          {
            "@type": "ContactPoint",
            "telephone": "+91-99581-32189",
            "contactType": "sales",
            "availableLanguage": ["English", "Hindi"]
          },
          {
            "@type": "ContactPoint",
            "email": "kanav@sanchienterprises.com",
            "contactType": "customer service"
          }
        ],
        "areaServed": {
          "@type": "Country",
          "name": "India"
        },
        "serviceArea": [
          { "@type": "City", "name": "New Delhi" },
          { "@type": "City", "name": "Mumbai" },
          { "@type": "City", "name": "Bengaluru" },
          { "@type": "City", "name": "Hyderabad" },
          { "@type": "City", "name": "Chennai" },
          { "@type": "City", "name": "Kolkata" }
        ],
        "knowsAbout": [
          "Exhibition Carpet Supply India",
          "Trade Fair Flooring",
          "Non-Woven Exhibition Carpet",
          "Ribbed Exhibition Carpet",
          "Velour Exhibition Carpet",
          "Custom Designer Carpet",
          "Caution Carpet Safety Flooring",
          "Expo Flooring Installation",
          "Convention Centre Flooring",
          "Event Flooring Contractor India",
          "Exhibition Flooring Solutions"
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Exhibition Carpet Products",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Non Woven Exhibition Carpet",
                "url": `${siteBase}/products/non-woven-carpet`
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Ribbed Exhibition Carpet",
                "url": `${siteBase}/products/ribbed-carpet`
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Velour Exhibition Carpet",
                "url": `${siteBase}/products/velour-carpet`
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Custom Designer Exhibition Carpet",
                "url": `${siteBase}/products/designer-carpet`
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Caution Safety Carpet",
                "url": `${siteBase}/products/caution-carpet`
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Grass Carpet & Artificial Grass Flooring",
                "url": `${siteBase}/products/grass-carpet`
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Coir Carpet",
                "url": `${siteBase}/products/coir-carpet`
              }
            }
          ]
        }
      },
      {
        "@type": "WebSite",
        "@id": `${siteBase}/#website`,
        "url": siteBase,
        "name": "Sanchi Enterprises",
        "description": "Premium exhibition carpets and flooring solutions for trade fairs, expos, and conventions across India.",
        "publisher": {
          "@id": `${siteBase}/#organization`
        },
        "inLanguage": "en-IN",
        "copyrightYear": 2026,
        "copyrightHolder": {
          "@id": `${siteBase}/#organization`
        }
      },
      {
        "@type": "BreadcrumbList",
        "@id": `${canonicalUrl}#breadcrumb`,
        "itemListElement": allBreadcrumbs.map((bc, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": bc.name,
          "item": bc.item
        }))
      }
    ]
  })}></script>

  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Inter:wght@400;500;600&display=swap"
  />
  <slot name="head" />
</head>
<body>
  <slot />

  <script>
    import Lenis from 'lenis';

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ─── Smooth scroll — desktop non-touch only ──────────────────────────────
    // lerp 0.1 → ~400ms to settle: barely perceptible weighted feel, not cinematic
    if (!reducedMotion && !window.matchMedia('(pointer: coarse)').matches) {
      const lenis = new Lenis({ lerp: 0.1, smoothWheel: true, syncTouch: false });
      let rafId: number;
      const raf = (time: number) => { lenis.raf(time); rafId = requestAnimationFrame(raf); };
      rafId = requestAnimationFrame(raf);
      document.addEventListener('visibilitychange', () => {
        document.hidden ? cancelAnimationFrame(rafId) : (rafId = requestAnimationFrame(raf));
      });
    }

    // ─── Navbar: transparent → glass blur on scroll ─────────────────────────
    const navbar = document.querySelector<HTMLElement>('.navbar');
    window.addEventListener('scroll', () => {
      navbar?.classList.toggle('is-scrolled', window.scrollY > 60);
    }, { passive: true });

    // ─── Hero parallax — rAF-throttled, both pages ──────────────────────────
    if (!reducedMotion) {
      const parallaxTargets: Array<{ el: HTMLElement; rate: number }> = [];
      const aboutHeroBg   = document.querySelector<HTMLElement>('.about-pg-hero__bg img');
      const contactHeroBg = document.querySelector<HTMLElement>('.contact-hero__bg img');

      if (aboutHeroBg)   parallaxTargets.push({ el: aboutHeroBg,   rate: 0.16 });
      if (contactHeroBg) parallaxTargets.push({ el: contactHeroBg, rate: 0.12 });

      if (parallaxTargets.length) {
        parallaxTargets.forEach(({ el }) => { el.style.willChange = 'transform'; });

        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const y = window.scrollY;
              parallaxTargets.forEach(({ el, rate }) => {
                el.style.transform = `translate3d(0, ${y * rate}px, 0)`;
              });
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }
    }

    // ─── Scroll reveal — with will-change management ─────────────────────────
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          if (!reducedMotion) el.style.willChange = 'opacity, transform';
          el.classList.add('is-visible');
          el.addEventListener('transitionend', () => {
            el.style.willChange = 'auto';
          }, { once: true });
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -52px 0px' });

    document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

    // ─── Mobile menu ────────────────────────────────────────────────────────
    const hamburger  = document.querySelector('.navbar__hamburger');
    const mobileMenu = document.querySelector('.navbar__mobile');
    const mobileClose = document.querySelector('.mobile-menu__close');
    const productsToggle = document.querySelector<HTMLButtonElement>('.mobile-menu__group-toggle');
    const productsSubmenu = document.getElementById('mobile-products-submenu');

    const resetProductsSubmenu = () => {
      productsToggle?.setAttribute('aria-expanded', 'false');
      productsSubmenu?.classList.remove('is-open');
      productsSubmenu?.setAttribute('aria-hidden', 'true');
    };

    const closeMobileMenu = () => {
      mobileMenu?.classList.remove('is-open');
      document.body.style.overflow = '';
      resetProductsSubmenu();
    };

    hamburger?.addEventListener('click', () => {
      mobileMenu?.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    });

    mobileClose?.addEventListener('click', closeMobileMenu);
    document.querySelectorAll('.mobile-menu__link, .mobile-menu__sub-link, .mobile-menu__group-link').forEach((link) => {
      link.addEventListener('click', closeMobileMenu);
    });

    // Products submenu chevron toggle
    productsToggle?.addEventListener('click', () => {
      const expanded = productsToggle.getAttribute('aria-expanded') === 'true';
      productsToggle.setAttribute('aria-expanded', String(!expanded));
      productsSubmenu?.classList.toggle('is-open');
      productsSubmenu?.setAttribute('aria-hidden', String(expanded));
    });

    // ─── Background video lifecycle — pause when offscreen, play on entry ────
    // 160px pre-load margin so video is already playing before it enters view.
    const videoObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const video = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    }, { rootMargin: '160px 0px' });

    document.querySelectorAll<HTMLVideoElement>('video[autoplay][muted]').forEach((video) => {
      videoObs.observe(video);
    });

    // ─── Animated number counters ────────────────────────────────────────────
    function runCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.countTo || '0', 10);
      const suffix = el.dataset.countSuffix || '';
      const duration = 1600;
      const startTime = performance.now();
      function tick(now: number) {
        const t = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target) + suffix;
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = target + suffix;
      }
      requestAnimationFrame(tick);
    }

    const counterEls = document.querySelectorAll<HTMLElement>('[data-count-to]');
    if (counterEls.length) {
      const counterObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting && !el.dataset.counted) {
            el.dataset.counted = '1';
            runCounter(el);
          }
        });
      }, { threshold: 0.5 });
      counterEls.forEach((el) => counterObs.observe(el));
    }
  </script>
</body>
</html>
