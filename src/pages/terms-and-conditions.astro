---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = 'May 2026';
---

<Layout
  title="Terms and Conditions — Sanchi Enterprises"
  description="Terms and conditions for using the Sanchi Enterprises website and engaging our exhibition carpet supply and installation services across India."
  breadcrumbs={[{ name: 'Terms and Conditions', item: 'https://sanchienterprises.com/terms-and-conditions' }]}
>
  <Navbar />
  <main>

    <section class="legal-hero" aria-labelledby="terms-heading">
      <div class="container">
        <div class="legal-hero__inner">
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate>Legal</span>
          <h1 class="legal-hero__title" id="terms-heading" data-animate data-delay="1">
            Terms and Conditions
          </h1>
          <p class="legal-hero__meta" data-animate data-delay="2">
            Sanchi Enterprises &nbsp;·&nbsp; Last updated {lastUpdated}
          </p>
          <p class="legal-hero__intro" data-animate data-delay="3">
            These terms govern your use of this website and the basis on which we provide
            exhibition carpet supply and installation services. Please read them carefully.
          </p>
        </div>
      </div>
    </section>

    <div class="legal-body">
      <div class="container">
        <div class="legal-content">

          <section class="legal-section" aria-labelledby="tc-s1">
            <h2 class="legal-section__title" id="tc-s1">1. About Sanchi Enterprises</h2>
            <p>
              Sanchi Enterprises is an exhibition carpet supply and installation business
              incorporated and operating in India, with offices in New Delhi and Mumbai.
              Founded in 1995, we supply Non Woven, Ribbed, Velour, Caution, and custom
              Designer carpet for trade fairs, expos, and conventions across India.
            </p>
            <p>
              These terms apply to use of this website (<strong>sanchienterprises.com</strong>)
              and to any service engagement that originates from an enquiry made through it.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s2">
            <h2 class="legal-section__title" id="tc-s2">2. Acceptance of Terms</h2>
            <p>
              By accessing or using this website, you agree to be bound by these terms.
              If you do not agree, do not use the website. These terms apply to all visitors,
              whether browsing the product catalogue or submitting an enquiry.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s3">
            <h2 class="legal-section__title" id="tc-s3">3. Nature of Website Enquiries</h2>
            <p>
              This website is a marketing and enquiry platform. Submitting the contact form
              does not constitute a binding order or contract. An enquiry expresses your
              interest in our services and initiates a conversation with our team.
            </p>
            <p>
              A binding agreement is only formed when both parties have agreed in writing
              (including by email or WhatsApp message) to the specific terms of supply:
              product specifications, quantities, pricing, event dates, delivery, and
              installation scope.
            </p>
            <p>
              Pricing shown on this website, where any is indicated, is indicative only.
              All pricing is subject to confirmation based on your specific requirements,
              order volume, event dates, and current stock availability.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s4">
            <h2 class="legal-section__title" id="tc-s4">4. Services</h2>
            <p>
              We provide the following services to B2B clients in the exhibition industry:
            </p>
            <ul>
              <li>Supply of exhibition carpet in standard and custom specifications</li>
              <li>Cutting carpet to floor plan dimensions</li>
              <li>On-site carpet laying and installation</li>
              <li>Edge finishing and cable tray coverage</li>
              <li>Live-day on-ground flooring support</li>
              <li>Post-event carpet removal (where agreed)</li>
              <li>Custom printed designer carpet production</li>
            </ul>
            <p>
              Service availability, lead times, and coverage areas are subject to our
              operational capacity at the time of engagement. We will advise on any
              limitations when responding to your enquiry.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s5">
            <h2 class="legal-section__title" id="tc-s5">5. Intellectual Property</h2>
            <p>
              All content on this website — including but not limited to text, photography,
              product descriptions, brand identity, graphic design, HTML markup, CSS, and
              JavaScript — is the intellectual property of Sanchi Enterprises and is protected
              under the Copyright Act 1957 (India) and applicable international copyright law.
            </p>
            <p>
              You may view and print pages for your own personal reference. You may not reproduce,
              republish, distribute, sell, modify, or create derivative works from any part of
              this website without prior written consent from Sanchi Enterprises.
            </p>
            <p>
              For the full policy on permitted and prohibited uses, see our
              <a href="/copyright-policy">Copyright Policy</a>.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s6">
            <h2 class="legal-section__title" id="tc-s6">6. Accuracy of Information</h2>
            <p>
              We maintain this website with reasonable care and aim to keep product information,
              shade availability, and specifications accurate. However, we do not warrant that
              all information is current, complete, or error-free at all times.
            </p>
            <p>
              Shade colours reproduced on screen may differ from physical samples due to
              monitor calibration, compression, and lighting conditions at the time of
              photography. Contact us for physical samples before placing a large order.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s7">
            <h2 class="legal-section__title" id="tc-s7">7. Third-Party Links</h2>
            <p>
              This website contains links to external platforms including WhatsApp and social
              media profiles. These links are provided for convenience. We are not responsible
              for the content, availability, or privacy practices of external websites.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s8">
            <h2 class="legal-section__title" id="tc-s8">8. Limitation of Liability</h2>
            <p>
              To the maximum extent permitted by applicable law, Sanchi Enterprises shall not
              be liable for any indirect, incidental, consequential, or punitive damages arising
              from your use of this website or reliance on information published on it.
            </p>
            <p>
              Our total liability for any claim arising from use of this website, where not
              excluded, shall not exceed the amount paid by you (if any) for the specific
              service giving rise to the claim.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s9">
            <h2 class="legal-section__title" id="tc-s9">9. Prohibited Use</h2>
            <p>You must not use this website to:</p>
            <ul>
              <li>Engage in any activity that is unlawful under Indian law</li>
              <li>Scrape, harvest, or systematically extract content or data</li>
              <li>Use automated bots, crawlers, or scripts to access content without authorisation</li>
              <li>Use our content to train artificial intelligence or machine learning models</li>
              <li>Impersonate Sanchi Enterprises or misrepresent any association with us</li>
              <li>Transmit spam, malware, or any harmful code</li>
            </ul>
          </section>

          <section class="legal-section" aria-labelledby="tc-s10">
            <h2 class="legal-section__title" id="tc-s10">10. Governing Law and Jurisdiction</h2>
            <p>
              These terms are governed by the laws of India. Any disputes arising from or in
              connection with these terms or your use of this website shall be subject to the
              exclusive jurisdiction of the courts of New Delhi, India.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s11">
            <h2 class="legal-section__title" id="tc-s11">11. Changes to These Terms</h2>
            <p>
              We may revise these terms at any time by updating this page. The "Last updated"
              date above reflects the current version. Continued use of the website following
              a revision constitutes acceptance of the updated terms.
            </p>
          </section>

          <section class="legal-section" aria-labelledby="tc-s12">
            <h2 class="legal-section__title" id="tc-s12">12. Contact</h2>
            <p>
              For any questions about these terms, contact us at:<br />
              <strong>Sanchi Enterprises</strong><br />
              Email: <a href="mailto:kanav@sanchienterprises.com">kanav@sanchienterprises.com</a><br />
              Phone: <a href="tel:+919958132189">+91 99581 32189</a>
            </p>
          </section>

        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .legal-hero {
    background-color: var(--color-navy-dark);
    padding: var(--sp-8) 0 var(--sp-7);
    position: relative;
    overflow: hidden;
  }
  .legal-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(27,42,107,0.30) 0%, transparent 62%);
    pointer-events: none;
  }
  .legal-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }
  .legal-hero__title {
    font-family: var(--font-display);
    font-size: clamp(34px, 4.5vw, 56px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--color-text-inverse);
    margin-bottom: var(--sp-2);
  }
  .legal-hero__meta {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(247,246,243,0.40);
    margin-bottom: var(--sp-3);
  }
  .legal-hero__intro {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.72;
    color: rgba(247,246,243,0.64);
    max-width: 560px;
  }

  .legal-body {
    background-color: var(--color-warm-white);
    padding: var(--sp-7) 0 var(--sp-8);
  }
  .legal-content {
    max-width: 720px;
  }

  .legal-section {
    padding-bottom: var(--sp-6);
    margin-bottom: var(--sp-6);
    border-bottom: 1px solid var(--color-border-light);
  }
  .legal-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .legal-section__title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-navy-dark);
    margin-bottom: var(--sp-3);
    line-height: 1.2;
  }
  .legal-section__subtitle {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-2);
  }
  .legal-section p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.82;
    color: var(--color-text-primary);
    opacity: 0.82;
    margin-bottom: var(--sp-3);
  }
  .legal-section p:last-child { margin-bottom: 0; }
  .legal-section ul,
  .legal-section ol {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.82;
    color: var(--color-text-primary);
    opacity: 0.82;
    padding-left: var(--sp-4);
    margin-bottom: var(--sp-3);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .legal-section a {
    color: var(--color-navy);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .legal-section a:hover { color: var(--color-navy-dark); }

  @media (max-width: 768px) {
    .legal-hero { padding: var(--sp-7) 0 var(--sp-6); }
    .legal-section__title { font-size: 18px; }
  }
</style>
