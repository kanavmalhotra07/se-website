---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found — Sanchi Enterprises"
  description="The page you were looking for doesn't exist. Browse our exhibition carpet range or contact our team."
>
  <Navbar />
  <main>

    <section class="not-found">
      <div class="not-found__bg" aria-hidden="true"></div>
      <div class="not-found__inner container">

        <span class="not-found__code" aria-hidden="true">404</span>

        <div class="not-found__content">
          <span class="eyebrow eyebrow--inverse eyebrow--line">Page Not Found</span>
          <h1 class="not-found__title">
            This floor<br />hasn't been laid yet.
          </h1>
          <p class="not-found__sub">
            The page you're looking for doesn't exist or may have moved.
            Try browsing our product range or get in touch directly.
          </p>

          <div class="not-found__actions">
            <a href="/products" class="btn btn--hero-primary">Browse Products</a>
            <a href="/contact"  class="btn btn--ghost-light">Contact Us</a>
          </div>

          <nav class="not-found__links" aria-label="Key pages">
            <a href="/"                              class="not-found__link">Home</a>
            <a href="/products/non-woven-carpet"     class="not-found__link">Non Woven Carpet</a>
            <a href="/products/ribbed-carpet"        class="not-found__link">Ribbed Carpet</a>
            <a href="/products/velour-carpet"        class="not-found__link">Velour Carpet</a>
            <a href="/products/loop-pile-carpet"     class="not-found__link">Loop Pile</a>
            <a href="/products/designer-carpet"      class="not-found__link">Designer Carpet</a>
            <a href="/products/caution-carpet"       class="not-found__link">Caution Carpet</a>
            <a href="/products/grass-carpet"         class="not-found__link">Grass Carpet</a>
            <a href="/products/coir-carpet"          class="not-found__link">Coir Carpet</a>
            <a href="/about"                         class="not-found__link">About</a>
          </nav>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .not-found {
    position: relative;
    min-height: 100vh;
    background: var(--color-navy-dark);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .not-found__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 60% 40%, rgba(184,150,58,0.06) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(27,42,107,0.5) 0%, transparent 60%);
    pointer-events: none;
  }

  .not-found__code {
    position: absolute;
    top: 50%;
    right: -2%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(160px, 22vw, 320px);
    font-weight: 800;
    line-height: 1;
    color: rgba(255,255,255,0.03);
    letter-spacing: -0.04em;
    pointer-events: none;
    user-select: none;
  }

  .not-found__inner {
    position: relative;
    z-index: 1;
    padding-top: 140px;
    padding-bottom: 100px;
    max-width: 680px;
  }

  .not-found__title {
    font-family: var(--font-serif);
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .not-found__sub {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: rgba(247,246,243,0.6);
    max-width: 480px;
    margin-bottom: var(--sp-5);
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-6);
  }

  .not-found__links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    border-top: 1px solid rgba(247,246,243,0.08);
    padding-top: var(--sp-4);
  }

  .not-found__link {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(247,246,243,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .not-found__link:hover {
    color: var(--color-gold);
  }

  @media (max-width: 768px) {
    .not-found__code {
      font-size: clamp(120px, 35vw, 200px);
      right: -5%;
      opacity: 0.6;
    }

    .not-found__inner {
      padding-top: 110px;
      padding-bottom: 80px;
    }

    .not-found__actions {
      flex-direction: column;
    }

    .not-found__actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
