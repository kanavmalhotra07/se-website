---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const venues = [
  { name: 'Pragati Maidan',               loc: 'New Delhi',        coord: '28.6°N · 77.2°E' },
  { name: 'Yashobhoomi',                  loc: 'Dwarka, Delhi',    coord: '28.6°N · 77.1°E' },
  { name: 'Jio World Convention Centre',  loc: 'Mumbai',           coord: '19.0°N · 72.8°E' },
  { name: 'Bombay Exhibition Centre',     loc: 'Mumbai',           coord: '19.1°N · 72.9°E' },
  { name: 'BIEC',                         loc: 'Bengaluru',        coord: '13.0°N · 77.5°E' },
  { name: 'HITEX',                        loc: 'Hyderabad',        coord: '17.4°N · 78.5°E' },
  { name: 'India Expo Centre',            loc: 'Greater Noida',    coord: '28.5°N · 77.4°E' },
  { name: 'NSIC Exhibition Complex',      loc: 'Okhla, New Delhi', coord: '28.5°N · 77.2°E' },
  { name: 'Chennai Trade Centre',         loc: 'Chennai',          coord: '13.1°N · 80.2°E' },
];

const whyItems = [
  {
    num: '01',
    title: 'Multi-Hall Coverage',
    desc: 'Supply and installation across multiple halls at the same event, simultaneously. Pragati Maidan, Yashobhoomi, and BIEC covered in parallel when required.',
  },
  {
    num: '02',
    title: 'Overnight Install Windows',
    desc: 'Full hall floor coverage completed within the move-in window. No delayed finishes. No catch-up crews on the morning of day one.',
  },
  {
    num: '03',
    title: 'National Stock Backbone',
    desc: 'Carpet inventory maintained in both Delhi and Mumbai. Short lead times for North and West India assignments without inter-city logistics delays.',
  },
  {
    num: '04',
    title: 'Year-on-Year Retention',
    desc: 'Organizers return event after event. Not because of the lowest quote, but because the floor is right every single time.',
  },
];

const opsItems = [
  {
    num: '01',
    title: 'Exhibition Carpet Supply',
    desc: 'Large-volume stock across non-woven, ribbed, velour, and caution grades. Available for bulk supply on tight lead times.',
    icon: `<svg viewBox="0 0 44 36" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="22" cy="9" rx="14" ry="5" stroke-width="1.5"/><line x1="8" y1="9" x2="8" y2="27" stroke-width="1.5"/><line x1="36" y1="9" x2="36" y2="27" stroke-width="1.5"/><ellipse cx="22" cy="27" rx="14" ry="5" stroke-width="1.5"/><line x1="15" y1="9" x2="15" y2="27" stroke-width="0.75" stroke-dasharray="2.5 2.5"/><line x1="22" y1="4" x2="22" y2="32" stroke-width="0.75" stroke-dasharray="2.5 2.5"/><line x1="29" y1="9" x2="29" y2="27" stroke-width="0.75" stroke-dasharray="2.5 2.5"/></svg>`,
  },
  {
    num: '02',
    title: 'On-Site Installation',
    desc: 'Full floor coverage, edge finishing, cutting to plan, seam management, and stall-boundary accuracy. All done by our own installation team.',
    icon: `<svg viewBox="0 0 44 36" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="15" width="36" height="19" stroke-width="1.5"/><line x1="4" y1="23" x2="40" y2="23" stroke-width="0.75"/><line x1="4" y1="29" x2="40" y2="29" stroke-width="0.75"/><line x1="16" y1="15" x2="16" y2="34" stroke-width="0.75"/><line x1="28" y1="15" x2="28" y2="34" stroke-width="0.75"/><circle cx="22" cy="7" r="3" stroke-width="1.5"/><path d="M22 10v5M18.5 14l3.5-1 3.5 1" stroke-width="1.5"/></svg>`,
  },
  {
    num: '03',
    title: 'Live-Day Floor Support',
    desc: 'Present on-site during event open days for repairs, adjustments, and any flooring issue that emerges during live operations.',
    icon: `<svg viewBox="0 0 44 36" fill="none" stroke="currentColor" stroke-linecap="round"><circle cx="22" cy="18" r="12" stroke-width="1.5"/><line x1="22" y1="18" x2="22" y2="11" stroke-width="1.5"/><line x1="22" y1="18" x2="27" y2="18" stroke-width="1.5"/><line x1="22" y1="6.5" x2="22" y2="8.5" stroke-width="1.5"/><line x1="22" y1="27.5" x2="22" y2="29.5" stroke-width="1.5"/><line x1="10.5" y1="18" x2="12.5" y2="18" stroke-width="1.5"/><line x1="31.5" y1="18" x2="33.5" y2="18" stroke-width="1.5"/></svg>`,
  },
];

const qualityPoints = [
  'Dimensional stability and durability under heavy footfall',
  'Colour consistency across large roll batches, same shade lot across the entire hall',
  'Edge finishing held to organizer and exhibitor tolerances',
  'Every installation follows the approved floor layout, stall boundaries precise',
  'Floor inspection completed before handover to client or organizer',
];

const galleryImages = [
  { src: '/images/about/designer-dsc09616.jpg', alt: 'Anuga FoodTec India Dairy, New Delhi',  wide: true,  pos: 'center 45%'   },
  { src: '/images/about/art-fair-1.jpg',        alt: 'India Art Fair, New Delhi',             wide: false, pos: 'center center' },
  { src: '/images/about/imw-1.jpg',             alt: 'India Maritime Week, Mumbai',           wide: false, pos: 'center center' },
  { src: '/images/about/gartex-2.jpg',          alt: 'Gartex and Denim Show, Mumbai',        wide: false, pos: 'center 50%'   },
  { src: '/images/about/designer-IMG_0057.jpg', alt: 'India AI Impact Summit 2026',          wide: false, pos: 'center center' },
  { src: '/images/about/ifat-1.jpg',            alt: 'IFAT + Drink Technology, Delhi',       wide: false, pos: 'center center' },
  { src: '/images/about/india-design-5.jpg',    alt: 'India Design, New Delhi',              wide: true,  pos: 'center center' },
];
---

<Layout
  title="About Sanchi Enterprises — Exhibition Flooring Since 1995"
  description="Founded by Davinder Malhotra in 1995, Sanchi Enterprises has been supplying and installing exhibition carpet at India's major trade fairs and expo centres for three decades."
>
  <Navbar />
  <main>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section class="about-pg-hero" aria-labelledby="about-heading">
      <div class="about-pg-hero__bg" aria-hidden="true">
        <img
          src="/images/about/ai-summit-hero.jpg"
          alt=""
          width="1600"
          height="900"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="about-pg-hero__dot-grid" aria-hidden="true"></div>
      <div class="about-pg-hero__overlay" aria-hidden="true"></div>
      <div class="about-pg-hero__vignette" aria-hidden="true"></div>
      <div class="about-pg-hero__scan-line" aria-hidden="true"></div>
      <div class="about-pg-hero__year" aria-hidden="true">1995</div>

      <div class="about-pg-hero__content">
        <div class="about-pg-hero__inner">
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate>About Sanchi Enterprises</span>
          <h1 class="about-pg-hero__title" id="about-heading" data-animate data-delay="1">
            Exhibition Flooring<br />Expertise Since 1995.
          </h1>
          <p class="about-pg-hero__sub" data-animate data-delay="2">
            Three decades of on-site delivery across India's major trade fairs,
            expo halls, and convention centres.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── MARQUEE BAND ─────────────────────────────────────────────────── -->
    <div class="about-pg-band" aria-label="Company positioning">
      <div class="about-pg-band__track">
        <div class="about-pg-band__segment">
          <span class="about-pg-band__text">Not consultants. Not catalogue suppliers.</span>
          <span class="about-pg-band__em">A team that turns up and gets the floor done.</span>
          <span class="about-pg-band__dot" aria-hidden="true">✦</span>
        </div>
        <div class="about-pg-band__segment" aria-hidden="true">
          <span class="about-pg-band__text">Not consultants. Not catalogue suppliers.</span>
          <span class="about-pg-band__em">A team that turns up and gets the floor done.</span>
          <span class="about-pg-band__dot" aria-hidden="true">✦</span>
        </div>
        <div class="about-pg-band__segment" aria-hidden="true">
          <span class="about-pg-band__text">Not consultants. Not catalogue suppliers.</span>
          <span class="about-pg-band__em">A team that turns up and gets the floor done.</span>
          <span class="about-pg-band__dot" aria-hidden="true">✦</span>
        </div>
        <div class="about-pg-band__segment" aria-hidden="true">
          <span class="about-pg-band__text">Not consultants. Not catalogue suppliers.</span>
          <span class="about-pg-band__em">A team that turns up and gets the floor done.</span>
          <span class="about-pg-band__dot" aria-hidden="true">✦</span>
        </div>
      </div>
    </div>

    <!-- ─── SCALE METRICS ─────────────────────────────────────────────────── -->
    <section class="about-pg-scale" aria-label="Scale of operations">
      <div class="container">
        <div class="about-pg-scale__grid">
          <div class="about-pg-scale__item" data-animate>
            <div class="about-pg-scale__number" data-count-to="10" data-count-suffix="M+">10M+</div>
            <div class="about-pg-scale__label">sq. m installed</div>
          </div>
          <div class="about-pg-scale__rule" aria-hidden="true"></div>
          <div class="about-pg-scale__item" data-animate data-delay="1">
            <div class="about-pg-scale__number" data-count-to="500" data-count-suffix="+">500+</div>
            <div class="about-pg-scale__label">events delivered</div>
          </div>
          <div class="about-pg-scale__rule" aria-hidden="true"></div>
          <div class="about-pg-scale__item" data-animate data-delay="2">
            <div class="about-pg-scale__number" data-count-to="30" data-count-suffix="+">30+</div>
            <div class="about-pg-scale__label">years in operation</div>
          </div>
          <div class="about-pg-scale__rule" aria-hidden="true"></div>
          <div class="about-pg-scale__item" data-animate data-delay="3">
            <div class="about-pg-scale__number" data-count-to="15" data-count-suffix="+">15+</div>
            <div class="about-pg-scale__label">dedicated install crew</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── COMPANY STORY — full-edge split layout ───────────────────────── -->
    <section class="about-pg-story" aria-labelledby="story-heading">
      <div class="about-pg-story__split">

        <!-- Left: image bleeds to viewport edge, no container constraint -->
        <div class="about-pg-story__img-side" data-animate="image">
          <img
            class="about-pg-story__img"
            src="/images/about/gartex-3.jpg"
            alt="Gartex trade fair, India — large-scale carpet installation in progress"
            loading="lazy"
            decoding="async"
            width="800"
            height="1000"
          />
          <div class="about-pg-story__img-gradient" aria-hidden="true"></div>

          <!-- Stats integrated into image bottom -->
          <div class="about-pg-story__stats-strip">
            <div class="about-pg-story__stat-cell">
              <div class="about-pg-story__stat-num" data-count-to="30" data-count-suffix="+">30+</div>
              <div class="about-pg-story__stat-lbl">Years</div>
            </div>
            <div class="about-pg-story__stat-cell">
              <div class="about-pg-story__stat-num" data-count-to="5">5</div>
              <div class="about-pg-story__stat-lbl">Carpet Grades</div>
            </div>
            <div class="about-pg-story__stat-cell">
              <div class="about-pg-story__stat-num">Pan&#8209;India</div>
              <div class="about-pg-story__stat-lbl">Coverage</div>
            </div>
          </div>
        </div>

        <!-- Right: text column, stone background, internal padding -->
        <div class="about-pg-story__text-side" data-animate data-delay="1">
          <div class="about-pg-story__text-pad">
            <span class="eyebrow eyebrow--line">Our Story</span>
            <h2 class="about-pg-story__title" id="story-heading">
              Founded in 1995.<br />Still on the Floor.
            </h2>
            <p class="about-pg-story__text">
              Sanchi Enterprises was founded by Mr. Davinder Malhotra in New Delhi in 1995,
              at a time when India's exhibition industry was beginning its long period of growth.
              From the outset, the business focused on a single category: carpet flooring for
              trade fairs, expos, and large-scale conventions.
            </p>
            <p class="about-pg-story__text">
              Kanav Malhotra joined and continued the focus the business was built on.
              Supply and installation of exhibition carpet across India's major venues.
              The scope of work is the same. The scale has grown.
            </p>
            <p class="about-pg-story__text">
              Today, Sanchi Enterprises operates across New Delhi, Mumbai, and pan-India
              assignments, supplying non-woven, ribbed, velour, caution, and designer carpet
              for some of India's largest trade fairs and international expo events.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── OPERATIONAL EXPERTISE ─────────────────────────────────────────── -->
    <section class="about-pg-ops" aria-labelledby="ops-heading">
      <div class="container">
        <div class="about-pg-ops__inner">
          <div class="about-pg-ops__header" data-animate>
            <span class="eyebrow eyebrow--inverse eyebrow--line">What We Do</span>
            <h2 class="about-pg-ops__title" id="ops-heading">
              Supply, Installation,<br />and Live-Day Execution.
            </h2>
            <p class="about-pg-ops__lead">
              All three handled as one operation, not three separate vendors.
            </p>
          </div>

          <div class="about-pg-ops__grid">
            {opsItems.map((item, i) => (
              <div class="about-pg-ops__item" data-animate data-delay={String(i)}>
                <div class="about-pg-ops__item-meta">
                  <div class="about-pg-ops__icon" aria-hidden="true" set:html={item.icon}></div>
                  <span class="about-pg-ops__num">{item.num}</span>
                </div>
                <div class="about-pg-ops__item-title">{item.title}</div>
                <p class="about-pg-ops__desc">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── QUALITY — cinematic full-bleed photo + editorial content ──────── -->
    <section class="about-pg-quality" aria-labelledby="quality-heading">

      <!-- Full-bleed cinematic video: installation work in progress -->
      <div class="about-pg-quality__visual" data-animate="image">
        <video
          class="about-pg-quality__visual-img"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/images/about/installation-1.jpg"
          aria-hidden="true"
        >
          <source src="/videos/wip/wip-installation-1.mp4" type="video/mp4" />
        </video>
        <div class="about-pg-quality__visual-veil" aria-hidden="true"></div>
        <div class="about-pg-quality__visual-badge" aria-hidden="true">
          <span class="eyebrow eyebrow--inverse eyebrow--line">Quality Standards</span>
        </div>
      </div>

      <!-- Editorial 2-col content below the photo -->
      <div class="about-pg-quality__content">
        <div class="container">
          <div class="about-pg-quality__content-row">

            <div class="about-pg-quality__body" data-animate>
              <h2 class="about-pg-quality__title" id="quality-heading">
                Exhibition-Grade.<br />Every Installation.
              </h2>
              <p class="about-pg-quality__text">
                Exhibition carpet is a working surface. It needs to lie flat under heavy
                footfall, hold its edges through repeated stall builds, and deliver
                consistent colour across an entire hall. Often that means hundreds of
                square metres laid in a single overnight session.
              </p>
              <p class="about-pg-quality__text">
                Every material we supply meets exhibition-grade specification.
                Every installation follows the approved floor layout.
                The finish is consistent, not approximate.
              </p>
            </div>

            <div class="about-pg-quality__checklist" data-animate data-delay="1">
              {qualityPoints.map((point) => (
                <div class="about-pg-quality__point">
                  <div class="about-pg-quality__dot" aria-hidden="true"></div>
                  <span class="about-pg-quality__point-text">{point}</span>
                </div>
              ))}
            </div>

          </div>
        </div>
      </div>

    </section>

    <!-- ─── NATIONWIDE PRESENCE ───────────────────────────────────────────── -->
    <section class="about-pg-presence" aria-labelledby="presence-heading">
      <div class="container">
        <div class="about-pg-presence__header" data-animate>
          <span class="eyebrow eyebrow--line">Where We Work</span>
          <h2 class="prod-section__title" id="presence-heading">
            India's Major Exhibition Venues.
          </h2>
        </div>
        <p class="about-pg-presence__intro" data-animate data-delay="1">
          From New Delhi's Pragati Maidan to Mumbai's Jio World Convention Centre, Sanchi
          Enterprises installs exhibition carpet at India's largest and most active trade fair
          and expo venues.
        </p>
      </div>

      <div class="about-pg-presence__scroll-outer" data-animate data-delay="2">
        <div class="about-pg-presence__venues">
          {venues.map((v) => (
            <div class="about-pg-presence__venue">
              <svg class="about-pg-presence__venue-icon" viewBox="0 0 32 20" fill="none" aria-hidden="true">
                <rect x="0.5" y="0.5" width="31" height="19" stroke="currentColor" stroke-width="0.75"/>
                <line x1="0.5" y1="7" x2="31.5" y2="7" stroke="currentColor" stroke-width="0.5"/>
                <line x1="0.5" y1="13" x2="31.5" y2="13" stroke="currentColor" stroke-width="0.5"/>
                <line x1="11" y1="0.5" x2="11" y2="19.5" stroke="currentColor" stroke-width="0.5"/>
                <line x1="21" y1="0.5" x2="21" y2="19.5" stroke="currentColor" stroke-width="0.5"/>
              </svg>
              <div class="about-pg-presence__venue-name">{v.name}</div>
              <div class="about-pg-presence__venue-loc">{v.loc}</div>
              <div class="about-pg-presence__venue-coord">{v.coord}</div>
            </div>
          ))}
        </div>
        <div class="about-pg-presence__scroll-hint" aria-hidden="true">
          <span>Drag to explore</span>
          <svg width="28" height="10" viewBox="0 0 28 10" fill="none">
            <line x1="0" y1="5" x2="23" y2="5" stroke="currentColor" stroke-width="1"/>
            <polyline points="19,1 24,5 19,9" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- ─── WHY ORGANIZERS CHOOSE US — timeline vertical list ─────────────── -->
    <section class="about-pg-why" aria-labelledby="why-heading">
      <div class="container">
        <div class="about-pg-why__top" data-animate>
          <span class="eyebrow eyebrow--line">Operational Capability</span>
          <h2 class="about-pg-why__heading" id="why-heading">
            Built to Operate<br />at Scale.
          </h2>
        </div>
        <div class="about-pg-why__list" data-animate data-delay="1">
          <div class="about-pg-why__spine" aria-hidden="true"></div>
          {whyItems.map((item, i) => (
            <div class="about-pg-why__item">
              <div class="about-pg-why__num" aria-hidden="true">{item.num}</div>
              <div class="about-pg-why__body">
                <div class="about-pg-why__title">{item.title}</div>
                <p class="about-pg-why__desc">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── GALLERY ───────────────────────────────────────────────────────── -->
    <section class="about-pg-gallery" aria-labelledby="gallery-heading">
      <div class="container">
        <div class="about-pg-gallery__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Installations</span>
          <h2 class="prod-section__title prod-section--dark" id="gallery-heading"
              style="color:var(--color-text-inverse);margin-top:var(--sp-2);">
            Across India's Trade Fairs.
          </h2>
        </div>
        <div class="about-pg-gallery__grid">
          {galleryImages.map((img, i) => (
            <div
              class={`about-pg-gallery__item${img.wide ? ' about-pg-gallery__item--w2' : ''}`}
              data-animate
              data-delay={i > 0 ? String(i) : undefined}
            >
              <img
                src={img.src}
                alt={img.alt}
                loading="lazy"
                decoding="async"
                width="800"
                height="600"
                style={`object-position:${img.pos}`}
              />
              <div class="about-pg-gallery__overlay">
                <span class="about-pg-gallery__caption">{img.alt}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Check Installation Availability</div>
            <p class="prod-cta__sub">
              Tell us your event, venue, and dates. We'll confirm carpet availability,
              installation scope, and site logistics within 24 hours.
            </p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Get a Flooring Plan</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Talk to Installation Team
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />

  <script>
    // Gallery cursor spotlight + inter-card dimming
    const galleryGrid = document.querySelector<HTMLElement>('.about-pg-gallery__grid');
    if (galleryGrid) {
      galleryGrid.addEventListener('mousemove', (e) => {
        const rect = galleryGrid.getBoundingClientRect();
        galleryGrid.style.setProperty('--gal-x', `${e.clientX - rect.left}px`);
        galleryGrid.style.setProperty('--gal-y', `${e.clientY - rect.top}px`);
      }, { passive: true });
    }

    // Video autoplay safety: ensure WIP video plays on low-power mode
    const qualityVideo = document.querySelector<HTMLVideoElement>('.about-pg-quality__visual-img');
    if (qualityVideo) {
      qualityVideo.play().catch(() => {});
    }
  </script>
</Layout>
