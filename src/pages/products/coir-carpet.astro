---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const applications = [
  'Exhibition Entrances',
  'Organic Brand Pavilions',
  'Eco-themed Events',
  'Natural Product Showcases',
  'Hospitality Lounge Areas',
  'Sustainability-themed Events',
  'Boutique Exhibition Stalls',
  'Heritage & Craft Displays',
];

const faqs = [
  {
    q: 'What is coir carpet made from?',
    a: 'Coir carpet is woven from natural coconut husk fibre — extracted from coconut shells, processed into yarn, and woven into flat or textured matting. It is a renewable, biodegradable natural material with a distinctive coarse texture that synthetic products cannot replicate. Coir has been used in Indian floor coverings for centuries and carries a heritage material quality distinct from modern exhibition carpet.',
  },
  {
    q: 'Where is coir carpet used in exhibitions?',
    a: 'Coir is most commonly specified for exhibition entrance areas and threshold zones, eco-brand pavilions, organic and natural product showcases, sustainability-themed events, and hospitality lounge areas where a natural material surface is part of the design brief. The material reads as tactile, grounded, and natural — appropriate for brands and events where those values are part of the presentation.',
  },
  {
    q: 'Is coir carpet suitable for high-footfall exhibition halls?',
    a: 'Coir is a durable natural fibre suitable for moderate footfall. For main exhibition hall aisles and very high-traffic areas, we recommend ribbed or non woven carpet. Coir is best suited to entrance zones, boutique pavilions, defined highlight areas, and spaces where the natural material character is part of the visual brief.',
  },
  {
    q: 'How do I order coir carpet for an event?',
    a: 'Share your event brief, venue, floor plan dimensions, and event dates. We will confirm the available specification, supply quantity, and installation timeline. Contact us via the enquiry form or WhatsApp.',
  },
];
---

<Layout
  title="Coir Carpet — Natural Fibre Exhibition Flooring | Sanchi Enterprises"
  description="Natural coir carpet woven from coconut husk fibre for exhibition entrances, eco-themed pavilions, organic brand events, and hospitality areas. Supplied and installed across India by Sanchi Enterprises."
  breadcrumbs={[
    { name: 'Products', item: 'https://sanchienterprises.com/products' },
    { name: 'Coir Carpet', item: 'https://sanchienterprises.com/products/coir-carpet' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Product",
          "@id": "https://sanchienterprises.com/products/coir-carpet/#product",
          "name": "Coir Carpet — Natural Fibre Exhibition Flooring",
          "description": "Natural coir carpet woven from coconut husk fibre for exhibition entrances, eco-themed pavilions, organic brand events, and hospitality areas. Supplied and installed across India.",
          "brand": { "@id": "https://sanchienterprises.com/#organization" },
          "url": "https://sanchienterprises.com/products/coir-carpet",
          "offers": {
            "@type": "Offer",
            "availability": "https://schema.org/InStock",
            "priceCurrency": "INR",
            "seller": { "@id": "https://sanchienterprises.com/#organization" }
          },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Material", "value": "Natural coconut husk fibre (coir)" },
            { "@type": "PropertyValue", "name": "Finish", "value": "Natural woven texture — brown / beige tones" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India supply and installation" }
          ]
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <!-- ─── HERO ──────────────────────────────────────────────── -->
    <section class="prod-hero" aria-labelledby="coir-heading">
      <div class="container">
        <div class="prod-hero__inner">
          <a href="/products" class="prod-hero__back">
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate>Coir Carpet</span>
          <h1 class="prod-hero__title" id="coir-heading" data-animate data-delay="1">
            Natural Coconut Fibre<br />Exhibition Flooring.
          </h1>
          <p class="prod-hero__intro" data-animate data-delay="2">
            Coir matting woven from natural coconut husk fibre — for exhibition
            entrances, eco-themed pavilions, and organic brand environments across India.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ABOUT ─────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="coir-about-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">About the Product</span>
          <h2 class="prod-section__title" id="coir-about-heading">A Material Quality<br />No Synthetic Can Match.</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Coir carpet is woven from natural coconut husk fibre — a renewable, biodegradable
          material with a distinctive coarse texture that carries the quality of heritage
          craft. In exhibition environments, coir is specified for entrance mats, organic
          and natural brand pavilions, sustainability-themed events, and wherever a floor
          material that reads as natural and unprocessed is part of the design brief.
        </p>
        <p class="prod-section__body" data-animate data-delay="2">
          Sanchi supplies and installs coir carpet across India's major exhibition venues,
          coordinated with the wider flooring scope where natural materials are being
          combined with standard exhibition carpet. Enquire for specification and
          availability for your event dates.
        </p>
      </div>
    </div>

    <!-- ─── MEDIA ──────────────────────────────────────────────── -->
    <div class="coir-media" aria-label="Coir carpet material photography">
      <div class="coir-media__grid">
        <div class="coir-media__cell coir-media__cell--main" data-animate="image">
          <img
            src="/images/coir/coir-3608.jpg"
            alt="Natural coir carpet — close view of the woven coconut fibre surface texture in natural brown-beige tones"
            loading="lazy"
            decoding="async"
            width="1440"
            height="1080"
          />
        </div>
        <div class="coir-media__cell coir-media__cell--side" data-animate="image" data-delay="1">
          <img
            src="/images/coir/coir-3607.jpg"
            alt="Coir matting detail — natural fibre weave pattern showing the characteristic coarse texture"
            loading="lazy"
            decoding="async"
            width="1440"
            height="1080"
          />
        </div>
      </div>
    </div>

    <!-- ─── APPLICATIONS ──────────────────────────────────────── -->
    <div class="prod-section" aria-labelledby="coir-apps-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title" id="coir-apps-heading">Where Coir Carpet Is Used</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── FAQ ───────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="coir-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="coir-faq-heading">Common Questions</h2>
        </div>
        <dl class="prod-faq" data-animate data-delay="1">
          {faqs.map((faq) => (
            <div class="prod-faq__item">
              <dt class="prod-faq__q">{faq.q}</dt>
              <dd class="prod-faq__a">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ──────────────────────────────────── -->
    <div class="prod-section" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="prod-related" data-animate data-delay="1">
          <a href="/products/grass-carpet" class="prod-related__link">
            <span class="prod-related__name">Grass Carpet</span>
            <span class="prod-related__desc">Synthetic grass for themed exhibition environments</span>
          </a>
          <a href="/products/velour-carpet" class="prod-related__link">
            <span class="prod-related__name">Velour Carpet</span>
            <span class="prod-related__desc">Premium cut-pile finish in 11 shades</span>
          </a>
          <a href="/products/non-woven-carpet" class="prod-related__link">
            <span class="prod-related__name">Non Woven Carpet</span>
            <span class="prod-related__desc">29 shades — industry standard floor coverage</span>
          </a>
          <a href="/products/designer-carpet" class="prod-related__link">
            <span class="prod-related__name">Designer Carpet</span>
            <span class="prod-related__desc">Fully custom printed to your brief</span>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── CTA ───────────────────────────────────────────────── -->
    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Coir Carpet</div>
            <p class="prod-cta__sub">
              Share your event brief, venue, and floor plan.
              We'll confirm specification and availability within 24 hours.
            </p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Media section ────────────────────────────────────────────────── */
  .coir-media {
    background: var(--color-warm-white);
  }
  .coir-media__grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 0;
    overflow: hidden;
  }
  .coir-media__cell {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .coir-media__cell--main { aspect-ratio: 16 / 10; }
  .coir-media__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.8s var(--ease-out, cubic-bezier(0.16,1,0.3,1));
  }
  .coir-media__cell:hover img { transform: scale(1.04); }
  @media (max-width: 768px) {
    .coir-media__grid { grid-template-columns: 1fr; }
    .coir-media__cell--side { display: none; }
  }

  /* ─── FAQ + related ────────────────────────────────────────────────── */
  .prod-faq {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .prod-faq__item {
    border-top: 1px solid rgba(0,0,0,0.08);
    padding-top: var(--sp-4);
  }
  .prod-faq__q {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-navy-dark);
    margin-bottom: var(--sp-2);
    line-height: 1.4;
  }
  .prod-faq__a {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .prod-related {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
  }
  .prod-related__link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-4);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 4px;
    transition: border-color 0.22s ease, background 0.22s ease;
    text-decoration: none;
  }
  .prod-related__link:hover {
    border-color: var(--color-navy);
    background: #EFEDE8;
  }
  .prod-related__name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-navy-dark);
    letter-spacing: -0.01em;
  }
  .prod-related__desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  @media (max-width: 1024px) { .prod-related { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .prod-related { grid-template-columns: 1fr; } }
</style>
