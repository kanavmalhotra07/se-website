---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const applications = [
  'Exhibition Entrances',
  'Organic Brand Pavilions',
  'Eco-themed Events',
  'Natural Product Showcases',
  'Hospitality Lounge Areas',
  'Sustainability-themed Events',
  'Boutique Exhibition Stalls',
  'Heritage & Craft Displays',
];

const faqs = [
  {
    q: 'What is coir carpet made from?',
    a: 'Coir carpet is woven from natural coconut husk fibre — extracted from coconut shells, processed into yarn, and woven into flat or textured matting. It is a renewable, biodegradable natural material with a distinctive coarse texture that synthetic products cannot replicate. Coir has been used in Indian floor coverings for centuries and carries a heritage material quality distinct from modern exhibition carpet.',
  },
  {
    q: 'Where is coir carpet used in exhibitions?',
    a: 'Coir is most commonly specified for exhibition entrance areas and threshold zones, eco-brand pavilions, organic and natural product showcases, sustainability-themed events, and hospitality lounge areas where a natural material surface is part of the design brief. The material reads as tactile, grounded, and natural — appropriate for brands and events where those values are part of the presentation.',
  },
  {
    q: 'Is coir carpet suitable for high-footfall exhibition halls?',
    a: 'Coir is a durable natural fibre suitable for moderate footfall. For main exhibition hall aisles and very high-traffic areas, we recommend ribbed or non woven carpet. Coir is best suited to entrance zones, boutique pavilions, defined highlight areas, and spaces where the natural material character is part of the visual brief.',
  },
  {
    q: 'How do I order coir carpet for an event?',
    a: 'Share your event brief, venue, floor plan dimensions, and event dates. We will confirm the available specification, supply quantity, and installation timeline. Contact us via the enquiry form or WhatsApp.',
  },
];
---

<Layout
  title="Coir Carpet — Natural Fibre Exhibition Flooring | Sanchi Enterprises"
  description="Coir carpet — natural coconut fibre exhibition flooring for trade fair entrances, eco-themed pavilions, organic brand events, and sustainability-focused environments. Supplied and installed across India by Sanchi Enterprises."
  ogImage="https://sanchienterprises.com/images/coir/coir-3608.jpg"
  breadcrumbs={[
    { name: 'Products', item: 'https://sanchienterprises.com/products' },
    { name: 'Coir Carpet', item: 'https://sanchienterprises.com/products/coir-carpet' },
  ]}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/coir/coir-3608.jpg" fetchpriority="high" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Product",
          "@id": "https://sanchienterprises.com/products/coir-carpet/#product",
          "name": "Coir Carpet — Natural Fibre Exhibition Flooring",
          "description": "Natural coir carpet woven from coconut husk fibre for exhibition entrances, eco-themed pavilions, organic brand events, and hospitality areas. Supplied and installed across India.",
          "brand": { "@id": "https://sanchienterprises.com/#organization" },
          "url": "https://sanchienterprises.com/products/coir-carpet",
          "image": "https://sanchienterprises.com/images/coir/coir-3608.jpg",
          "offers": {
            "@type": "Offer",
            "availability": "https://schema.org/InStock",
            "priceCurrency": "INR",
            "seller": { "@id": "https://sanchienterprises.com/#organization" }
          },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Material", "value": "Natural coconut husk fibre (coir)" },
            { "@type": "PropertyValue", "name": "Finish", "value": "Natural woven texture — brown / beige tones" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India supply and installation" }
          ]
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <!-- ─── HERO — full-viewport, video-backed ───────────────────── -->
    <section class="coir-hero" aria-labelledby="coir-heading">
      <div class="coir-hero__media" aria-hidden="true">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="none"
          poster="/images/coir/coir-3608.jpg"
          class="coir-hero__video"
        >
          <source src="/images/coir/coir-video.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="coir-hero__overlay" aria-hidden="true"></div>
      <div class="container">
        <div class="coir-hero__content">
          <a href="/products" class="coir-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Coir Carpet</span>
          <h1 class="coir-hero__title" id="coir-heading" data-animate data-delay="2">
            Natural Coconut Fibre<br />Exhibition Flooring.
          </h1>
          <p class="coir-hero__sub" data-animate data-delay="3">
            Natural coir exhibition flooring woven from coconut husk fibre — for
            trade fair entrances, eco-themed pavilions, and organic brand environments across India.
          </p>
        </div>
      </div>
      <div class="coir-hero__scroll" aria-hidden="true">
        <div class="coir-hero__scroll-line"></div>
      </div>
    </section>

    <!-- ─── STATEMENT ────────────────────────────────────────────── -->
    <div class="coir-statement" aria-label="Product positioning">
      <div class="container">
        <div class="coir-statement__inner" data-animate>
          <p class="coir-statement__text">
            Woven from heritage craft.<br />
            <span class="coir-statement__em">A floor material that carries meaning in every fibre.</span>
          </p>
        </div>
      </div>
    </div>

    <!-- ─── EDITORIAL SPLIT — image left, about text right ──────── -->
    <div class="coir-split" aria-labelledby="coir-about-heading">
      <div class="coir-split__visual" data-animate="image">
        <img
          src="/images/coir/coir-3609.jpg"
          alt="Natural coir carpet woven from coconut husk fibre — surface texture showing the characteristic coarse natural weave in brown-beige tones"
          loading="lazy"
          decoding="async"
          width="1200"
          height="900"
        />
      </div>
      <div class="coir-split__text">
        <div class="coir-split__text-inner" data-animate data-delay="1">
          <span class="eyebrow eyebrow--line">About the Product</span>
          <h2 class="coir-split__title" id="coir-about-heading">
            A Material Quality<br />No Synthetic Can Match.
          </h2>
          <p class="coir-split__body">
            Coir carpet is woven from natural coconut husk fibre — a renewable, biodegradable
            natural fibre exhibition flooring material with a distinctive coarse texture that
            carries the quality of heritage craft. In exhibition environments, coir is specified
            for expo entrances and threshold mats, organic and natural brand pavilions,
            sustainability-themed events, and wherever a floor material that reads as natural
            and unprocessed is part of the design brief.
          </p>
          <p class="coir-split__body">
            Sanchi supplies and installs coir carpet for trade fairs and exhibitions across
            India — coordinated with the wider flooring scope where natural materials are
            being combined with standard exhibition carpet at major venues including Pragati
            Maidan (New Delhi), India Expo Centre (Greater Noida), and BIEC (Bengaluru).
            Enquire for specification and availability for your event dates.
          </p>
        </div>
      </div>
    </div>

    <!-- ─── APPLICATIONS ─────────────────────────────────────────── -->
    <div class="prod-section" aria-labelledby="coir-apps-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title" id="coir-apps-heading">Where Coir Carpet Is Used</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── SPEC STRIP ────────────────────────────────────────────── -->
    <div class="coir-specs" aria-label="Product specification">
      <div class="container">
        <div class="coir-specs__grid" data-animate>
          <div class="coir-specs__item">
            <span class="coir-specs__label">Material</span>
            <span class="coir-specs__value">Natural coconut husk fibre</span>
          </div>
          <div class="coir-specs__item">
            <span class="coir-specs__label">Finish</span>
            <span class="coir-specs__value">Woven — natural brown &amp; beige tones</span>
          </div>
          <div class="coir-specs__item">
            <span class="coir-specs__label">Coverage</span>
            <span class="coir-specs__value">Pan-India supply &amp; installation</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── FAQ ──────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="coir-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="coir-faq-heading">Common Questions</h2>
        </div>
        <dl class="coir-faq" data-animate data-delay="1">
          {faqs.map((faq) => (
            <div class="coir-faq__item">
              <dt class="coir-faq__q">{faq.q}</dt>
              <dd class="coir-faq__a">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ─────────────────────────────────────── -->
    <div class="prod-section" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="coir-related" data-animate data-delay="1">
          <a href="/products/grass-carpet" class="coir-related__link">
            <span class="coir-related__name">Grass Carpet</span>
            <span class="coir-related__desc">Synthetic grass for themed exhibition environments</span>
          </a>
          <a href="/products/loop-pile-carpet" class="coir-related__link">
            <span class="coir-related__name">Loop Pile Carpet</span>
            <span class="coir-related__desc">Structured cut-loop surface in 6 architectural tones</span>
          </a>
          <a href="/products/non-woven-carpet" class="coir-related__link">
            <span class="coir-related__name">Non Woven Carpet</span>
            <span class="coir-related__desc">29 shades — industry standard floor coverage</span>
          </a>
          <a href="/products/designer-carpet" class="coir-related__link">
            <span class="coir-related__name">Designer Carpet</span>
            <span class="coir-related__desc">Fully custom printed to your brief</span>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── CTA ──────────────────────────────────────────────────── -->
    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Coir Carpet</div>
            <p class="prod-cta__sub">
              Share your event brief, venue, and floor plan.
              We'll confirm specification and availability within 24 hours.
            </p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Hero ──────────────────────────────────────────────────────── */
  .coir-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-bottom: var(--sp-8);
    background-color: var(--color-navy-dark);
  }
  .coir-hero__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .coir-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }
  .coir-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 12, 36, 0.97) 0%,
      rgba(8, 12, 36, 0.65) 38%,
      rgba(8, 12, 36, 0.26) 72%,
      rgba(8, 12, 36, 0.14) 100%
    );
  }
  .coir-hero__content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding-top: 140px;
  }
  .coir-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(247, 246, 243, 0.40);
    margin-bottom: var(--sp-5);
    transition: color 0.22s ease;
  }
  .coir-hero__back:hover { color: rgba(247, 246, 243, 0.80); }
  .coir-hero__title {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 84px);
    font-weight: 700;
    line-height: 1.03;
    letter-spacing: -0.032em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .coir-hero__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.3vw, 17px);
    line-height: 1.72;
    color: rgba(247, 246, 243, 0.58);
    max-width: 440px;
  }
  .coir-hero__scroll {
    position: absolute;
    bottom: 40px;
    right: 48px;
    z-index: 2;
  }
  .coir-hero__scroll-line {
    width: 1px;
    height: 70px;
    background: linear-gradient(to bottom, transparent, rgba(247, 246, 243, 0.40));
    animation: coir-scroll 2.8s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes coir-scroll {
    0%, 100% { opacity: 0.30; transform: scaleY(0.5); }
    55%       { opacity: 0.85; transform: scaleY(1); }
  }

  /* ─── Statement ─────────────────────────────────────────────────── */
  .coir-statement {
    background: var(--color-warm-white);
    padding: var(--sp-9) 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .coir-statement__inner { max-width: 720px; }
  .coir-statement__text {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.6vw, 32px);
    font-weight: 600;
    line-height: 1.42;
    letter-spacing: -0.016em;
    color: rgba(12, 18, 48, 0.45);
    margin: 0;
  }
  .coir-statement__em {
    color: var(--color-navy-dark);
    font-weight: 700;
  }

  /* ─── Editorial split ───────────────────────────────────────────── */
  .coir-split {
    display: flex;
    min-height: 580px;
    overflow: hidden;
    background: var(--color-stone);
  }
  .coir-split__visual {
    flex: 0 0 50%;
    overflow: hidden;
  }
  .coir-split__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .coir-split:hover .coir-split__visual img { transform: scale(1.04); }
  .coir-split__text {
    flex: 1;
    display: flex;
    align-items: center;
    padding: var(--sp-8) var(--sp-7);
  }
  .coir-split__text-inner { max-width: 480px; }
  .coir-split__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 40px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.022em;
    color: var(--color-navy-dark);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .coir-split__body {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 15px);
    line-height: 1.80;
    color: var(--color-text-secondary);
    margin-bottom: var(--sp-4);
  }
  .coir-split__body:last-child { margin-bottom: 0; }

  /* ─── Spec strip ────────────────────────────────────────────────── */
  .coir-specs {
    background: var(--color-navy-dark);
    padding: var(--sp-6) 0;
  }
  .coir-specs__grid {
    display: flex;
    gap: 0;
  }
  .coir-specs__item {
    flex: 1;
    padding: var(--sp-4) var(--sp-5);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .coir-specs__item:first-child { padding-left: 0; }
  .coir-specs__item:last-child  { border-right: none; }
  .coir-specs__label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(247, 246, 243, 0.35);
  }
  .coir-specs__value {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: rgba(247, 246, 243, 0.88);
  }

  /* ─── FAQ ───────────────────────────────────────────────────────── */
  .coir-faq {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .coir-faq__item {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-top: var(--sp-4);
  }
  .coir-faq__q {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-navy-dark);
    margin-bottom: var(--sp-2);
    line-height: 1.4;
  }
  .coir-faq__a {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ─── Related ───────────────────────────────────────────────────── */
  .coir-related {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
  }
  .coir-related__link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-4);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.22s ease, background 0.22s ease;
  }
  .coir-related__link:hover {
    border-color: var(--color-navy);
    background: var(--color-stone);
  }
  .coir-related__name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-navy-dark);
    letter-spacing: -0.01em;
  }
  .coir-related__desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* ─── Responsive ────────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .coir-split { flex-direction: column; min-height: auto; }
    .coir-split__visual { height: 360px; flex: none; }
    .coir-split__text { padding: var(--sp-6) var(--sp-4); }
    .coir-split__text-inner { max-width: 100%; }
    .coir-related { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .coir-hero__scroll { display: none; }
    .coir-split__visual { height: 260px; }
    .coir-specs__grid { flex-direction: column; }
    .coir-specs__item {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: var(--sp-3) 0;
    }
    .coir-specs__item:last-child { border-bottom: none; }
    .coir-related { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .coir-hero__scroll-line { animation: none; }
    .coir-split:hover .coir-split__visual img { transform: none; }
  }
</style>
