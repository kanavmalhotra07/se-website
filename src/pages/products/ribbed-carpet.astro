---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const shades = [
  { name: 'Black',        img: '/images/catalogue/ribbed-black.jpg'       },
  { name: 'Dark Grey',    img: '/images/catalogue/ribbed-dark-grey.jpg'    },
  { name: 'Medium Grey',  img: '/images/catalogue/ribbed-medium-grey.jpg'  },
  { name: 'Dark Brown',   img: '/images/catalogue/ribbed-dark-brown.jpg'   },
  { name: 'Green Black',  img: '/images/catalogue/ribbed-green-black.jpg'  },
  { name: 'Powder Blue',  img: '/images/catalogue/ribbed-powder-blue.jpg'  },
  { name: 'Red',          img: '/images/catalogue/ribbed-red.jpg'          },
];

const applications = [
  'Exhibition Halls',
  'Aisle Flooring',
  'High-footfall Corridors',
  'Entrance Areas',
  'Brand Pavilions',
  'Convention Centres',
];

const faqs = [
  {
    q: 'Why is ribbed carpet specified for high-footfall exhibition areas?',
    a: 'The ribbed loop-pile surface distributes wear evenly across the structure, preventing the visible degradation that develops in cut-pile alternatives under sustained heavy traffic. It maintains its appearance across multi-day events — appropriate for entrance zones, main aisles, and corridors where thousands of visitors pass daily.',
  },
  {
    q: 'What is the lead time for ribbed carpet supply?',
    a: 'All 7 shades are maintained in permanent stock year-round. Most ribbed carpet orders can be fulfilled on short notice. Share your event dates, venue, and floor plan and we will confirm availability, cutting specification, and delivery timeline within 24 hours.',
  },
  {
    q: 'Can ribbed carpet be installed over any type of exhibition floor?',
    a: 'Yes. Ribbed carpet can be installed directly over concrete, wood composite, and standard exhibition hall flooring using carpet tape. The ribbed structure provides excellent dimensional stability and lays flat without buckling under high-traffic conditions.',
  },
  {
    q: 'Is ribbed carpet suitable for outdoor or semi-covered exhibition areas?',
    a: 'Ribbed carpet is designed for indoor exhibition environments. For outdoor pavilions, covered temporary structures, or semi-exposed areas, the installation conditions — including moisture exposure and temperature variation — should be discussed with our team before selecting. We can advise on the appropriate specification for your venue.',
  },
  {
    q: 'How does ribbed carpet compare to non woven carpet for trade fair use?',
    a: 'Non woven carpet is the cost-efficient choice for large-area coverage where economy of scale is the primary driver. Ribbed carpet is specified when durability under sustained high footfall is the overriding requirement — entrance halls, main aisles, and areas expected to carry thousands of visitors daily across multi-day events. The two products are complementary: non woven for general floor coverage, ribbed for the highest-traffic zones.',
  },
  {
    q: 'Does ribbed carpet require any special floor preparation before installation?',
    a: 'No special sub-floor preparation is required for standard exhibition hall conditions. Ribbed carpet is installed using carpet tape over concrete, screed, or composite hall flooring. Our installation team handles surface assessment, tape application, edge finishing, and seam management as part of the on-site scope.',
  },
];
---

<Layout
  title="Ribbed Exhibition Carpet — Trade Fair & Expo Flooring | Sanchi Enterprises"
  description="Ribbed exhibition carpet in 7 stocked shades. Durable loop-pile surface for high-footfall trade fair halls, expo corridors, and convention centres. Bulk supply and on-site installation across India."
  ogImage="https://www.sanchienterprises.com/images/catalogue/ribbed-black.jpg"
  breadcrumbs={[
    { name: 'Products', item: 'https://www.sanchienterprises.com/products' },
    { name: 'Ribbed Carpet', item: 'https://www.sanchienterprises.com/products/ribbed-carpet' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://www.sanchienterprises.com/products/ribbed-carpet/#service",
          "name": "Ribbed Exhibition Carpet",
          "description": "Ribbed loop-pile exhibition carpet in 7 stocked shades. Built for high-traffic trade fair environments — maintains appearance under sustained heavy footfall at multi-day expos and convention halls.",
          "serviceType": "Exhibition Carpet Supply and Installation",
          "provider": { "@id": "https://www.sanchienterprises.com/#organization" },
          "url": "https://www.sanchienterprises.com/products/ribbed-carpet",
          "image": "https://www.sanchienterprises.com/images/catalogue/ribbed-black.jpg",
          "areaServed": { "@type": "Country", "name": "India" },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Surface", "value": "Ribbed loop-pile" },
            { "@type": "PropertyValue", "name": "Shades in Stock", "value": "7 colours" },
            { "@type": "PropertyValue", "name": "Supply Format", "value": "Bulk roll" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India delivery" }
          ]
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <section class="prod-hero" aria-labelledby="ribbed-heading">
      <div class="container">
        <div class="prod-hero__inner">
          <a href="/products" class="prod-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Ribbed Carpet</span>
          <h1 class="prod-hero__title" id="ribbed-heading" data-animate data-delay="2">
            Built for High-Traffic<br />Exhibition Environments.
          </h1>
          <p class="prod-hero__intro" data-animate data-delay="3">
            Ribbed carpet is the workhorse of the exhibition floor. Its structured
            loop-pile surface handles heavy footfall without losing appearance across
            multi-day events. Supplied in bulk rolls, cut to specification, and
            available in 7 stocked shades.
          </p>
        </div>
      </div>
    </section>

    <div class="shade-section" aria-labelledby="shades-heading">
      <div class="container">
        <div class="shade-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Shade Catalogue</span>
          <h2 class="shade-section__title" id="shades-heading">Available Shades</h2>
          <p class="shade-section__count">7 colours — all held in stock</p>
        </div>
        <div class="shade-grid">
          {shades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 5) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Ribbed Carpet — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="prod-section prod-section--stone" aria-label="Product specifications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Specification</span>
          <h2 class="prod-section__title">Product Details</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Ribbed carpet offers a firm underfoot feel with excellent dimensional
          stability — it lays flat under high-traffic conditions and resists
          edge-lift during extended event runs. Compatible with standard carpet
          tape for direct installation over concrete, wood, or composite floors.
        </p>
        <div class="prod-features" data-animate data-delay="2">
          <div class="prod-feature">
            <div class="prod-feature__label">Surface</div>
            <div class="prod-feature__value">Ribbed loop-pile</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Supply Format</div>
            <div class="prod-feature__value">Bulk roll</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Shades in Stock</div>
            <div class="prod-feature__value">7 colours</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Installation</div>
            <div class="prod-feature__value">Supply & lay available</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Lead Time</div>
            <div class="prod-feature__value">Short-notice orders handled</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Coverage</div>
            <div class="prod-feature__value">Pan-India delivery</div>
          </div>
        </div>
      </div>
    </div>

    <div class="prod-section" aria-label="Applications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title">Where Ribbed Carpet Works</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── INDUSTRY CONTEXT ──────────────────────────────────────────────── -->
    <div class="prod-section prod-section--dark" aria-labelledby="ribbed-context-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Exhibition Context</span>
          <h2 class="ribbed-context-title" id="ribbed-context-heading">The Specified Choice for India's High-Traffic Exhibition Zones.</h2>
        </div>
        <p class="prod-section__body--inverse" data-animate data-delay="1">
          Exhibition aisle flooring is among the most demanding applications for any carpet
          product. A major trade fair in India can receive fifty thousand visitors over three
          or four days — all walking the same corridors, entering through the same gates, and
          converging on the same central aisles. The floor in these areas needs to hold its
          appearance through that volume without showing cumulative wear.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="2">
          Ribbed carpet is routinely specified for high-traffic exhibition zones because its
          loop-pile structure handles sustained foot pressure without surface degradation.
          The ribbed texture provides better grip underfoot than flat-weave alternatives —
          relevant in entrance areas and high-footfall corridors where visitor movement is
          dense and directional. It maintains a clean, professional appearance across the
          full duration of a multi-day event, from the opening hour to the final day.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="3">
          At exhibitions hosted at Pragati Maidan (New Delhi), Bombay Exhibition Centre
          (Mumbai), BIEC (Bengaluru), and India Expo Centre (Greater Noida), ribbed carpet
          is the standard specification for main aisles, entrance thresholds, and
          high-footfall connecting corridors — with non woven or velour used in adjacent
          areas according to the budget and presentation requirements of each zone.
        </p>
      </div>
    </div>

    <!-- ─── FAQ ────────────────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="ribbed-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="ribbed-faq-heading">Common Questions</h2>
        </div>
        <dl class="prod-faq" data-animate data-delay="1">
          {faqs.map((faq) => (
            <div class="prod-faq__item">
              <dt class="prod-faq__q">{faq.q}</dt>
              <dd class="prod-faq__a">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ──────────────────────────────────────────────── -->
    <div class="prod-section" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="prod-related" data-animate data-delay="1">
          <a href="/products/non-woven-carpet" class="prod-related__link">
            <span class="prod-related__name">Non Woven Carpet</span>
            <span class="prod-related__desc">29 shades — industry standard floor coverage</span>
          </a>
          <a href="/products/velour-carpet" class="prod-related__link">
            <span class="prod-related__name">Velour Carpet</span>
            <span class="prod-related__desc">Premium cut-pile finish in 11 shades</span>
          </a>
          <a href="/products/designer-carpet" class="prod-related__link">
            <span class="prod-related__name">Designer Carpet</span>
            <span class="prod-related__desc">Fully custom printed to your brief</span>
          </a>
          <a href="/products/caution-carpet" class="prod-related__link">
            <span class="prod-related__name">Caution Carpet</span>
            <span class="prod-related__desc">Safety flooring for cable trays and access zones</span>
          </a>
        </div>
      </div>
    </div>

    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Ribbed Carpet</div>
            <p class="prod-cta__sub">Share your floor area, shade preference, and event dates. We'll confirm availability and pricing within 24 hours.</p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .ribbed-context-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 42px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
  }
  .prod-section__body--inverse {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.2vw, 16px);
    line-height: 1.80;
    color: rgba(247, 246, 243, 0.65);
    max-width: 760px;
    margin-bottom: var(--sp-4);
  }
  .prod-section__body--inverse:last-child { margin-bottom: 0; }

  .prod-faq {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .prod-faq__item {
    border-top: 1px solid var(--color-border-light, rgba(0,0,0,0.08));
    padding-top: var(--sp-4);
  }
  .prod-faq__q {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-navy-dark);
    margin-bottom: var(--sp-2);
    line-height: 1.4;
  }
  .prod-faq__a {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .prod-related {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
  }
  .prod-related__link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-4);
    border: 1px solid var(--color-border-light, rgba(0,0,0,0.08));
    border-radius: 4px;
    transition: border-color 0.22s ease, background 0.22s ease;
    text-decoration: none;
  }
  .prod-related__link:hover {
    border-color: var(--color-navy);
    background: var(--color-stone, #EFEDE8);
  }
  .prod-related__name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-navy-dark);
    letter-spacing: -0.01em;
  }
  .prod-related__desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  @media (max-width: 1024px) { .prod-related { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .prod-related { grid-template-columns: 1fr; } }
</style>
