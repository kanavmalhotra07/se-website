---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const shades = [
  { name: 'Black',        img: '/images/catalogue/ribbed-black.jpg'       },
  { name: 'Dark Grey',    img: '/images/catalogue/ribbed-dark-grey.jpg'    },
  { name: 'Medium Grey',  img: '/images/catalogue/ribbed-medium-grey.jpg'  },
  { name: 'Dark Brown',   img: '/images/catalogue/ribbed-dark-brown.jpg'   },
  { name: 'Green Black',  img: '/images/catalogue/ribbed-green-black.jpg'  },
  { name: 'Powder Blue',  img: '/images/catalogue/ribbed-powder-blue.jpg'  },
  { name: 'Red',          img: '/images/catalogue/ribbed-red.jpg'          },
];

const applications = [
  'Exhibition Halls',
  'Aisle Flooring',
  'High-footfall Corridors',
  'Entrance Areas',
  'Brand Pavilions',
  'Convention Centres',
];
---

<Layout
  title="Ribbed Carpet — Sanchi Enterprises"
  description="Ribbed exhibition carpet in 7 shades. Durable, high-footfall suitable flooring for trade fairs, expo corridors, and convention halls. Bulk supply and installation across India."
>
  <Navbar />
  <main>

    <section class="prod-hero" aria-labelledby="ribbed-heading">
      <div class="container">
        <div class="prod-hero__inner">
          <a href="/products" class="prod-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Ribbed Carpet</span>
          <h1 class="prod-hero__title" id="ribbed-heading" data-animate data-delay="2">
            Built for High-Traffic<br />Exhibition Environments.
          </h1>
          <p class="prod-hero__intro" data-animate data-delay="3">
            Ribbed carpet is the workhorse of the exhibition floor. Its structured
            loop-pile surface handles heavy footfall without losing appearance across
            multi-day events. Supplied in bulk rolls, cut to specification, and
            available in 7 stocked shades.
          </p>
        </div>
      </div>
    </section>

    <div class="shade-section" aria-labelledby="shades-heading">
      <div class="container">
        <div class="shade-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Shade Catalogue</span>
          <h2 class="shade-section__title" id="shades-heading">Available Shades</h2>
          <p class="shade-section__count">7 colours — all held in stock</p>
        </div>
        <div class="shade-grid">
          {shades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 5) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Ribbed Carpet — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="prod-section prod-section--stone" aria-label="Product specifications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Specification</span>
          <h2 class="prod-section__title">Product Details</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Ribbed carpet offers a firm underfoot feel with excellent dimensional
          stability — it lays flat under high-traffic conditions and resists
          edge-lift during extended event runs. Compatible with standard carpet
          tape for direct installation over concrete, wood, or composite floors.
        </p>
        <div class="prod-features" data-animate data-delay="2">
          <div class="prod-feature">
            <div class="prod-feature__label">Surface</div>
            <div class="prod-feature__value">Ribbed loop-pile</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Supply Format</div>
            <div class="prod-feature__value">Bulk roll</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Shades in Stock</div>
            <div class="prod-feature__value">7 colours</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Installation</div>
            <div class="prod-feature__value">Supply & lay available</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Lead Time</div>
            <div class="prod-feature__value">Short-notice orders handled</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Coverage</div>
            <div class="prod-feature__value">Pan-India delivery</div>
          </div>
        </div>
      </div>
    </div>

    <div class="prod-section" aria-label="Applications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title">Where Ribbed Carpet Works</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Ribbed Carpet</div>
            <p class="prod-cta__sub">Share your floor area, shade preference, and event dates. We'll confirm availability and pricing within 24 hours.</p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>
