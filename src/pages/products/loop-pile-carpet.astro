---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ExhibitionAuthority from '../../components/ExhibitionAuthority.astro';
import Footer from '../../components/Footer.astro';

const shades = [
  { name: 'Charcoal',  img: '/images/catalogue/lp-charcoal.jpg'       },
  { name: 'Grey',      img: '/images/catalogue/loop-pile-grey.jpg'     },
  { name: 'Brown',     img: '/images/catalogue/lp-brown.jpg'           },
  { name: 'Beige',     img: '/images/catalogue/lp-beige.jpg'           },
  { name: 'Maroon',    img: '/images/catalogue/loop-pile-maroon.jpg'   },
  { name: 'Blue',      img: '/images/catalogue/lp-blue.jpg'            },
];

const applications = [
  'Corporate Pavilions',
  'Hospitality Suites',
  'Conference Lounges',
  'Brand Experience Zones',
  'Premium Retail Spaces',
  'VIP & Meeting Areas',
  'Interior Installations',
  'Long-term Event Setups',
];

const faqs = [
  {
    q: 'How does loop pile carpet differ from velour for exhibition use?',
    a: 'Both are premium products, but they serve different environments. Velour\'s cut-pile surface is softer and produces a richer, deeper visual finish — suited to brand activations, art fair stands, and hospitality spaces where warmth and softness are part of the experience. Loop pile\'s cut-loop construction creates a more structured, architectural surface — better suited to corporate conference lounges, long-duration brand suites, and professional environments where a considered, neutral floor quality is preferred.',
  },
  {
    q: 'Is loop pile carpet suitable for multi-day exhibitions?',
    a: 'Yes. The cut-loop construction maintains its structural integrity and surface appearance under sustained footfall across multi-day events. It is specifically suited to long-duration exhibition environments — conference facilities, hospitality lounges, and permanent-feel brand spaces — where the floor needs to look consistent from the first day of the show to the last.',
  },
  {
    q: 'What shades are available and can they be matched to brand palettes?',
    a: 'Loop pile carpet is available in 6 architectural tones: Charcoal, Grey, Brown, Beige, Maroon, and Blue — all held in permanent stock. These are neutral, professional tones suited to corporate and upmarket environments. For exact brand colour matching or custom patterns, our Designer Carpet service produces fully custom carpet to your Pantone or swatch specification.',
  },
  {
    q: 'What types of events specify loop pile carpet in India?',
    a: 'Loop pile carpet is specified at corporate hospitality suites and VIP areas at major trade fairs and government summits — including AI Impact Summit India, conferences at Pragati Maidan (New Delhi) and Yashobhoomi, premium pavilions at Jio World Convention Centre (Mumbai) and HITEX (Hyderabad), long-duration brand experience installations, and any exhibition environment where the floor needs to convey a professional, enduring character across an extended event run.',
  },
  {
    q: 'Can loop pile carpet be installed over any exhibition hall floor?',
    a: 'Yes. Loop pile carpet is installed using standard carpet tape over concrete, screed, or composite exhibition hall flooring — the same method used for ribbed and velour carpet. Our installation team handles cutting, laying, edge finishing, and seam management on site. No special sub-floor preparation is required for standard exhibition hall conditions.',
  },
  {
    q: 'How far in advance should loop pile carpet be ordered?',
    a: 'All 6 shades are maintained in permanent stock year-round. Most loop pile carpet orders can be fulfilled on short notice. For large-area corporate installations or events during peak exhibition seasons, we recommend confirming requirements 4–6 weeks before the event move-in date to allow pre-cutting and logistics coordination.',
  },
];
---

<Layout
  title="Loop Pile Exhibition Carpet — Corporate & Premium Event Flooring | Sanchi Enterprises"
  description="Loop pile exhibition carpet in 6 architectural shades. Structured cut-loop surface for corporate pavilions, hospitality suites, conference lounges, and premium event environments. Bulk supply and installation across India."
  ogImage="https://www.sanchienterprises.com/images/loop-pile/lp-env-hero.jpg"
  ogImageWidth="1920"
  ogImageHeight="1080"
  breadcrumbs={[
    { name: 'Products', item: 'https://www.sanchienterprises.com/products' },
    { name: 'Loop Pile Carpet', item: 'https://www.sanchienterprises.com/products/loop-pile-carpet' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://www.sanchienterprises.com/products/loop-pile-carpet/#service",
          "name": "Loop Pile Exhibition Carpet",
          "description": "Loop pile cut-loop exhibition carpet in 6 architectural shades — Charcoal, Grey, Brown, Beige, Maroon, and Blue. Structured, dense surface for corporate pavilions, hospitality suites, conference lounges, and premium event environments. Bulk supply and on-site installation across India.",
          "serviceType": "Exhibition Carpet Supply and Installation",
          "provider": { "@id": "https://www.sanchienterprises.com/#organization" },
          "url": "https://www.sanchienterprises.com/products/loop-pile-carpet",
          "image": "https://www.sanchienterprises.com/images/loop-pile/lp-env-hero.jpg",
          "areaServed": { "@type": "Country", "name": "India" },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Surface", "value": "Cut-loop pile" },
            { "@type": "PropertyValue", "name": "Shades in Stock", "value": "6 architectural tones" },
            { "@type": "PropertyValue", "name": "Supply Format", "value": "Bulk roll" },
            { "@type": "PropertyValue", "name": "Best Suited For", "value": "Corporate, hospitality, and long-duration premium spaces" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India delivery" }
          ],
          "offers": {
            "@type": "Offer",
            "priceCurrency": "INR",
            "availability": "https://schema.org/InStock",
            "url": "https://www.sanchienterprises.com/products/loop-pile-carpet",
            "seller": { "@type": "Organization", "name": "Sanchi Enterprises" },
            "priceSpecification": {
              "@type": "PriceSpecification",
              "priceCurrency": "INR",
              "price": "0",
              "description": "Custom quotation based pricing. Contact for pricing."
            }
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <!-- ─── HERO — full-viewport, cinematic ──────────────────────────── -->
    <section class="lp-hero" aria-labelledby="lp-heading">
      <div class="lp-hero__bg" aria-hidden="true">
        <img
          src="/images/loop-pile/lp-env-hero.jpg"
          alt=""
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1080"
        />
      </div>
      <div class="lp-hero__overlay" aria-hidden="true"></div>
      <div class="container">
        <div class="lp-hero__content">
          <a href="/products" class="lp-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Loop Pile Carpet</span>
          <h1 class="lp-hero__title" id="lp-heading" data-animate data-delay="2">
            A Dense, Structured Surface<br />for Premium Environments.
          </h1>
          <p class="lp-hero__sub" data-animate data-delay="3">
            Loop pile exhibition carpet brings an architectural quality to trade fair
            pavilions and premium event spaces. Its dense, structured surface reads as a
            deliberate material choice — resilient under footfall, refined in
            appearance, and available in six tones suited to corporate and
            upmarket environments.
          </p>
        </div>
      </div>
      <div class="lp-hero__scroll" aria-hidden="true">
        <div class="lp-hero__scroll-line"></div>
      </div>
    </section>

    <!-- ─── STATEMENT ────────────────────────────────────────────────── -->
    <div class="lp-statement" aria-label="Product positioning">
      <div class="container">
        <div class="lp-statement__layout">
          <div class="lp-statement__inner" data-animate>
            <span class="eyebrow eyebrow--line">Exhibition Grade</span>
            <p class="lp-statement__text">
              Structured. Architectural.<br />
              <span class="lp-statement__em">The floor that holds its quality across every day of the show.</span>
            </p>
            <div class="lp-statement__meta" data-animate data-delay="1">
              <div class="lp-statement__stat">
                <span class="lp-statement__stat-n">6</span>
                <span class="lp-statement__stat-l">Architectural<br />Shades in Stock</span>
              </div>
              <div class="lp-statement__divider" aria-hidden="true"></div>
              <div class="lp-statement__stat">
                <span class="lp-statement__stat-n">Multi-day</span>
                <span class="lp-statement__stat-l">Surface Integrity<br />Under Footfall</span>
              </div>
            </div>
          </div>
          <div class="lp-statement__img" data-animate="image" aria-hidden="true">
            <img
              src="/images/loop-pile/lp-detail-a.jpg"
              alt=""
              loading="lazy"
              decoding="async"
              width="1200"
              height="900"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- ─── SHADE RANGE ───────────────────────────────────────────────── -->
    <div class="shade-section" aria-labelledby="shades-heading">
      <div class="container">
        <div class="shade-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Colour Range</span>
          <h2 class="shade-section__title" id="shades-heading">Available Shades</h2>
          <p class="shade-section__count">6 architectural tones — all held in stock</p>
        </div>
        <div class="shade-grid lp-shade-grid">
          {shades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 4) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Loop Pile Carpet — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── EDITORIAL SPLIT — texture image + specification ──────────── -->
    <div class="lp-split" aria-labelledby="lp-spec-heading">
      <div class="lp-split__visual" data-animate="image">
        <img
          src="/images/loop-pile/lp-vip-lounge.jpg"
          alt="Loop pile carpet installed in a VIP ministerial lounge at a major government summit — premium beige shade in an elite diplomatic event environment"
          loading="lazy"
          decoding="async"
          width="1200"
          height="900"
        />
      </div>
      <div class="lp-split__text">
        <div class="lp-split__text-inner" data-animate data-delay="1">
          <span class="eyebrow eyebrow--line">Specification</span>
          <h2 class="lp-split__title" id="lp-spec-heading">
            Product Details
          </h2>
          <p class="lp-split__body">
            Loop pile carpet is specified for environments where material quality is
            a deliberate part of the environment. The cut-loop construction produces
            a surface that is denser and more structured than non-woven alternatives —
            maintaining its form across multi-day events and presenting well under
            exhibition and architectural lighting.
          </p>
          <p class="lp-split__body">
            Its tonal palette — anchored in neutral greys, browns, and charcoal —
            works with corporate and hospitality interiors without competing with
            the event itself. Supplied in bulk rolls, cut to your floor plan, and
            installed on-site.
          </p>
          <div class="prod-features lp-features">
            <div class="prod-feature">
              <div class="prod-feature__label">Surface</div>
              <div class="prod-feature__value">Cut-loop pile</div>
            </div>
            <div class="prod-feature">
              <div class="prod-feature__label">Supply Format</div>
              <div class="prod-feature__value">Bulk roll</div>
            </div>
            <div class="prod-feature">
              <div class="prod-feature__label">Shades in Stock</div>
              <div class="prod-feature__value">6 colours</div>
            </div>
            <div class="prod-feature">
              <div class="prod-feature__label">Installation</div>
              <div class="prod-feature__value">Supply &amp; lay available</div>
            </div>
            <div class="prod-feature">
              <div class="prod-feature__label">Best Suited For</div>
              <div class="prod-feature__value">Premium &amp; corporate spaces</div>
            </div>
            <div class="prod-feature">
              <div class="prod-feature__label">Coverage</div>
              <div class="prod-feature__value">Pan-India delivery</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── APPLICATIONS ─────────────────────────────────────────────── -->
    <div class="prod-section" aria-labelledby="lp-apps-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title" id="lp-apps-heading">Where Loop Pile Works</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── ATMOSPHERIC PANEL — supply & installation ────────────────── -->
    <div class="lp-panel" aria-labelledby="lp-install-heading">
      <div class="lp-panel__bg" aria-hidden="true">
        <img
          src="/images/loop-pile/lp-corridor-panel.jpg"
          alt=""
          loading="lazy"
          decoding="async"
          width="1920"
          height="1080"
        />
      </div>
      <div class="lp-panel__overlay" aria-hidden="true"></div>
      <div class="container">
        <div class="lp-panel__content" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Supply &amp; Installation</span>
          <h2 class="lp-panel__title" id="lp-install-heading">
            From Order to<br />On-site Installation.
          </h2>
          <p class="lp-panel__body">
            Sanchi Enterprises supplies loop pile carpet in bulk quantities,
            pre-cut and labelled to your floor plan. Our installation team handles
            on-site laying, edge finishing, and live-day maintenance — managed
            through a single point of contact from order through to post-show removal.
          </p>
          <p class="lp-panel__body">
            All six shades are held in permanent stock, allowing short-notice orders
            to be fulfilled without compromise on quality or lead time.
          </p>
        </div>
      </div>
    </div>

    <!-- ─── EXHIBITION CONTEXT ───────────────────────────────────────── -->
    <div class="prod-section prod-section--dark" aria-labelledby="lp-context-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Exhibition Context</span>
          <h2 class="prod-section__title" id="lp-context-heading">Loop Pile Carpet<br />in Indian Exhibitions.</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Loop pile carpet occupies a specific position in the exhibition flooring hierarchy
          that neither ribbed nor velour covers precisely. Its cut-loop construction produces
          a surface that is more structured and architectural than velour's soft cut-pile —
          suited to environments where the floor needs to convey quality and permanence
          without the visual softness associated with premium event carpet.
        </p>
        <p class="prod-section__body" data-animate data-delay="2">
          Corporate hospitality suites, extended-run conference facilities, long-duration
          exhibitions, and high-value product environments where visitors spend significant
          time — these are the spaces where loop pile carpet's neutral, structured surface
          performs best. The material reads as considered rather than decorative: appropriate
          for environments where the exhibit or the conversation in the space is the focus,
          not the floor itself.
        </p>
        <p class="prod-section__body" data-animate data-delay="3">
          Among the venues where Sanchi Enterprises regularly installs flooring — Pragati
          Maidan and Yashobhoomi in Delhi, the Jio World Convention Centre and Bombay
          Exhibition Centre in Mumbai, BIEC in Bengaluru, and HITEX in Hyderabad — loop pile
          carpet is the specified choice for hospitality zones and corporate pavilions where
          the floor needs to support a professional, long-duration environment.
        </p>
      </div>
    </div>

    <ExhibitionAuthority heading="Installed at India's<br />Major Trade Fairs." />

    <!-- ─── FAQ ──────────────────────────────────────────────────────── -->
    <div class="prod-section" aria-labelledby="lp-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="lp-faq-heading">Common Questions</h2>
        </div>
        <dl class="lp-faq" data-animate data-delay="1">
          {faqs.map((faq) => (
            <div class="lp-faq__item">
              <dt class="lp-faq__q">{faq.q}</dt>
              <dd class="lp-faq__a">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ─────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="lp-related" data-animate data-delay="1">
          <a href="/products/velour-carpet" class="lp-related__link">
            <span class="lp-related__name">Velour Carpet</span>
            <span class="lp-related__desc">Premium cut-pile finish in 11 shades</span>
          </a>
          <a href="/products/non-woven-carpet" class="lp-related__link">
            <span class="lp-related__name">Non Woven Carpet</span>
            <span class="lp-related__desc">29 shades — industry standard floor coverage</span>
          </a>
          <a href="/products/ribbed-carpet" class="lp-related__link">
            <span class="lp-related__name">Ribbed Carpet</span>
            <span class="lp-related__desc">High-footfall ribbed surface in 7 shades</span>
          </a>
          <a href="/products/designer-carpet" class="lp-related__link">
            <span class="lp-related__name">Designer Carpet</span>
            <span class="lp-related__desc">Fully custom printed to your brief</span>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── CTA ──────────────────────────────────────────────────────── -->
    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Loop Pile Carpet</div>
            <p class="prod-cta__sub">
              Share your floor area, shade preference, and event dates.
              We'll confirm availability and pricing within 24 hours.
            </p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<script>
  // ─── Hero parallax — rAF-throttled ──────────────────────────────────
  const lpHeroBg = document.querySelector<HTMLElement>('.lp-hero__bg img');
  if (lpHeroBg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    lpHeroBg.style.willChange = 'transform';
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          lpHeroBg.style.transform = `translate3d(0, ${window.scrollY * 0.14}px, 0)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  // ─── Panel bg parallax ──────────────────────────────────────────────
  const lpPanelBg = document.querySelector<HTMLElement>('.lp-panel__bg img');
  if (lpPanelBg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    lpPanelBg.style.willChange = 'transform';
    const panelEl = lpPanelBg.closest<HTMLElement>('.lp-panel');
    if (panelEl) {
      let pticking = false;
      window.addEventListener('scroll', () => {
        if (!pticking) {
          requestAnimationFrame(() => {
            const rect = panelEl.getBoundingClientRect();
            const offset = (rect.top + rect.height / 2 - window.innerHeight / 2);
            lpPanelBg.style.transform = `translate3d(0, ${offset * 0.10}px, 0)`;
            pticking = false;
          });
          pticking = true;
        }
      }, { passive: true });
    }
  }
</script>

<style>
  /* ─── Hero ──────────────────────────────────────────────────────────── */
  .lp-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-bottom: var(--sp-8);
    background-color: var(--color-navy-dark);
  }
  .lp-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .lp-hero__bg img {
    width: 100%;
    height: 110%;
    object-fit: cover;
    object-position: center 55%;
  }
  .lp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 12, 36, 0.94) 0%,
      rgba(8, 12, 36, 0.62) 28%,
      rgba(8, 12, 36, 0.22) 58%,
      rgba(8, 12, 36, 0.08) 100%
    );
  }
  .lp-hero__content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding-top: 140px;
  }
  .lp-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(247, 246, 243, 0.40);
    margin-bottom: var(--sp-5);
    transition: color 0.22s var(--ease-out);
  }
  .lp-hero__back:hover { color: rgba(247, 246, 243, 0.80); }
  .lp-hero__title {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 84px);
    font-weight: 700;
    line-height: 1.03;
    letter-spacing: -0.032em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .lp-hero__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.3vw, 17px);
    line-height: 1.72;
