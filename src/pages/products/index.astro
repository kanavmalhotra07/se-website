  if (piHeroBg) {
    piHeroBg.style.willChange = 'transform';
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          piHeroBg.style.transform = `translate3d(0, ${window.scrollY * 0.14}px, 0)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
