---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const nwRegularShades = [
  { src: '/images/catalogue/nw-light-grey.jpg',   name: 'Light Grey'   },
  { src: '/images/catalogue/nw-light-camel.jpg',  name: 'Light Camel'  },
  { src: '/images/catalogue/nw-camel.jpg',         name: 'Camel'        },
  { src: '/images/catalogue/nw-light-brown.jpg',  name: 'Light Brown'  },
  { src: '/images/catalogue/nw-dark-brown.jpg',   name: 'Dark Brown'   },
  { src: '/images/catalogue/nw-dark-grey.jpg',    name: 'Dark Grey'    },
  { src: '/images/catalogue/nw-black.jpg',         name: 'Black'        },
  { src: '/images/catalogue/nw-blue-black.jpg',   name: 'Blue Black'   },
  { src: '/images/catalogue/nw-green-black.jpg',  name: 'Green Black'  },
  { src: '/images/catalogue/nw-plain-green.jpg',  name: 'Plain Green'  },
  { src: '/images/catalogue/nw-red.jpg',           name: 'Red'          },
  { src: '/images/catalogue/nw-red-black.jpg',    name: 'Red Black'    },
  { src: '/images/catalogue/nw-magenta.jpg',       name: 'Magenta'      },
  { src: '/images/catalogue/nw-blue.jpg',          name: 'Plain Blue'   },
];

const nwPremiumShades = [
  { src: '/images/catalogue/nw-p-orange.jpg',        name: 'Orange'       },
  { src: '/images/catalogue/nw-p-safron.jpg',        name: 'Saffron'      },
  { src: '/images/catalogue/nw-p-yellow.jpg',        name: 'Yellow'       },
  { src: '/images/catalogue/nw-p-yellow-green.jpg',  name: 'Yellow Green' },
  { src: '/images/catalogue/nw-p-cactus-green.jpg',  name: 'Cactus Green' },
  { src: '/images/catalogue/nw-p-aqua-green.jpg',    name: 'Aqua Green'   },
  { src: '/images/catalogue/nw-p-firozi-blue.jpg',   name: 'Firozi Blue'  },
  { src: '/images/catalogue/nw-p-oasis-blue.jpg',    name: 'Oasis Blue'   },
  { src: '/images/catalogue/nw-p-turkish-blue.jpg',  name: 'Turkish Blue' },
  { src: '/images/catalogue/nw-p-violet.jpg',        name: 'Violet'       },
  { src: '/images/catalogue/nw-p-purple.jpg',        name: 'Purple'       },
  { src: '/images/catalogue/nw-p-dark-purple.jpg',   name: 'Dark Purple'  },
  { src: '/images/catalogue/nw-p-pink.jpg',           name: 'Pink'         },
  { src: '/images/catalogue/nw-p-golden.jpg',         name: 'Golden'       },
  { src: '/images/catalogue/nw-p-silver-grey.jpg',   name: 'Silver Grey'  },
];

const velourShades = [
  { src: '/images/catalogue/velour-silver-grey.jpg', name: 'Silver Grey'  },
  { src: '/images/catalogue/velour-camel.jpg',        name: 'Camel'        },
  { src: '/images/catalogue/velour-dark-grey.jpg',    name: 'Dark Grey'    },
  { src: '/images/catalogue/velour-black.jpg',        name: 'Black'        },
  { src: '/images/catalogue/velour-powder-blue.jpg',  name: 'Powder Blue'  },
  { src: '/images/catalogue/velour-pastel-green.jpg', name: 'Pastel Green' },
  { src: '/images/catalogue/velour-medium-grey.jpg',  name: 'Medium Grey'  },
  { src: '/images/catalogue/velour-dark-brown.jpg',   name: 'Dark Brown'   },
  { src: '/images/catalogue/velour-pink.jpg',          name: 'Pink'         },
  { src: '/images/catalogue/velour-red.jpg',           name: 'Red'          },
  { src: '/images/catalogue/velour-red-black.jpg',    name: 'Red Black'    },
];

const ribbedShades = [
  { src: '/images/catalogue/ribbed-medium-grey.jpg', name: 'Medium Grey' },
  { src: '/images/catalogue/ribbed-dark-grey.jpg',   name: 'Dark Grey'   },
  { src: '/images/catalogue/ribbed-black.jpg',        name: 'Black'       },
  { src: '/images/catalogue/ribbed-grey.jpg',         name: 'Grey'        },
  { src: '/images/catalogue/ribbed-powder-blue.jpg',  name: 'Powder Blue' },
  { src: '/images/catalogue/ribbed-red.jpg',          name: 'Red'         },
  { src: '/images/catalogue/ribbed-dark-brown.jpg',   name: 'Dark Brown'  },
];

const loopPileShades = [
  { src: '/images/catalogue/lp-beige.jpg',         name: 'Beige'    },
  { src: '/images/catalogue/lp-blue.jpg',          name: 'Blue'     },
  { src: '/images/catalogue/lp-brown.jpg',         name: 'Brown'    },
  { src: '/images/catalogue/lp-charcoal.jpg',      name: 'Charcoal' },
  { src: '/images/catalogue/loop-pile-grey.jpg',   name: 'Grey'     },
  { src: '/images/catalogue/loop-pile-maroon.jpg', name: 'Maroon'   },
];
---

<Layout
  title="Exhibition Carpet Products — Sanchi Enterprises"
  description="Non Woven, Ribbed, Velour, Designer, Loop Pile, and Caution Carpet for trade fairs, expos, and conventions. Bulk supply, custom design, and on-site installation across India."
>
  <Navbar />
  <main>

    <!-- ── HERO ────────────────────────────────────────────── -->
    <section class="pi-hero" aria-label="Products overview">
      <div class="pi-hero__bg" aria-hidden="true">
        <img src="/images/hero/hero.jpg" alt="" loading="eager" decoding="async" width="1920" height="1080" />
      </div>
      <div class="pi-hero__overlay" aria-hidden="true"></div>
      <div class="container">
        <div class="pi-hero__inner" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Product Range</span>
          <h1 class="pi-hero__title">Flooring that<br />defines the space.</h1>
          <p class="pi-hero__sub">
            Six specialist carpet categories. Thousands of square metres installed across
            India's leading trade fairs, expos, and branded exhibitions every year.
          </p>
          <div class="pi-hero__cats" aria-hidden="true">
            <span>Non Woven</span><span class="pi-hero__cats-dot">·</span>
            <span>Ribbed</span><span class="pi-hero__cats-dot">·</span>
            <span>Velour</span><span class="pi-hero__cats-dot">·</span>
            <span>Designer</span><span class="pi-hero__cats-dot">·</span>
            <span>Loop Pile</span><span class="pi-hero__cats-dot">·</span>
            <span>Caution</span>
          </div>
        </div>
      </div>
      <div class="pi-hero__scroll" aria-hidden="true">
        <div class="pi-hero__scroll-line"></div>
      </div>
    </section>

    <!-- ── 01 NON WOVEN — dark, image right ─────────────────── -->
    <section class="pi-prod pi-prod--dark pi-prod--flip" id="non-woven" aria-labelledby="nonwoven-heading">
      <div class="pi-prod__visual" data-animate="image">
        <img
          src="/images/about/gartex-2.jpg"
          alt="Magenta non-woven carpet covering the full Gartex exhibition hall — wide perspective showing carpet-defined floor at scale"
          class="pi-prod__img"
          loading="lazy"
          decoding="async"
          style="object-position: center 42%"
          width="1200"
          height="900"
        />
      </div>
      <div class="pi-prod__content">
        <div class="pi-prod__content-inner" data-animate>
          <span class="pi-prod__number" aria-hidden="true">01</span>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Non Woven Carpet</span>
          <h2 class="pi-prod__name" id="nonwoven-heading">
            The Exhibition<br />Standard
          </h2>
          <p class="pi-prod__body">
            India's most widely deployed exhibition carpet. Full-hall coverage, flat installation,
            clean matte finish. Two grades — Regular and Premium — 29 shades held in stock
            year-round. Supplied cut to size, bulk quantity, pan-India delivery.
          </p>
          <div class="pi-prod__specs">
            <div class="pi-prod__spec">
              <span class="pi-prod__spec-label">Weight</span>
              <span class="pi-prod__spec-value">600 gsm standard</span>
            </div>
            <div class="pi-prod__spec">
              <span class="pi-prod__spec-label">Grades</span>
              <span class="pi-prod__spec-value">Regular · Premium</span>
            </div>
          </div>
          <a href="/products/non-woven-carpet" class="pi-prod__link">
            View Non Woven Range
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M1 5h12M8.5 1.5L13 5l-4.5 3.5" stroke="currentColor" stroke-width="1.4"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── NW COLOUR WALL — full-width shade display ─────────── -->
    <div class="pi-nw-wall" aria-label="Non Woven colour range">
      <div class="container">
        <div class="pi-nw-wall-group" data-animate>
          <span class="pi-nw-wall-label">Regular Shade <em>— 14 colours</em></span>
          <div class="pi-nw-wall-track">
            {nwRegularShades.map((s) => (
              <div class="pi-nw-wall-card">
                <div class="pi-nw-wall-card__img">
                  <img src={s.src} alt={`Non Woven — ${s.name}`} loading="lazy" decoding="async" width="80" height="80" />
                </div>
                <span class="pi-nw-wall-card__name">{s.name}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="pi-nw-wall-group" data-animate data-delay="1">
          <span class="pi-nw-wall-label">Premium Shade <em>— 15 colours</em></span>
          <div class="pi-nw-wall-track">
            {nwPremiumShades.map((s) => (
              <div class="pi-nw-wall-card">
                <div class="pi-nw-wall-card__img">
                  <img src={s.src} alt={`Non Woven Premium — ${s.name}`} loading="lazy" decoding="async" width="80" height="80" />
                </div>
                <span class="pi-nw-wall-card__name">{s.name}</span>
              </div>
            ))}
          </div>
        </div>
        <p class="pi-nw-wall-note" data-animate data-delay="2">Physical samples available on request</p>
      </div>
    </div>

    <!-- ── 02 RIBBED — stone, texture macro left ─────────────── -->
    <section class="pi-prod pi-prod--stone" id="ribbed" aria-labelledby="ribbed-heading">
      <div class="pi-prod__visual" data-animate="image">
        <img
          src="/images/catalogue/ribbed-black.jpg"
          alt="Ribbed Black carpet — dense loop-pile surface texture at macro scale"
          class="pi-prod__img"
          loading="lazy"
          decoding="async"
          style="object-position: center center"
          width="400"
          height="533"
        />
      </div>
      <div class="pi-prod__content pi-prod__content--light">
        <div class="pi-prod__content-inner" data-animate>
          <span class="pi-prod__number pi-prod__number--dim" aria-hidden="true">02</span>
          <span class="eyebrow eyebrow--line">Ribbed Carpet</span>
          <h2 class="pi-prod__name pi-prod__name--dark" id="ribbed-heading">
            Built for<br />High Footfall
          </h2>
          <p class="pi-prod__body pi-prod__body--dark">
            The ribbed surface structure adds rigidity underfoot — the preferred choice for busy
            exhibition aisles, entrance corridors, and open show floors where durability
            matters as much as appearance. 7 shades in stock.
          </p>
          <div class="pi-shade-mini-grid" aria-label="Ribbed shades">
            {ribbedShades.map((s) => (
              <div class="pi-shade-mini">
                <div class="pi-shade-mini__img">
                  <img src={s.src} alt={s.name} loading="lazy" decoding="async" width="120" height="120" />
                </div>
                <span class="pi-shade-mini__name">{s.name}</span>
              </div>
            ))}
          </div>
          <a href="/products/ribbed-carpet" class="pi-prod__link pi-prod__link--navy">
            View Ribbed Range
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M1 5h12M8.5 1.5L13 5l-4.5 3.5" stroke="currentColor" stroke-width="1.4"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── 03 VELOUR — cinematic full-bleed ──────────────────── -->
    <section class="pi-velour" id="velour" aria-labelledby="velour-heading">
      <div class="pi-velour__bg" aria-hidden="true">
        <img
          src="/images/aesthetic/DSC03565.jpg"
          alt=""
          loading="lazy"
          decoding="async"
          width="1456"
          height="816"
        />
      </div>
      <div class="pi-velour__overlay" aria-hidden="true"></div>
      <div class="container">
        <div class="pi-velour__layout">
          <div class="pi-velour__content" data-animate>
            <span class="pi-prod__number" aria-hidden="true">03</span>
            <span class="eyebrow eyebrow--inverse eyebrow--line">Velour Carpet</span>
            <h2 class="pi-velour__title" id="velour-heading">
              The Premium<br />Surface
            </h2>
            <p class="pi-velour__body">
              Velour's soft cut-pile is the hallmark of premium exhibition environments.
              Art fairs, luxury brand pavilions, high-end product launches — spaces where
              the surface quality sets the tone. 11 shades in stock.
            </p>
            <div class="pi-prod__specs">
              <div class="pi-prod__spec">
                <span class="pi-prod__spec-label">Pile</span>
                <span class="pi-prod__spec-value">Soft cut-pile, dense</span>
              </div>
              <div class="pi-prod__spec">
                <span class="pi-prod__spec-label">Best for</span>
                <span class="pi-prod__spec-value">Art fairs · Brand pavilions · Luxury events</span>
              </div>
            </div>
            <a href="/products/velour-carpet" class="pi-prod__link">
              View Velour Range
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M1 5h12M8.5 1.5L13 5l-4.5 3.5" stroke="currentColor" stroke-width="1.4"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
          <div class="pi-velour__shades" data-animate data-delay="1">
            {velourShades.map((s) => (
              <div class="pi-velour__swatch">
                <img src={s.src} alt={s.name} loading="lazy" decoding="async" width="200" height="250" />
                <span class="pi-velour__swatch-name">{s.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── 04 DESIGNER — dominant + supporting ──────────────── -->
    <section class="pi-dmos-section" id="designer" aria-labelledby="designer-heading">
      <div class="pi-dmos" data-animate="image">
        <!-- Left — dominant main panel with text overlay -->
        <div class="pi-dmos__cell pi-dmos__cell--main">
          <img
            src="/images/designer-carpet/electronica-tech-hall.jpg"
            alt="Electronica India — wide exhibition hall entrance with custom blue electronics-icon printed carpet covering the entire open floor at architectural scale"
            loading="lazy"
            decoding="async"
            style="object-position: center 60%"
            width="5712"
            height="4284"
          />
          <div class="pi-dmos__text">
            <div class="pi-dmos__text-inner">
              <span class="pi-prod__number" aria-hidden="true">04</span>
              <span class="eyebrow eyebrow--inverse eyebrow--line">Designer Carpet</span>
              <h2 class="pi-dmos__title" id="designer-heading">
                Your Brand,<br />Underfoot
              </h2>
              <p class="pi-dmos__body">
                Fully custom-printed exhibition carpet designed to your brief.
                Logos, brand colour fields, event themes, directional graphics —
                produced and delivered to your exhibition timeline.
              </p>
              <div class="pi-prod__tags">
                <span class="pi-prod__tag pi-prod__tag--inv">Custom Artwork</span>
                <span class="pi-prod__tag pi-prod__tag--inv">Brand Identity</span>
                <span class="pi-prod__tag pi-prod__tag--inv">Event Themes</span>
                <span class="pi-prod__tag pi-prod__tag--inv">Directional Graphics</span>
              </div>
              <a href="/products/designer-carpet" class="pi-prod__link">
                View Designer Range
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                  <path d="M1 5h12M8.5 1.5L13 5l-4.5 3.5" stroke="currentColor" stroke-width="1.4"
                    stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
        <!-- Right — single supporting detail panel -->
        <div class="pi-dmos__cell pi-dmos__cell--side">
          <img
            src="/images/designer-carpet/iitf-triangles.jpg"
            alt="Wide exhibition hall floor covered end-to-end in a bold pink and magenta triangular geometric printed carpet at full architectural scale"
            loading="lazy"
            decoding="async"
            style="object-position: center 65%"
            width="5712"
            height="4284"
          />
        </div>
      </div>

      <!-- Pattern type strip — About-page hover interaction -->
      <div class="pi-designer__strip" aria-label="Design pattern examples">
        <a href="/products/designer-carpet" class="pi-designer__thumb" aria-label="Icon pattern — Light + LED India">
          <img src="/images/designer-carpet/light-led-icon-foyer.jpg" alt="Wide venue foyer covered in navy blue printed carpet with white tech icon pattern at Light + LED India" loading="lazy" decoding="async" style="object-position: center 55%" />
        </a>
        <a href="/products/designer-carpet" class="pi-designer__thumb" aria-label="Terracotta Swirl — Anuga Select">
          <img src="/images/designer-carpet/anuga-select-swirl.jpg" alt="Rich terracotta and red swirl-pattern printed carpet covering the entrance lobby at Anuga Select" loading="lazy" decoding="async" style="object-position: center 55%" />
        </a>
        <a href="/products/designer-carpet" class="pi-designer__thumb" aria-label="Diamond pattern — Smart Home Expo">
          <img src="/images/designer-carpet/smart-home-diamond.jpg" alt="Grand convention centre foyer with bold black and white diamond-grid printed carpet at Smart Home Expo Mumbai" loading="lazy" decoding="async" style="object-position: center 60%" />
        </a>
        <a href="/products/designer-carpet" class="pi-designer__thumb" aria-label="Floral pattern — DJGF">
          <img src="/images/designer-carpet/djgf-floral.jpg" alt="Colourful floral petal-pattern designer carpet" loading="lazy" decoding="async" style="object-position: center 45%" />
        </a>
      </div>
    </section>

    <!-- ── 05 CAUTION — dark, utility aesthetic ──────────────── -->
    <section class="pi-prod pi-prod--dark pi-prod--flip pi-caution" id="caution" aria-labelledby="caution-heading">
      <div class="pi-prod__visual" data-animate="image">
        <img
          src="/images/catalogue/caution-in-use-2.jpg"
          alt="Yellow and black caution carpet marking a cable tray threshold at a live exhibition event"
          class="pi-prod__img"
          loading="lazy"
          decoding="async"
          style="object-position: center 55%"
          width="900"
          height="1200"
        />
      </div>
      <div class="pi-prod__content pi-caution__content">
        <div class="pi-prod__content-inner" data-animate>
          <span class="pi-prod__number" aria-hidden="true">05</span>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Caution Carpet</span>
          <h2 class="pi-prod__name" id="caution-heading">
            Safety by<br />Design
          </h2>
          <p class="pi-prod__body">
            High-visibility stripe carpet for cable tray management, access ramps,
            and pedestrian movement zones during live events. Keeps exhibitors,
            crew, and visitors safe without interrupting the show.
          </p>
          <div class="pi-prod__specs">
            <div class="pi-prod__spec">
              <span class="pi-prod__spec-label">Application</span>
              <span class="pi-prod__spec-value">Cable trays · Access ramps · Safety zones</span>
            </div>
            <div class="pi-prod__spec">
              <span class="pi-prod__spec-label">Marking</span>
              <span class="pi-prod__spec-value">High-visibility stripe</span>
            </div>
          </div>
          <a href="/products/caution-carpet" class="pi-prod__link">
            View Caution Carpet
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M1 5h12M8.5 1.5L13 5l-4.5 3.5" stroke="currentColor" stroke-width="1.4"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── 06 LOOP PILE — stone, texture-forward ─────────────── -->
    <section class="pi-prod pi-prod--stone pi-loop" id="loop-pile" aria-labelledby="looppile-heading">
      <div class="pi-prod__visual pi-loop__visual" data-animate="image">
        <img
          src="/images/catalogue/lp-charcoal.jpg"
          alt="Loop Pile Charcoal carpet — editorial close-up showing dense loop-pile construction and surface texture"
          class="pi-prod__img pi-loop__img"
          loading="lazy"
          decoding="async"
          style="object-position: center 42%"
          width="1456"
          height="816"
        />
        <div class="pi-loop__vignette" aria-hidden="true"></div>
      </div>
      <div class="pi-prod__content pi-prod__content--light">
        <div class="pi-prod__content-inner" data-animate>
          <span class="pi-prod__number pi-prod__number--dim" aria-hidden="true">06</span>
          <span class="eyebrow eyebrow--line">Loop Pile Carpet</span>
          <h2 class="pi-prod__name pi-prod__name--dark" id="looppile-heading">
            The Refined<br />Texture
          </h2>
          <p class="pi-prod__body pi-prod__body--dark">
            Loop pile construction creates a structured, dense surface — harder-wearing than
            velour, quieter underfoot than ribbed. The preferred choice for pavilion interiors,
            branded zones, and premium event environments. 6 shades in stock.
          </p>
          <div class="pi-shade-mini-grid pi-shade-mini-grid--3col" aria-label="Loop pile shades available">
            {loopPileShades.map((s) => (
              <div class="pi-shade-mini">
                <div class="pi-shade-mini__img">
                  <img src={s.src} alt={s.name} loading="lazy" decoding="async" width="120" height="120" />
                </div>
                <span class="pi-shade-mini__name">{s.name}</span>
              </div>
            ))}
          </div>
          <div class="pi-prod__specs pi-prod__specs--light">
            <div class="pi-prod__spec">
              <span class="pi-prod__spec-label pi-prod__spec-label--muted">Construction</span>
              <span class="pi-prod__spec-value pi-prod__spec-value--dark">Loop pile, medium density</span>
            </div>
            <div class="pi-prod__spec">
              <span class="pi-prod__spec-label pi-prod__spec-label--muted">Best for</span>
              <span class="pi-prod__spec-value pi-prod__spec-value--dark">Pavilion interiors · Branded environments</span>
            </div>
          </div>
          <a href="/products/loop-pile-carpet" class="pi-prod__link pi-prod__link--navy">
            View Loop Pile Carpet
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M1 5h12M8.5 1.5L13 5l-4.5 3.5" stroke="currentColor" stroke-width="1.4"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── VENUE STRIP ────────────────────────────────────────── -->
    <section class="pi-venues" aria-label="Exhibitions served">
      <div class="pi-venues__label-row">
        <span class="pi-venues__label">Installed at India's premier exhibitions</span>
      </div>
      <div class="pi-venues__track-wrap" aria-hidden="true">
        <div class="pi-venues__track">
          <span class="pi-venues__item">India International Trade Fair</span><span class="pi-venues__sep">◆</span>
          <span class="pi-venues__item">IFAT India</span><span class="pi-venues__sep">◆</span>
          <span class="pi-venues__item">Electronica &amp; Productronica India</span><span class="pi-venues__sep">◆</span>
          <span class="pi-venues__item">Anuga FoodTec India</span><span class="pi-venues__sep">◆</span>
