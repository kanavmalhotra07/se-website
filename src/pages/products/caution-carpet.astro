---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const useCases = [
  'Cable Tray Coverage',
  'Access Ramps',
  'Backstage &amp; Service Areas',
  'Safety Walkways',
  'Step Edge Protection',
  'Temporary Access Zones',
  'Loading Bay Approaches',
  'Emergency Exit Paths',
];

const faqs = [
  {
    q: 'Can caution carpet be supplied and installed independently from the main exhibition carpet?',
    a: 'Yes. Caution carpet can be supplied and installed as a standalone requirement. It is most effective, however, when integrated as part of the complete flooring brief — our team coordinates cable tray routing, access zone marking, and safety transitions alongside the primary carpet installation in a single, coordinated scope.',
  },
  {
    q: 'What colour configuration is standard for caution carpet?',
    a: 'Caution carpet is manufactured in high-visibility yellow and black — the industry standard for safety and hazard marking at live events. The yellow and black stripe pattern is immediately identifiable to visitors, crew, and contractors as a marked transition zone or hazard area.',
  },
  {
    q: 'Who manages caution carpet during the live event?',
    a: 'Our installation team handles laying, positioning, and securing of caution carpet prior to show opening. We remain available throughout live event days for adjustments, maintenance, and post-show removal — all managed under the same scope as the primary flooring.',
  },
  {
    q: 'What widths and dimensions are available for cable tray caution carpet coverage?',
    a: 'Caution carpet is supplied in standard roll widths and can be cut to any length required by your cable tray layout. Width options are confirmed at the briefing stage against your specific cable management plan. Share your floor plan and cable route dimensions when making an enquiry and we will confirm the exact coverage specification.',
  },
  {
    q: 'Which exhibition venues across India does Sanchi supply caution carpet to?',
    a: 'We supply and install caution carpet at trade fairs and live events across India — including Pragati Maidan (New Delhi), Bombay Exhibition Centre (Mumbai), BIEC (Bengaluru), India Expo Centre (Greater Noida), HITEX (Hyderabad), and major regional exhibition venues. Caution carpet is coordinated with the primary flooring scope at each venue rather than sourced separately.',
  },
  {
    q: 'How far in advance should caution carpet be planned as part of an exhibition flooring brief?',
    a: 'Caution carpet should be included in the initial flooring brief — at the same stage as the primary carpet specification. Cable tray routing, power distribution channels, and access transition zones need to be identified before the floor plan is finalised so that caution carpet can be cut to the correct dimensions and positioned accurately on installation day. Last-minute additions create avoidable complications. Include it in the brief from the start.',
  },
];
---

<Layout
  title="Caution Carpet for Exhibitions — Cable Tray & Safety Flooring | Sanchi Enterprises"
  description="Caution carpet for cable tray management, access ramps, and safety zones at trade fairs and live events. Yellow and black safety flooring supplied and installed by Sanchi Enterprises across India."
  ogImage="https://sanchienterprises.com/images/catalogue/caution-in-use-1.jpg"
  breadcrumbs={[
    { name: 'Products', item: 'https://sanchienterprises.com/products' },
    { name: 'Caution Carpet', item: 'https://sanchienterprises.com/products/caution-carpet' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://sanchienterprises.com/products/caution-carpet/#service",
          "name": "Caution Safety Carpet",
          "description": "High-visibility yellow and black caution carpet for cable tray management, access ramps, and protected movement zones at trade fairs and live exhibitions. Supplied and installed by Sanchi Enterprises as part of a complete exhibition flooring scope.",
          "serviceType": "Safety Carpet Supply and Installation",
          "provider": { "@id": "https://sanchienterprises.com/#organization" },
          "url": "https://sanchienterprises.com/products/caution-carpet",
          "image": "https://sanchienterprises.com/images/catalogue/caution-in-use-1.jpg",
          "areaServed": { "@type": "Country", "name": "India" },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Colour", "value": "Yellow and black (high-visibility)" },
            { "@type": "PropertyValue", "name": "Application", "value": "Cable tray coverage, access ramps, safety walkways" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India delivery and installation" }
          ]
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <!-- ─── HERO — full-viewport, operations in motion ───────────── -->
    <section class="caution-hero" aria-labelledby="caution-heading">
      <div class="caution-hero__media" aria-hidden="true">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/images/catalogue/caution-carpet-ops-poster.jpg"
          class="caution-hero__video"
        >
          <source src="/videos/caution-carpet-hero.mp4" type="video/mp4" />
          <img
            src="/images/catalogue/caution-carpet-ops-poster.jpg"
            alt=""
            width="1920"
            height="1080"
            loading="eager"
            decoding="async"
          />
        </video>
      </div>
      <div class="caution-hero__overlay" aria-hidden="true"></div>

      <div class="container">
        <div class="caution-hero__content">
          <a href="/products" class="caution-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Caution Carpet</span>
          <h1 class="caution-hero__title" id="caution-heading" data-animate data-delay="2">
            Safety Flooring for<br />Live Exhibition Environments.
          </h1>
          <p class="caution-hero__intro" data-animate data-delay="3">
            Introduced for safer cable management, access flooring, and protected
            movement zones during exhibitions and live events. Caution carpet
            marks transitions, covers hazard points, and keeps event areas safe
            for visitors, crew, and contractors throughout show days.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ABOUT — operational briefing, text-only ──────────────── -->
    <div class="prod-section prod-section--stone" aria-label="About caution carpet">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">About the Product</span>
          <h2 class="prod-section__title">Designed for Exhibition Operations.</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Trade fairs and live events involve significant on-ground infrastructure —
          cable routes, power distribution channels, equipment transitions, and
          temporary walkways. Caution carpet addresses these conditions directly,
          providing a visible and tactile warning surface that meets the operational
          reality of a live show floor.
        </p>
        <p class="prod-section__body" data-animate data-delay="2">
          Sanchi Enterprises supplies and installs caution carpet as part of a
          complete flooring scope. It is integrated into the same installation
          plan as the primary exhibition carpet — laid, fixed, and removed by
          the same team, coordinated to the event schedule.
        </p>
      </div>
    </div>

    <div class="prod-section" aria-label="Application photography">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">In Use</span>
          <h2 class="prod-section__title">Caution Carpet on the Show Floor.</h2>
        </div>
        <div class="caution-doc-grid">

          <!-- Main feature: crowd at threshold, designer carpet flanking, peak energy -->
          <div class="caution-doc-main" data-animate="image">
            <img
              src="/images/catalogue/caution-in-use-1.jpg"
              alt="Group of visitors converging at the main access point — caution carpet threshold between designer carpet zones at Light + LED Expo Mumbai"
              loading="lazy"
              decoding="async"
              width="3024"
              height="4032"
              style="object-position: center 42%"
            />
            <span class="caution-doc-label">Light + LED Expo — Mumbai</span>
          </div>

          <!-- Top right: single figure, cool palette, clean threshold read -->
          <div class="caution-doc-sub" data-animate="image" data-delay="1">
            <img
              src="/images/catalogue/caution-carpet-1.jpg"
              alt="Attendee walking across caution carpet threshold at MediaExpo Mumbai entrance gate"
              loading="lazy"
              decoding="async"
              width="4032"
              height="3024"
              style="object-position: center 52%"
            />
            <span class="caution-doc-label">MediaExpo — Mumbai</span>
          </div>

          <!-- Bottom right: mid-stride directional movement, foreground depth -->
          <div class="caution-doc-sub" data-animate="image" data-delay="2">
            <img
              src="/images/catalogue/caution-in-use-3.jpg"
              alt="Visitor mid-stride crossing caution carpet at exhibition hall entry — Light + LED Expo Mumbai"
              loading="lazy"
              decoding="async"
              width="4032"
              height="3024"
              style="object-position: 42% 54%"
            />
            <span class="caution-doc-label">Light + LED Expo — Mumbai</span>
          </div>

        </div>
      </div>
    </div>

    <div class="prod-section prod-section--stone" aria-label="Use cases">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Use Cases</span>
          <h2 class="prod-section__title">Where Caution Carpet Is Applied</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {useCases.map((useCase) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label" set:html={useCase}></div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="prod-section" aria-label="On-site handling">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">On-site Handling</span>
          <h2 class="prod-section__title">Installed and Managed<br />by Our Team.</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Caution carpet is supplied pre-cut to the dimensions specified in your
          floor plan and installed on-site by the Sanchi team alongside the
          primary carpet scope. Our crew marks cable tray routes, transition
          zones, and access paths prior to the show opening — and stays available
          through live event days for adjustments, maintenance, and post-show removal.
        </p>
        <p class="prod-section__body" data-animate data-delay="2">
          No separate contractor required. Caution carpet placement is handled
          as part of the same exhibition flooring brief.
        </p>
      </div>
    </div>

    <!-- ─── INDUSTRY CONTEXT ───────────────────────────────────────── -->
    <div class="prod-section prod-section--dark" aria-labelledby="caution-context-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Exhibition Context</span>
          <h2 class="caution-context-title" id="caution-context-heading">Planning Exhibition Safety Flooring as Part of the Brief.</h2>
        </div>
        <p class="prod-section__body--inverse" data-animate data-delay="1">
          Most exhibition flooring briefs arrive without a caution carpet allocation. The primary
          carpet — square metreage, product type, shade — receives the design attention. Caution
          carpet is treated as an operational afterthought: ordered late, sourced separately, or
          improvised on site. This creates avoidable problems. Cable tray routes that weren't
          factored into the floor plan require ad hoc workarounds. Safety transition zones that
          weren't coordinated with the primary carpet installation create visual inconsistency and
          safety gaps at the handover between exhibition areas.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="2">
          At Pragati Maidan in New Delhi, Bombay Exhibition Centre in Mumbai, BIEC in Bengaluru,
          and India Expo Centre in Greater Noida, exhibition infrastructure is substantial. Power
          distribution channels, data cable routes, and AV equipment transitions cross active
          visitor and crew movement paths for the full duration of the event. Caution carpet in
          these environments is not a supplementary specification — it is a core component of a
          well-managed show floor, required both by venue safety protocols and by the operational
          reality of running a live trade fair at scale.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="3">
          Sanchi Enterprises integrates caution carpet into the primary flooring brief from the
          planning stage. When the floor plan is reviewed, cable tray routes, access transition
          points, and emergency exit paths are identified alongside the primary carpet layout.
          Caution carpet is then cut, positioned, and installed as part of the same scope — laid
          in coordination with the primary carpet, fixed for the event period, and removed cleanly
          post-show. No separate contractor and no last-minute sourcing.
        </p>
      </div>
    </div>

    <!-- ─── FAQ ──────────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="caution-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="caution-faq-heading">Common Questions</h2>
        </div>
        <dl class="prod-faq" data-animate data-delay="1">
          {faqs.map((faq) => (
            <div class="prod-faq__item">
              <dt class="prod-faq__q">{faq.q}</dt>
              <dd class="prod-faq__a">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ──────────────────────────────────────── -->
    <div class="prod-section" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="prod-related" data-animate data-delay="1">
          <a href="/products/non-woven-carpet" class="prod-related__link">
            <span class="prod-related__name">Non Woven Carpet</span>
            <span class="prod-related__desc">29 shades — industry standard floor coverage</span>
          </a>
          <a href="/products/ribbed-carpet" class="prod-related__link">
            <span class="prod-related__name">Ribbed Carpet</span>
            <span class="prod-related__desc">High-footfall loop-pile in 7 shades</span>
          </a>
          <a href="/products/velour-carpet" class="prod-related__link">
            <span class="prod-related__name">Velour Carpet</span>
            <span class="prod-related__desc">Premium cut-pile finish in 11 shades</span>
          </a>
          <a href="/products/designer-carpet" class="prod-related__link">
            <span class="prod-related__name">Designer Carpet</span>
            <span class="prod-related__desc">Fully custom printed to your brief</span>
          </a>
        </div>
      </div>
    </div>

    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Caution Carpet</div>
            <p class="prod-cta__sub">Tell us your venue, floor plan, and event dates. We'll scope the caution carpet requirement alongside your primary flooring brief.</p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Caution Carpet Hero — Operations in Motion ───────────────── */
  .caution-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    /* Center-aligned vertically — text floats mid-frame, video action
       visible both above and below. Distinct from dc-hero's flex-end anchor. */
    align-items: center;
    overflow: hidden;
    background-color: var(--color-navy-dark);
  }

  .caution-hero__media {
    position: absolute;
    inset: 0;
  }

  .caution-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Shift slightly left (crops branded text at far-right edge of source frame)
       and below center (keeps caution carpet threshold in the lower portion) */
    object-position: 40% 55%;
  }

  /* Directional overlay — axis is horizontal, not vertical.
     Dark on the left (text side), lighter toward the right (action side).
     A secondary bottom fade grounds the floor and caution carpet.
     This creates a different operational character from the dc-hero's
     bottom-to-top cinematic approach. */
  .caution-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(10, 15, 40, 0.96) 0%,
        rgba(10, 15, 40, 0.80) 30%,
        rgba(10, 15, 40, 0.46) 54%,
        rgba(10, 15, 40, 0.18) 76%,
        rgba(10, 15, 40, 0.06) 100%
      ),
      linear-gradient(
        to top,
        rgba(10, 15, 40, 0.68) 0%,
        transparent 38%
      );
  }

  .caution-hero__content {
    position: relative;
    z-index: 2;
    max-width: 580px;
    padding-top: 120px;
    padding-bottom: var(--sp-7);
  }

  .caution-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(247, 246, 243, 0.38);
    margin-bottom: var(--sp-5);
    transition: color 0.22s ease;
  }
  .caution-hero__back:hover { color: rgba(247, 246, 243, 0.75); }

  /* Title — intentionally smaller than dc-hero's max 96px.
     Operational presence without the artistic scale of Designer Carpet. */
  .caution-hero__title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.0vw, 68px);
    font-weight: 700;
    line-height: 1.07;
    letter-spacing: -0.026em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .caution-hero__intro {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.3vw, 16px);
    line-height: 1.80;
    color: rgba(247, 246, 243, 0.60);
    max-width: 430px;
  }

  /* Mobile: shift to bottom-anchored layout, full-width overlay */
  @media (max-width: 768px) {
    .caution-hero {
      align-items: flex-end;
      padding-bottom: var(--sp-7);
    }
    .caution-hero__content {
      padding-bottom: 0;
    }
    .caution-hero__video {
      object-position: center 55%;
    }
    .caution-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(10, 15, 40, 0.97) 0%,
        rgba(10, 15, 40, 0.70) 42%,
        rgba(10, 15, 40, 0.22) 68%,
        rgba(10, 15, 40, 0.08) 100%
      );
    }
  }

  /* ─── Documentation grid — 3-panel asymmetric ──────────────── */
  .caution-doc-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    grid-template-rows: 1fr 1fr;
    gap: 10px;
    height: 540px;
    margin-top: var(--sp-5);
  }

  .caution-doc-main {
    grid-row: 1 / 3;
    position: relative;
    overflow: hidden;
  }

  .caution-doc-sub {
    position: relative;
    overflow: hidden;
  }

  .caution-doc-main img,
  .caution-doc-sub img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s var(--ease-out);
  }

  .caution-doc-main:hover img,
  .caution-doc-sub:hover img {
    transform: scale(1.03);
  }

  /* Subtle tonal overlay */
  .caution-doc-main::after,
  .caution-doc-sub::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(12, 18, 48, 0.06);
    pointer-events: none;
  }

  /* Event label — floated at bottom-left of each panel */
  .caution-doc-label {
    position: absolute;
    bottom: 14px;
    left: 16px;
    z-index: 2;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(247, 246, 243, 0.72);
    text-shadow: 0 1px 6px rgba(10, 15, 40, 0.55);
    pointer-events: none;
  }

  /* Tablet */
  @media (max-width: 1024px) and (min-width: 769px) {
    .caution-doc-grid {
      height: 440px;
    }
  }

  /* Mobile: natural-ratio stack */
  @media (max-width: 768px) {
    .caution-doc-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      height: auto;
      gap: 10px;
    }
    .caution-doc-main {
      grid-row: auto;
      aspect-ratio: 4 / 3;
    }
    .caution-doc-sub {
      aspect-ratio: 4 / 3;
    }
  }

  /* ─── Industry context ──────────────────────────────────────── */
  .caution-context-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.2vw, 44px);
    font-weight: 700;
    line-height: 1.10;
    letter-spacing: -0.022em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
  }
  .prod-section__body--inverse {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.2vw, 16px);
    line-height: 1.80;
    color: rgba(247, 246, 243, 0.58);
    max-width: 760px;
    margin-top: var(--sp-4);
    margin-bottom: 0;
  }

  /* ─── FAQ + Related products ────────────────────────────────── */
  .prod-faq {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .prod-faq__item {
    border-top: 1px solid var(--color-border-light, rgba(0,0,0,0.08));
    padding-top: var(--sp-4);
  }
  .prod-faq__q {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-navy-dark);
    margin-bottom: var(--sp-2);
