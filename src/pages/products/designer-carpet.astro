---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';

const primaryCaps = [
  { num: '01', title: 'Custom Artwork',         body: 'Original artwork, event photography, and custom illustration integrated directly into the carpet surface.' },
  { num: '02', title: 'Brand Colour Matching',  body: 'Colours produced to your specification — Pantone, RAL, or supplied swatches matched to your identity.' },
  { num: '03', title: 'Logo & Identity Flooring', body: 'Logos and wordmarks printed at exhibition scale, precisely positioned within your floor plan.' },
  { num: '04', title: 'Event Theme Graphics',   body: 'Thematic visual concepts designed around your event — from product launches to industry conferences.' },
];

const extraCaps = [
  'Directional Graphics',
  'Wayfinding Systems',
  'Printed Patterns',
  'Spatial Zone Design',
  'Bespoke Concepts',
  'Full-floor Installation',
];

const steps = [
  { num: '01', label: 'Submit Your Brief',        desc: 'Share brand guidelines, artwork files, event themes, or even rough concepts. We translate them into production-ready exhibition flooring layouts.' },
  { num: '02', label: 'Design & Approval',         desc: 'We create scaled visual proofs for review, revisions, and final approval before print production begins.' },
  { num: '03', label: 'Production & Installation', desc: 'Carpets are printed, finished, delivered, and installed on-site with live exhibition support if required.' },
];

const faqs = [
  {
    q: 'What artwork files or formats do you need to produce custom exhibition carpet?',
    a: 'We accept brand guidelines, vector artwork (.AI, .EPS, .PDF), high-resolution raster files (.PSD, .TIFF at 300dpi or higher), and concept sketches or reference images. Our design team works with what you have — production-ready artwork is developed and approved before any carpet goes to print.',
  },
  {
    q: 'How long does custom designer carpet take from brief to installation?',
    a: 'Lead time depends on the print area and installation scope. Once artwork is approved, production and delivery are coordinated to your event timeline. Submit your brief as early as possible — we will provide a full production schedule when scoping the project.',
  },
  {
    q: 'Can designer carpet reproduce Pantone colours accurately?',
    a: 'Yes. Our production process supports Pantone, RAL, and supplied swatch colour matching to your brand specification. We produce scaled visual proofs for colour approval before print production begins.',
  },
  {
    q: 'Can designer carpet be produced for a single exhibition stall or booth?',
    a: 'Yes. Designer carpet is produced at any scale — from a single brand stall of 20–30 square metres with a logo or brand pattern, to full hall coverage of several thousand square metres with a coordinated printed graphic system. The minimum order is determined by the print area and production setup. Share your floor plan and brief for a project-specific scope.',
  },
  {
    q: 'Which Indian trade fairs have featured Sanchi custom designer carpet?',
    a: 'Our designer carpet installations include Anuga FoodTec India, Light + LED India (Mumbai), Electronica India, India Design (New Delhi), and multiple private brand launches and VIP hospitality installations at Pragati Maidan, Bombay Exhibition Centre, and Jio World Convention Centre. Each installation is produced specifically for that project — there is no shared template or repeat design.',
  },
  {
    q: 'What is the difference between designer carpet and standard exhibition carpet?',
    a: 'Standard exhibition carpet — non woven, ribbed, velour — is selected from a stocked range of fixed colours and supplied cut to your dimensions. Designer carpet is produced specifically for your project: the artwork, colour, scale, and pattern are unique to your brief. It is specified when the floor itself is part of the brand or event identity, not a neutral background surface.',
  },
];
---

<Layout
  title="Custom Designer Exhibition Carpet — Printed Flooring India | Sanchi Enterprises"
  description="Fully custom exhibition carpet produced to your brief — logos, brand colours, event themes, directional graphics, and bespoke artwork at exhibition scale. Designed and installed across India."
  ogImage="https://www.sanchienterprises.com/images/designer-carpet/anuga-blue-wave.webp"
  ogImageWidth="1920"
  ogImageHeight="1440"
  breadcrumbs={[
    { name: 'Products', item: 'https://www.sanchienterprises.com/products' },
    { name: 'Designer Carpet', item: 'https://www.sanchienterprises.com/products/designer-carpet' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://www.sanchienterprises.com/products/designer-carpet/#service",
          "name": "Custom Designer Exhibition Carpet",
          "description": "Fully custom exhibition carpet produced to your specification — logos, brand colours, event themes, directional graphics, and bespoke artwork at exhibition scale. Not template-based. Every carpet starts with your brief.",
          "serviceType": "Custom Exhibition Carpet Production and Installation",
          "provider": { "@id": "https://www.sanchienterprises.com/#organization" },
          "url": "https://www.sanchienterprises.com/products/designer-carpet",
          "image": "https://www.sanchienterprises.com/images/designer-carpet/anuga-blue-wave.webp",
          "areaServed": { "@type": "Country", "name": "India" },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Customisation", "value": "Fully custom — logos, colours, artwork, patterns" },
            { "@type": "PropertyValue", "name": "Colour Matching", "value": "Pantone, RAL, and supplied swatch matching" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India production and installation" }
          ],
          "offers": {
            "@type": "Offer",
            "priceCurrency": "INR",
            "availability": "https://schema.org/InStock",
            "url": "https://www.sanchienterprises.com/products/designer-carpet",
            "seller": { "@type": "Organization", "name": "Sanchi Enterprises" },
            "priceSpecification": {
              "@type": "PriceSpecification",
              "priceCurrency": "INR",
              "price": "0",
              "description": "Custom quotation based pricing. Contact for pricing."
            }
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <!-- ─── HERO — full-viewport, video-backed ───────────────── -->
    <section class="dc-hero" aria-labelledby="dc-heading">
      <div class="dc-hero__media" aria-hidden="true">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster="/images/designer-carpet/electronica-green-aisle.webp"
          class="dc-hero__video"
        >
          <source src="/videos/designer/designer-light-led.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="dc-hero__overlay" aria-hidden="true"></div>

      <div class="container">
        <div class="dc-hero__content">
          <a href="/products" class="dc-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Designer Carpet</span>
          <h1 class="dc-hero__title" id="dc-heading" data-animate data-delay="2">
            Your Design.<br />Your Identity.<br />Your Floor.
          </h1>
          <p class="dc-hero__sub" data-animate data-delay="3">
            Fully custom exhibition carpet designed to your specification —
            not selected from a catalogue.
          </p>
        </div>
      </div>

      <div class="dc-hero__scroll" aria-hidden="true">
        <div class="dc-hero__scroll-line"></div>
      </div>
    </section>

    <!-- ─── STATEMENT — restrained, typographic ──────────────── -->
    <div class="dc-statement" aria-label="Positioning statement">
      <div class="container">
        <div class="dc-statement__inner" data-animate>
          <p class="dc-statement__text">
            Not template-based. Not from a fixed catalogue.<br />
            <span class="dc-statement__em">Every carpet starts with your brief.</span>
          </p>
        </div>
      </div>
    </div>

    <!-- ─── PORTFOLIO GALLERY — editorial hierarchy ─── -->
    <div class="dc-portfolio" aria-label="Designer carpet installations">
      <div class="container">
        <div class="dc-portfolio__label" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Selected Installations</span>
        </div>
      </div>
      <div class="dc-pf-grid">

        <!-- Featured: blue wave grid — earns the full left column -->
        <div class="dc-pf-cell dc-pf-cell--featured">
          <div class="dc-pf-cell__img-wrap">
            <img
              src="/images/designer-carpet/anuga-blue-wave.webp"
              srcset="/images/designer-carpet/anuga-blue-wave-640w.webp 640w, /images/designer-carpet/anuga-blue-wave-1280w.webp 1280w, /images/designer-carpet/anuga-blue-wave.webp 1920w"
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 40vw"
              alt="Full exhibition hall floor covered end-to-end in a bold blue and white wave-grid printed carpet — pattern fills the entire open floor at Anuga Food Tech"
              loading="lazy"
              decoding="async"
              width="4032"
              height="3024"
            />
          </div>
          <div class="dc-pf-cell__info">
            <span class="dc-pf-cell__num" aria-hidden="true">01</span>
            <div class="dc-pf-cell__name">Wave Grid System</div>
            <p class="dc-pf-cell__desc">Interlocking wave geometry printed across a full exhibition hall — carpet as spatial identity.</p>
          </div>
        </div>

        <!-- Secondary A: diamond mono — high-contrast monochrome pattern -->
        <div class="dc-pf-cell dc-pf-cell--secondary">
          <div class="dc-pf-cell__img-wrap">
            <img
              src="/images/designer-carpet/diamond-mono.webp"
              alt="Exhibition refreshment lounge — bold black and white diamond harlequin printed carpet covering the full hospitality zone floor"
              loading="lazy"
              decoding="async"
              width="4032"
              height="3024"
            />
          </div>
          <div class="dc-pf-cell__cap">
            <span aria-hidden="true">02</span>Diamond Grid · Monochrome
          </div>
        </div>

        <!-- Secondary B: Light+LED icon carpet — wide hall, unique tech pattern -->
        <div class="dc-pf-cell dc-pf-cell--secondary">
          <div class="dc-pf-cell__img-wrap">
            <img
              src="/images/designer-carpet/light-led-icon-hall.webp"
              alt="Light + LED India exhibition hall — full floor covered in navy blue printed carpet with white electronics icon pattern"
              loading="lazy"
              decoding="async"
              width="4032"
              height="3024"
            />
          </div>
          <div class="dc-pf-cell__cap">
            <span aria-hidden="true">03</span>Icon Grid
          </div>
        </div>

      </div>
    </div>

    <!-- ─── CAPABILITIES — technical ──────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="caps-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Capabilities</span>
          <h2 class="prod-section__title" id="caps-heading">What We Can Produce</h2>
        </div>
        <div class="dc-caps-grid">
          {primaryCaps.map((cap, i) => (
            <div class="dc-cap-block" data-animate data-delay={String((i % 2) + 1)}>
              <div class="dc-cap-block__num" aria-hidden="true">{cap.num}</div>
              <div class="dc-cap-block__title">{cap.title}</div>
              <div class="dc-cap-block__body">{cap.body}</div>
            </div>
          ))}
        </div>
        <div class="dc-caps-extra" data-animate data-delay="2">
          {extraCaps.map((cap) => (
            <span class="dc-caps-extra__item">{cap}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── PROCESS — dark, atmospheric ──────────────────────── -->
    <div class="dc-process" aria-labelledby="process-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">How It Works</span>
          <h2 class="dc-process__title" id="process-heading">From Brief to Floor.</h2>
        </div>
        <div class="dc-process__steps" data-animate data-delay="1">
          {steps.map((step) => (
            <div class="dc-process__step">
              <div class="dc-process__num" aria-hidden="true">{step.num}</div>
              <div class="dc-process__label">{step.label}</div>
              <div class="dc-process__desc">{step.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── INDUSTRY CONTEXT ───────────────────────────────────── -->
    <div class="prod-section prod-section--dark" aria-labelledby="dc-context-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Exhibition Context</span>
          <h2 class="dc-context-title" id="dc-context-heading">What Designer Carpet Actually Means at Exhibition Scale.</h2>
        </div>
        <p class="prod-section__body--inverse" data-animate data-delay="1">
          At every exhibition, the floor sends a signal. Whether it reads as standard coverage or as
          a spatial identity statement depends on how the flooring decision was made. Non woven,
          ribbed, and velour carpet cover the floor, carry the footfall, and hold the palette. Designer
          carpet is a different category of decision. The artwork, the scale, the pattern, and the
          colour are produced from scratch — nothing is selected from a stock range. When a brand
          specifies designer carpet, the floor stops being a neutral surface and becomes part of the
          spatial communication.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="2">
          At Anuga FoodTec India, the entire hall floor was covered in a bold blue wave-grid system —
          interlocking geometry that read as a single spatial identity from entry to exit across
          several thousand square metres. At Light + LED India in Mumbai, a navy blue icon-pattern
          carpet covered the full exhibition hall: a printed graphic system of electronics symbols
          that extended the visual language of the event from the walls down to the floor. At this
          scale, designer carpet functions as environmental branding — a decision made as part of the
          exhibition design brief, not as a last-minute flooring specification.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="3">
          The same production precision applies at a single stall. A brand logo or a custom pattern
          produced at 30 square metres — correctly positioned within a defined floor plan, matched to
          Pantone or RAL colour standards, and installed without seams or registration errors —
          demands the same accuracy as a full-hall installation. Sanchi produces designer carpet
          across the full scale range: from 20-square-metre branded stalls at Pragati Maidan, Bombay
          Exhibition Centre, and India Expo Centre, to multi-thousand-square-metre installations where
          the floor defines the character of the entire event space.
        </p>
      </div>
    </div>

    <!-- ─── FAQ ─────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="dc-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="dc-faq-heading">Common Questions</h2>
        </div>
        <div data-animate data-delay="1">
          <FAQAccordion faqs={faqs} />
        </div>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ──────────────────────────────────── -->
    <div class="prod-section" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="prod-related" data-animate data-delay="1">
          <a href="/products/non-woven-carpet" class="prod-related__link">
            <span class="prod-related__name">Non Woven Carpet</span>
            <span class="prod-related__desc">29 shades — industry standard floor coverage</span>
          </a>
          <a href="/products/ribbed-carpet" class="prod-related__link">
            <span class="prod-related__name">Ribbed Carpet</span>
            <span class="prod-related__desc">High-footfall loop-pile in 7 shades</span>
          </a>
          <a href="/products/velour-carpet" class="prod-related__link">
            <span class="prod-related__name">Velour Carpet</span>
            <span class="prod-related__desc">Premium cut-pile finish in 11 shades</span>
          </a>
          <a href="/products/caution-carpet" class="prod-related__link">
            <span class="prod-related__name">Caution Carpet</span>
            <span class="prod-related__desc">Safety flooring for cable trays and access zones</span>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── CTA ───────────────────────────────────────────────── -->
    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Start Your Design Brief</div>
            <p class="prod-cta__sub">
              Share your brand guidelines, artwork files, or event concept —
              we'll outline the production scope and timeline within 24 hours.
            </p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Design Brief</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<script>
  // Portfolio hover: entering the grid dims all panels; individual hover restores that panel
  const pfGrid = document.querySelector<HTMLElement>('.dc-pf-grid');
  if (pfGrid) {
    pfGrid.addEventListener('mouseenter', () => {
      pfGrid.querySelectorAll<HTMLElement>('.dc-pf-cell__img-wrap img').forEach((img) => {
        img.style.filter = 'brightness(0.28) saturate(0.35)';
      });
    });
    pfGrid.addEventListener('mouseleave', () => {
      pfGrid.querySelectorAll<HTMLElement>('.dc-pf-cell__img-wrap img').forEach((img) => {
        img.style.filter = '';
      });
    });
    pfGrid.querySelectorAll<HTMLElement>('.dc-pf-cell').forEach((cell) => {
      cell.addEventListener('mouseenter', () => {
        const img = cell.querySelector<HTMLElement>('.dc-pf-cell__img-wrap img');
        if (img) img.style.filter = 'brightness(1.0) saturate(1.05)';
      });
    });
  }
</script>

<style>
  /* ─── Hero ─────────────────────────────────────────────────── */
  .dc-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-bottom: var(--sp-8);
    background-color: var(--color-navy-dark);
  }

  .dc-hero__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .dc-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .dc-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 12, 36, 0.97) 0%,
      rgba(8, 12, 36, 0.68) 36%,
      rgba(8, 12, 36, 0.28) 72%,
      rgba(8, 12, 36, 0.16) 100%
    );
  }

  .dc-hero__content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding-top: 140px;
  }

  .dc-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(247, 246, 243, 0.40);
    margin-bottom: var(--sp-5);
    transition: color 0.22s var(--ease-out);
  }
  .dc-hero__back:hover { color: rgba(247, 246, 243, 0.80); }

  .dc-hero__title {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.034em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .dc-hero__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.3vw, 17px);
    line-height: 1.72;
    color: rgba(247, 246, 243, 0.58);
    max-width: 420px;
  }

  .dc-hero__scroll {
    position: absolute;
    bottom: 40px;
    right: 48px;
    z-index: 2;
  }
  .dc-hero__scroll-line {
    width: 1px;
    height: 70px;
    background: linear-gradient(to bottom, transparent, rgba(247, 246, 243, 0.40));
    animation: dc-scroll 2.8s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes dc-scroll {
    0%, 100% { opacity: 0.30; transform: scaleY(0.5); }
    55% { opacity: 0.85; transform: scaleY(1); }
  }

  /* ─── Statement band ────────────────────────────────────────── */
  .dc-statement {
    background: var(--color-warm-white);
    padding: var(--sp-9) 0;
  }
  .dc-statement__inner {
    max-width: 820px;
  }
  .dc-statement__text {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.8vw, 34px);
    font-weight: 600;
    line-height: 1.38;
    letter-spacing: -0.016em;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .dc-statement__em {
    color: var(--color-navy-dark);
    font-weight: 700;
  }

  /* ─── Portfolio gallery — editorial hierarchy ──────────────── */
  .dc-portfolio {
    background: var(--color-navy-dark);
    padding-top: var(--sp-8);
  }

  .dc-portfolio__label {
    padding-bottom: var(--sp-6);
  }

  .dc-pf-grid {
    display: grid;
    grid-template-columns: 58% 42%;
    grid-template-rows: 1fr 1fr;
    min-height: 820px;
    gap: 3px;
  }

  .dc-pf-cell {
    position: relative;
    overflow: hidden;
  }

  .dc-pf-cell--featured {
    grid-row: 1 / 3;
    grid-column: 1;
  }

  .dc-pf-cell--secondary {
    grid-column: 2;
  }

  .dc-pf-cell__img-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .dc-pf-cell__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
