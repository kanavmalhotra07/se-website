---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';

const regularShades = [
  { name: 'Light Grey',   img: '/images/catalogue/nw-light-grey.webp'   },
  { name: 'Light Camel',  img: '/images/catalogue/nw-light-camel.webp'  },
  { name: 'Camel',        img: '/images/catalogue/nw-camel.webp'        },
  { name: 'Light Brown',  img: '/images/catalogue/nw-light-brown.webp'  },
  { name: 'Dark Brown',   img: '/images/catalogue/nw-dark-brown.webp'   },
  { name: 'Dark Grey',    img: '/images/catalogue/nw-dark-grey.webp'    },
  { name: 'Black',        img: '/images/catalogue/nw-black.webp'        },
  { name: 'Blue Black',   img: '/images/catalogue/nw-blue-black.webp'   },
  { name: 'Green Black',  img: '/images/catalogue/nw-green-black.webp'  },
  { name: 'Plain Green',  img: '/images/catalogue/nw-plain-green.webp'  },
  { name: 'Red',          img: '/images/catalogue/nw-red.webp'          },
  { name: 'Red Black',    img: '/images/catalogue/nw-red-black.webp'    },
  { name: 'Magenta',      img: '/images/catalogue/nw-magenta.webp'      },
  { name: 'Plain Blue',   img: '/images/catalogue/nw-blue.webp'         },
];

const premiumShades = [
  { name: 'Orange',        img: '/images/catalogue/nw-p-orange.webp'        },
  { name: 'Saffron',       img: '/images/catalogue/nw-p-safron.webp'        },
  { name: 'Yellow',        img: '/images/catalogue/nw-p-yellow.webp'        },
  { name: 'Yellow Green',  img: '/images/catalogue/nw-p-yellow-green.webp'  },
  { name: 'Cactus Green',  img: '/images/catalogue/nw-p-cactus-green.webp'  },
  { name: 'Aqua Green',    img: '/images/catalogue/nw-p-aqua-green.webp'    },
  { name: 'Firozi Blue',   img: '/images/catalogue/nw-p-firozi-blue.webp'   },
  { name: 'Turkish Blue',  img: '/images/catalogue/nw-p-turkish-blue.webp'  },
  { name: 'Oasis Blue',    img: '/images/catalogue/nw-p-oasis-blue.webp'    },
  { name: 'Silver Grey',   img: '/images/catalogue/nw-p-silver-grey.webp'   },
  { name: 'Pink',          img: '/images/catalogue/nw-p-pink.webp'          },
  { name: 'Purple',        img: '/images/catalogue/nw-p-purple.webp'        },
  { name: 'Violet',        img: '/images/catalogue/nw-p-violet.webp'        },
  { name: 'Dark Purple',   img: '/images/catalogue/nw-p-dark-purple.webp'   },
  { name: 'Golden',        img: '/images/catalogue/nw-p-golden.webp'        },
];

const applications = [
  'Trade Fair Halls',
  'Expo Pavilions',
  'Convention Corridors',
  'Open-plan Event Areas',
  'Stall Flooring',
  'Temporary Installations',
  'Multi-day Events',
  'Budget-conscious Projects',
];

const faqs = [
  {
    q: 'What is the difference between Regular and Premium grade non woven carpet?',
    a: 'Regular grade is the practical choice for large-area floor coverage where cost efficiency is the primary consideration — reliable appearance and easy handling for high-volume trade fair installations. Premium grade uses a denser construction with a more refined surface finish, suited to pavilions where presentation quality needs to be higher without moving to cut-pile alternatives such as velour.',
  },
  {
    q: 'What floor areas can non woven carpet cover?',
    a: 'Non woven carpet scales to any event size — from a few hundred square metres for a single stall to several thousand square metres covering multiple halls simultaneously. Carpet is supplied in bulk rolls and pre-cut to your floor plan dimensions.',
  },
  {
    q: 'Which trade fairs and exhibitions use non woven carpet?',
    a: 'Non woven carpet is the default floor covering across the Indian exhibition industry. It is installed at Pragati Maidan (New Delhi), Yashobhoomi (Dwarka), Bombay Exhibition Centre (Mumbai), Jio World Convention Centre, BIEC (Bengaluru), India Expo Centre (Greater Noida), and every major trade fair venue in India.',
  },
  {
    q: 'What is the minimum order quantity for non woven carpet?',
    a: 'Minimum order quantities depend on the shade and grade. For large exhibition projects — covering hundreds or thousands of square metres — carpet is supplied in full or partial roll quantities. We supply smaller quantities for individual stall flooring and large bulk orders for full hall coverage. Share your floor plan and we will confirm the quantity and pricing.',
  },
  {
    q: 'Can non woven carpet be reused across multiple events?',
    a: 'Standard practice in the Indian exhibition industry is to supply non woven carpet as a single-event material. The product is designed for efficient deployment and post-show removal rather than long-term reuse. For organizers managing carpet across a full event season, we can advise on the right grade and quantity strategy.',
  },
  {
    q: 'How far in advance should non woven carpet be ordered?',
    a: 'Because we maintain year-round inventory across both Regular and Premium grades — with stock held in Delhi and Mumbai — most orders can be fulfilled on relatively short notice. For large-scale orders covering multiple halls, we recommend confirming requirements at least 4–6 weeks before the event move-in date to allow pre-cutting and logistics coordination.',
  },
];
---

<Layout
  title="Non Woven Exhibition Carpet — Bulk Supply & Installation | Sanchi Enterprises"
  description="Non woven exhibition carpet in Regular and Premium grades — 29 shades in permanent stock. The industry standard for trade fair floor coverage across India. Bulk supply and on-site installation."
  ogImage="https://www.sanchienterprises.com/images/products/non-woven/nw-in-use-1.webp"
  ogImageWidth="1920"
  ogImageHeight="1440"
  breadcrumbs={[
    { name: 'Products', item: 'https://www.sanchienterprises.com/products' },
    { name: 'Non Woven Carpet', item: 'https://www.sanchienterprises.com/products/non-woven-carpet' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://www.sanchienterprises.com/products/non-woven-carpet/#service",
          "name": "Non Woven Exhibition Carpet",
          "description": "Non woven exhibition carpet available in Regular and Premium grades. 14 Regular shades and 15 Premium shades, all in permanent stock. The most widely used flooring product in the Indian exhibition industry — lightweight, cost-effective, and supplied cut to specification.",
          "serviceType": "Exhibition Carpet Supply and Installation",
          "provider": { "@id": "https://www.sanchienterprises.com/#organization" },
          "url": "https://www.sanchienterprises.com/products/non-woven-carpet",
          "image": "https://www.sanchienterprises.com/images/products/non-woven/nw-in-use-1.webp",
          "areaServed": { "@type": "Country", "name": "India" },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Grades", "value": "Regular and Premium" },
            { "@type": "PropertyValue", "name": "Total Colours", "value": "29 shades" },
            { "@type": "PropertyValue", "name": "Supply Format", "value": "Bulk roll, cut to size" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India delivery" }
          ],
          "offers": {
            "@type": "Offer",
            "priceCurrency": "INR",
            "availability": "https://schema.org/InStock",
            "url": "https://www.sanchienterprises.com/products/non-woven-carpet",
            "seller": { "@type": "Organization", "name": "Sanchi Enterprises" },
            "priceSpecification": {
              "@type": "PriceSpecification",
              "priceCurrency": "INR",
              "price": "0",
              "description": "Custom quotation based pricing. Contact for pricing."
            }
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <!-- ─── HERO — exhibition floor at full scale ───────────────────── -->
    <section class="nw-hero" aria-labelledby="nonwoven-heading">
      <div class="nw-hero__media" aria-hidden="true">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/images/products/non-woven/nw-hero-poster.webp"
          class="nw-hero__video"
        >
          <source src="/videos/nw-hero.mp4" type="video/mp4" />
          <img
            src="/images/products/non-woven/nw-hero-poster.webp"
            alt=""
            width="1920"
            height="1080"
            loading="eager"
            decoding="async"
          />
        </video>
      </div>
      <div class="nw-hero__overlay" aria-hidden="true"></div>

      <div class="container">
        <div class="nw-hero__content">
          <a href="/products" class="nw-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Non Woven Carpet</span>
          <h1 class="nw-hero__title" id="nonwoven-heading" data-animate data-delay="2">
            The Exhibition Industry<br />Standard Floor Covering.
          </h1>
          <p class="nw-hero__intro" data-animate data-delay="3">
            Non woven carpet is the most widely used flooring product in
            the Indian exhibition industry. Lightweight, cost-effective,
            and available in Regular and Premium grades — covering large floor
            areas efficiently, supplied cut to specification, ready for
            direct installation.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── GRADE OVERVIEW ───────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-label="Grade overview">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">About the Product</span>
          <h2 class="prod-section__title">Two Grades. 29 Colours.</h2>
        </div>
        <div class="nw-grades" data-animate data-delay="1">
          <div class="nw-grade">
            <div class="nw-grade__label">Regular Shade</div>
            <p class="nw-grade__desc">
              The practical choice for general exhibition floor coverage.
              Reliable appearance, easy to handle, and well suited to
              high-volume installations where cost efficiency matters.
              14 colours in permanent stock.
            </p>
          </div>
          <div class="nw-grade__divider" aria-hidden="true"></div>
          <div class="nw-grade">
            <div class="nw-grade__label">Premium Shade</div>
            <p class="nw-grade__desc">
              Denser construction and a more refined surface finish.
              Selected for pavilions where the floor presentation is
              expected to meet a higher standard — without moving to
              velour or ribbed alternatives. 15 colours in permanent stock.
            </p>
          </div>
        </div>
        <div class="prod-features" data-animate data-delay="2">
          <div class="prod-feature">
            <div class="prod-feature__label">Grades Available</div>
            <div class="prod-feature__value">Regular &amp; Premium</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Total Colours</div>
            <div class="prod-feature__value">29 shades</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Supply Format</div>
            <div class="prod-feature__value">Bulk roll, cut to size</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Installation</div>
            <div class="prod-feature__value">Supply &amp; lay available</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Inventory</div>
            <div class="prod-feature__value">Year-round stock maintained</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Coverage</div>
            <div class="prod-feature__value">Pan-India delivery</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── REGULAR SHADES ───────────────────────────────────────────────── -->
    <div class="nw-shade-section" aria-labelledby="regular-heading">
      <div class="container">
        <div class="nw-shade-header" data-animate>
          <div class="nw-shade-header__left">
            <span class="eyebrow eyebrow--line">Shade Catalogue</span>
            <h2 class="nw-shade-title" id="regular-heading">Regular Shade</h2>
          </div>
          <div class="nw-shade-header__right">
            <span class="nw-shade-count">14 colours</span>
            <p class="nw-shade-sub">All held in stock year-round</p>
          </div>
        </div>
        <div class="shade-grid" data-animate data-delay="1">
          {regularShades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 5) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Non Woven Regular — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── PREMIUM SHADES ───────────────────────────────────────────────── -->
    <div class="nw-shade-section nw-shade-section--premium" aria-labelledby="premium-heading">
      <div class="container">
        <div class="nw-shade-header" data-animate>
          <div class="nw-shade-header__left">
            <span class="eyebrow eyebrow--line">Shade Catalogue</span>
            <h2 class="nw-shade-title" id="premium-heading">Premium Shade</h2>
          </div>
          <div class="nw-shade-header__right">
            <span class="nw-shade-count">15 colours</span>
            <p class="nw-shade-sub">All held in stock year-round</p>
          </div>
        </div>
        <div class="shade-grid" data-animate data-delay="1">
          {premiumShades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 5) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Non Woven Premium — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
        <p class="nw-shade-note" data-animate data-delay="2">
          Colour representation may vary from screen reproduction. Contact us to arrange physical samples.
        </p>
      </div>
    </div>

    <!-- ─── IN USE GALLERY ───────────────────────────────────────────────── -->
    <div class="prod-section" aria-label="Installation photography">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">In Use</span>
          <h2 class="prod-section__title">Non Woven Carpet Across India.</h2>
        </div>
        <div class="nw-gallery" data-animate data-delay="1">
          <div class="nw-gallery__item nw-gallery__item--tall">
            <img
              src="/images/products/non-woven/nw-in-use-1.webp"
              alt="Purple non woven carpet at Light + LED Expo Mumbai — registration desk with attendees on carpet floor"
              loading="lazy"
              decoding="async"
              width="5712"
              height="4284"
              style="object-position: center 48%"
            />
          </div>
          <div class="nw-gallery__item">
            <img
              src="/images/products/non-woven/nw-in-use-2.webp"
              alt="Pink non woven carpet running through a trade fair corridor — booths lining both sides"
              loading="lazy"
              decoding="async"
              width="4032"
              height="3024"
              style="object-position: center 58%"
            />
          </div>
          <div class="nw-gallery__item">
            <img
              src="/images/products/non-woven/nw-in-use-3.webp"
              alt="Blue non woven carpet at India Maritime Week 2025 — large crowd on exhibition floor"
              loading="lazy"
              decoding="async"
              width="5712"
              height="4284"
              style="object-position: center 52%"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- ─── APPLICATIONS ─────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-label="Applications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title">Common Uses</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── SUPPLY & INSTALLATION ────────────────────────────────────────── -->
    <div class="prod-section" aria-label="Installation and supply">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Supply &amp; Installation</span>
          <h2 class="prod-section__title">From Bulk Supply to<br />On-site Installation.</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Sanchi Enterprises supplies non woven carpet in bulk quantities,
          pre-cut and labelled to your floor plan. Our team handles on-site
          laying, edge finishing, and live-day maintenance — coordinated
          through a single point of contact from order through to post-show removal.
        </p>
        <p class="prod-section__body" data-animate data-delay="2">
          Inventory is maintained year-round across both grades, allowing
          short-notice orders to be fulfilled without compromise on quality
          or availability.
        </p>
      </div>
    </div>

    <!-- ─── INDUSTRY CONTEXT ─────────────────────────────────────────────── -->
    <div class="prod-section prod-section--dark" aria-labelledby="nw-context-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Exhibition Context</span>
          <h2 class="nw-context-title" id="nw-context-heading">India's Exhibition Industry Runs on Non Woven Carpet.</h2>
        </div>
        <p class="prod-section__body--inverse" data-animate data-delay="1">
          Walk into any trade fair in India — at Pragati Maidan in New Delhi, Bombay Exhibition
          Centre in Mumbai, BIEC in Bengaluru, or India Expo Centre in Greater Noida — and the
          floor beneath your feet is almost certainly non woven carpet. It has been the default
          exhibition floor covering in India for decades: reliable in performance, available in
          sufficient volume, and cost-effective at the scale that exhibition organisers and
          contractors demand.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="2">
          Non woven carpet covers areas that few other flooring materials can manage efficiently
          at exhibition scale. Halls of 10,000 square metres. Multi-hall events running 50,000
          square metres of floor in parallel. Individual stall floors at a few hundred square
          metres each. The material's lightweight structure and simple installation method allow
          large teams to cover significant floor areas within the overnight build window that
          most trade fair venues in India operate.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="3">
          For exhibition organizers and stall contractors across India's full exhibition calendar
          — from auto shows and technology expos to food and textile trade fairs — non woven
          carpet's compatibility with all standard installation methods, year-round stock
          availability, and cost efficiency at large floor areas make it the practical choice
          the industry keeps returning to, event after event.
        </p>
      </div>
    </div>

    <!-- ─── FAQ ──────────────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="nw-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="nw-faq-heading">Common Questions</h2>
        </div>
        <div data-animate data-delay="1">
          <FAQAccordion faqs={faqs} />
        </div>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ─────────────────────────────────────────────── -->
    <div class="prod-section" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="prod-related" data-animate data-delay="1">
          <a href="/products/ribbed-carpet" class="prod-related__link">
            <span class="prod-related__name">Ribbed Carpet</span>
            <span class="prod-related__desc">High-footfall loop-pile in 7 shades</span>
          </a>
          <a href="/products/velour-carpet" class="prod-related__link">
            <span class="prod-related__name">Velour Carpet</span>
            <span class="prod-related__desc">Premium cut-pile finish in 11 shades</span>
          </a>
          <a href="/products/designer-carpet" class="prod-related__link">
            <span class="prod-related__name">Designer Carpet</span>
            <span class="prod-related__desc">Fully custom printed to your brief</span>
          </a>
          <a href="/products/caution-carpet" class="prod-related__link">
            <span class="prod-related__name">Caution Carpet</span>
            <span class="prod-related__desc">Safety flooring for cable trays and access zones</span>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── CTA ──────────────────────────────────────────────────────────── -->
    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Non Woven Carpet</div>
            <p class="prod-cta__sub">
              Share your floor area, grade preference, and event dates.
              We'll confirm stock, pricing, and installation options within 24 hours.
            </p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Industry context (dark section) ─────────────────────────────────── */
  .nw-context-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 42px);
    font-weight: 700;
    line-height: 1.1;
