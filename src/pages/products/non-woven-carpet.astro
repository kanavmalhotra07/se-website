---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const regularShades = [
  { name: 'Light Grey',   img: '/images/catalogue/nw-light-grey.jpg'   },
  { name: 'Light Camel',  img: '/images/catalogue/nw-light-camel.jpg'  },
  { name: 'Camel',        img: '/images/catalogue/nw-camel.jpg'        },
  { name: 'Light Brown',  img: '/images/catalogue/nw-light-brown.jpg'  },
  { name: 'Dark Brown',   img: '/images/catalogue/nw-dark-brown.jpg'   },
  { name: 'Dark Grey',    img: '/images/catalogue/nw-dark-grey.jpg'    },
  { name: 'Black',        img: '/images/catalogue/nw-black.jpg'        },
  { name: 'Blue Black',   img: '/images/catalogue/nw-blue-black.jpg'   },
  { name: 'Green Black',  img: '/images/catalogue/nw-green-black.jpg'  },
  { name: 'Plain Green',  img: '/images/catalogue/nw-plain-green.jpg'  },
  { name: 'Red',          img: '/images/catalogue/nw-red.jpg'          },
  { name: 'Red Black',    img: '/images/catalogue/nw-red-black.jpg'    },
  { name: 'Magenta',      img: '/images/catalogue/nw-magenta.jpg'      },
  { name: 'Plain Blue',   img: '/images/catalogue/nw-blue.jpg'         },
];

const premiumShades = [
  { name: 'Orange',        img: '/images/catalogue/nw-p-orange.jpg'        },
  { name: 'Saffron',       img: '/images/catalogue/nw-p-safron.jpg'        },
  { name: 'Yellow',        img: '/images/catalogue/nw-p-yellow.jpg'        },
  { name: 'Yellow Green',  img: '/images/catalogue/nw-p-yellow-green.jpg'  },
  { name: 'Cactus Green',  img: '/images/catalogue/nw-p-cactus-green.jpg'  },
  { name: 'Aqua Green',    img: '/images/catalogue/nw-p-aqua-green.jpg'    },
  { name: 'Firozi Blue',   img: '/images/catalogue/nw-p-firozi-blue.jpg'   },
  { name: 'Turkish Blue',  img: '/images/catalogue/nw-p-turkish-blue.jpg'  },
  { name: 'Oasis Blue',    img: '/images/catalogue/nw-p-oasis-blue.jpg'    },
  { name: 'Silver Grey',   img: '/images/catalogue/nw-p-silver-grey.jpg'   },
  { name: 'Pink',          img: '/images/catalogue/nw-p-pink.jpg'          },
  { name: 'Purple',        img: '/images/catalogue/nw-p-purple.jpg'        },
  { name: 'Violet',        img: '/images/catalogue/nw-p-violet.jpg'        },
  { name: 'Dark Purple',   img: '/images/catalogue/nw-p-dark-purple.jpg'   },
  { name: 'Golden',        img: '/images/catalogue/nw-p-golden.jpg'        },
];

const applications = [
  'Trade Fair Halls',
  'Expo Pavilions',
  'Convention Corridors',
  'Open-plan Event Areas',
  'Stall Flooring',
  'Temporary Installations',
  'Multi-day Events',
  'Budget-conscious Projects',
];
---

<Layout
  title="Non Woven Carpet — Sanchi Enterprises"
  description="Non Woven exhibition carpet in Regular and Premium grades. 14 Regular and 15 Premium shades. The industry standard for trade fair floor coverage. Bulk supply and on-site installation across India."
>
  <Navbar />
  <main>

    <!-- ─── HERO — exhibition floor at full scale ───────────────────── -->
    <section class="nw-hero" aria-labelledby="nonwoven-heading">
      <div class="nw-hero__media" aria-hidden="true">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/images/products/non-woven/nw-hero-poster.jpg"
          class="nw-hero__video"
        >
          <source src="/videos/nw-hero.mp4" type="video/mp4" />
          <img
            src="/images/products/non-woven/nw-hero-poster.jpg"
            alt=""
            width="1920"
            height="1080"
          />
        </video>
      </div>
      <div class="nw-hero__overlay" aria-hidden="true"></div>

      <div class="container">
        <div class="nw-hero__content">
          <a href="/products" class="nw-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Non Woven Carpet</span>
          <h1 class="nw-hero__title" id="nonwoven-heading" data-animate data-delay="2">
            The Exhibition Industry<br />Standard Floor Covering.
          </h1>
          <p class="nw-hero__intro" data-animate data-delay="3">
            Non woven carpet is the most widely used flooring product in
            the Indian exhibition industry. Lightweight, cost-effective,
            and available in Regular and Premium grades — covering large floor
            areas efficiently, supplied cut to specification, ready for
            direct installation.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── GRADE OVERVIEW ───────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-label="Grade overview">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">About the Product</span>
          <h2 class="prod-section__title">Two Grades. 29 Colours.</h2>
        </div>
        <div class="nw-grades" data-animate data-delay="1">
          <div class="nw-grade">
            <div class="nw-grade__label">Regular Shade</div>
            <p class="nw-grade__desc">
              The practical choice for general exhibition floor coverage.
              Reliable appearance, easy to handle, and well suited to
              high-volume installations where cost efficiency matters.
              14 colours in permanent stock.
            </p>
          </div>
          <div class="nw-grade__divider" aria-hidden="true"></div>
          <div class="nw-grade">
            <div class="nw-grade__label">Premium Shade</div>
            <p class="nw-grade__desc">
              Denser construction and a more refined surface finish.
              Selected for pavilions where the floor presentation is
              expected to meet a higher standard — without moving to
              velour or ribbed alternatives. 15 colours in permanent stock.
            </p>
          </div>
        </div>
        <div class="prod-features" data-animate data-delay="2">
          <div class="prod-feature">
            <div class="prod-feature__label">Grades Available</div>
            <div class="prod-feature__value">Regular &amp; Premium</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Total Colours</div>
            <div class="prod-feature__value">29 shades</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Supply Format</div>
            <div class="prod-feature__value">Bulk roll, cut to size</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Installation</div>
            <div class="prod-feature__value">Supply &amp; lay available</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Inventory</div>
            <div class="prod-feature__value">Year-round stock maintained</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Coverage</div>
            <div class="prod-feature__value">Pan-India delivery</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── REGULAR SHADES ───────────────────────────────────────────────── -->
    <div class="nw-shade-section" aria-labelledby="regular-heading">
      <div class="container">
        <div class="nw-shade-header" data-animate>
          <div class="nw-shade-header__left">
            <span class="eyebrow eyebrow--line">Shade Catalogue</span>
            <h2 class="nw-shade-title" id="regular-heading">Regular Shade</h2>
          </div>
          <div class="nw-shade-header__right">
            <span class="nw-shade-count">14 colours</span>
            <p class="nw-shade-sub">All held in stock year-round</p>
          </div>
        </div>
        <div class="shade-grid" data-animate data-delay="1">
          {regularShades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 5) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Non Woven Regular — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── PREMIUM SHADES ───────────────────────────────────────────────── -->
    <div class="nw-shade-section nw-shade-section--premium" aria-labelledby="premium-heading">
      <div class="container">
        <div class="nw-shade-header" data-animate>
          <div class="nw-shade-header__left">
            <span class="eyebrow eyebrow--line">Shade Catalogue</span>
            <h2 class="nw-shade-title" id="premium-heading">Premium Shade</h2>
          </div>
          <div class="nw-shade-header__right">
            <span class="nw-shade-count">15 colours</span>
            <p class="nw-shade-sub">All held in stock year-round</p>
          </div>
        </div>
        <div class="shade-grid" data-animate data-delay="1">
          {premiumShades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 5) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Non Woven Premium — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
        <p class="nw-shade-note" data-animate data-delay="2">
          Colour representation may vary from screen reproduction. Contact us to arrange physical samples.
        </p>
      </div>
    </div>

    <!-- ─── IN USE GALLERY ───────────────────────────────────────────────── -->
    <div class="prod-section" aria-label="Installation photography">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">In Use</span>
          <h2 class="prod-section__title">Non Woven Carpet Across India.</h2>
        </div>
        <div class="nw-gallery" data-animate data-delay="1">
          <div class="nw-gallery__item nw-gallery__item--tall">
            <img
              src="/images/products/non-woven/nw-in-use-1.jpg"
              alt="Purple non woven carpet at Light + LED Expo Mumbai — registration desk with attendees on carpet floor"
              loading="lazy"
              decoding="async"
              width="5712"
              height="4284"
              style="object-position: center 48%"
            />
          </div>
          <div class="nw-gallery__item">
            <img
              src="/images/products/non-woven/nw-in-use-2.jpg"
              alt="Pink non woven carpet running through a trade fair corridor — booths lining both sides"
              loading="lazy"
              decoding="async"
              width="4032"
              height="3024"
              style="object-position: center 58%"
            />
          </div>
          <div class="nw-gallery__item">
            <img
              src="/images/products/non-woven/nw-in-use-3.jpg"
              alt="Blue non woven carpet at India Maritime Week 2025 — large crowd on exhibition floor"
              loading="lazy"
              decoding="async"
              width="5712"
              height="4284"
              style="object-position: center 52%"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- ─── APPLICATIONS ─────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-label="Applications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title">Common Uses</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── SUPPLY & INSTALLATION ────────────────────────────────────────── -->
    <div class="prod-section" aria-label="Installation and supply">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Supply &amp; Installation</span>
          <h2 class="prod-section__title">From Bulk Supply to<br />On-site Installation.</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Sanchi Enterprises supplies non woven carpet in bulk quantities,
          pre-cut and labelled to your floor plan. Our team handles on-site
          laying, edge finishing, and live-day maintenance — coordinated
          through a single point of contact from order through to post-show removal.
        </p>
        <p class="prod-section__body" data-animate data-delay="2">
          Inventory is maintained year-round across both grades, allowing
          short-notice orders to be fulfilled without compromise on quality
          or availability.
        </p>
      </div>
    </div>

    <!-- ─── CTA ──────────────────────────────────────────────────────────── -->
    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Non Woven Carpet</div>
            <p class="prod-cta__sub">
              Share your floor area, grade preference, and event dates.
              We'll confirm stock, pricing, and installation options within 24 hours.
            </p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Non Woven Hero — exhibition floor at full scale ─────────────────── */
  .nw-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: var(--color-navy-dark);
  }

  .nw-hero__media {
    position: absolute;
    inset: 0;
  }

  .nw-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 52%;
  }

  /* Left-heavy gradient: text side is dark, exhibition energy bleeds right */
  .nw-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(8, 12, 32, 0.94) 0%,
        rgba(8, 12, 32, 0.78) 28%,
        rgba(8, 12, 32, 0.44) 52%,
        rgba(8, 12, 32, 0.16) 76%,
        rgba(8, 12, 32, 0.04) 100%
      ),
      linear-gradient(
        to top,
        rgba(8, 12, 32, 0.72) 0%,
        transparent 36%
      );
  }

  .nw-hero__content {
    position: relative;
    z-index: 2;
    max-width: 580px;
    padding-top: 120px;
    padding-bottom: var(--sp-7);
  }

  .nw-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(247, 246, 243, 0.38);
    margin-bottom: var(--sp-5);
    transition: color 0.22s ease;
  }
  .nw-hero__back:hover { color: rgba(247, 246, 243, 0.75); }

  .nw-hero__title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.0vw, 68px);
    font-weight: 700;
    line-height: 1.07;
    letter-spacing: -0.026em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .nw-hero__intro {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.3vw, 16px);
    line-height: 1.80;
    color: rgba(247, 246, 243, 0.60);
    max-width: 430px;
  }

  @media (max-width: 768px) {
    .nw-hero {
      align-items: flex-end;
      padding-bottom: var(--sp-7);
    }
    .nw-hero__content {
      padding-bottom: 0;
    }
    .nw-hero__video {
      object-position: center 52%;
    }
    .nw-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(8, 12, 32, 0.96) 0%,
        rgba(8, 12, 32, 0.68) 40%,
        rgba(8, 12, 32, 0.20) 68%,
        rgba(8, 12, 32, 0.06) 100%
      );
    }
  }

  /* ─── Grade split overview ─────────────────────────────────────────────── */
  .nw-grades {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--sp-5);
    margin-bottom: var(--sp-6);
    align-items: start;
  }

  .nw-grade__label {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-navy);
    margin-bottom: var(--sp-2);
  }

  .nw-grade__desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .nw-grade__divider {
    width: 1px;
    background: var(--color-border-light);
    align-self: stretch;
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .nw-grades {
      grid-template-columns: 1fr;
    }
    .nw-grade__divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }
  }

  /* ─── Shade section header ─────────────────────────────────────────────── */
  .nw-shade-section {
    padding: var(--sp-8) 0 var(--sp-7);
  }

  .nw-shade-section--premium {
    background: var(--color-stone);
  }

  .nw-shade-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
    gap: var(--sp-4);
  }

  .nw-shade-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 700;
    color: var(--color-navy-dark);
    margin: var(--sp-2) 0 0;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .nw-shade-count {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--color-navy);
    display: block;
    line-height: 1;
    text-align: right;
  }

  .nw-shade-sub {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 4px 0 0;
    text-align: right;
  }

  .nw-shade-note {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-tertiary, rgba(0,0,0,0.38));
    margin-top: var(--sp-4);
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .nw-shade-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .nw-shade-count,
    .nw-shade-sub {
      text-align: left;
    }
  }

  /* ─── Installation gallery ─────────────────────────────────────────────── */
  .nw-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 10px;
  }

  .nw-gallery__item {
    overflow: hidden;
    border-radius: 4px;
  }

  .nw-gallery__item--tall {
    grid-row: 1 / 3;
  }

  .nw-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.70s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nw-gallery__item--tall img { min-height: 480px; }
  .nw-gallery__item:not(.nw-gallery__item--tall) img { aspect-ratio: 4 / 3; }
  .nw-gallery__item:hover img { transform: scale(1.035); }

  @media (max-width: 640px) {
    .nw-gallery {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .nw-gallery__item--tall { grid-row: auto; }
    .nw-gallery__item--tall img { min-height: 260px; }
    .nw-gallery__item:not(.nw-gallery__item--tall) img { aspect-ratio: 3 / 2; }
  }
</style>
