---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const shades = [
  { name: 'Black',        img: '/images/catalogue/velour-black.webp'        },
  { name: 'Dark Grey',    img: '/images/catalogue/velour-dark-grey.webp'    },
  { name: 'Medium Grey',  img: '/images/catalogue/velour-medium-grey.webp'  },
  { name: 'Silver Grey',  img: '/images/catalogue/velour-silver-grey.webp'  },
  { name: 'Camel',        img: '/images/catalogue/velour-camel.webp'        },
  { name: 'Dark Brown',   img: '/images/catalogue/velour-dark-brown.webp'   },
  { name: 'Red',          img: '/images/catalogue/velour-red.webp'          },
  { name: 'Red Black',    img: '/images/catalogue/velour-red-black.webp'    },
  { name: 'Pink',         img: '/images/catalogue/velour-pink.webp'         },
  { name: 'Powder Blue',  img: '/images/catalogue/velour-powder-blue.webp'  },
  { name: 'Pastel Green', img: '/images/catalogue/velour-pastel-green.webp' },
];

const applications = [
  'Premium Pavilions',
  'Art Fairs',
  'Brand Activations',
  'Corporate Events',
  'Fashion Shows',
  'Retail Pop-ups',
  'VIP & Hospitality Areas',
  'Convention Centres',
];

const faqs = [
  {
    q: 'When should velour carpet be chosen over non woven or ribbed alternatives?',
    a: 'Velour is selected when the floor finish is a deliberate part of the design statement — premium brand pavilions, art fairs, fashion show venues, VIP hospitality areas, and retail activations where a soft, dense, and visually rich underfoot experience is expected by the audience. The cut-pile surface is denser and softer than non woven or ribbed alternatives.',
  },
  {
    q: 'Does velour carpet photograph well under exhibition lighting?',
    a: 'Yes. The cut-pile surface absorbs and reflects light uniformly, producing a rich, deep appearance under both natural and exhibition hall lighting. Velour carpet is frequently specified in environments where the floor is an active element of the brand photography and visual identity.',
  },
  {
    q: 'What are the installation requirements for velour carpet at events?',
    a: 'Velour carpet is installed using the same method as other exhibition carpet types — laid over the exhibition floor and secured with carpet tape along edges and seam lines. Our installation team handles all cutting, laying, edge finishing, and post-show removal as part of the full flooring scope.',
  },
  {
    q: 'Which exhibition types and industries most commonly specify velour carpet?',
    a: 'Velour is most commonly specified at India Art Fair, design and architecture exhibitions, luxury brand pavilions at major expos, fashion industry events, pharmaceutical and healthcare conferences with premium hospitality zones, automobile launches and VIP brand activations. Any exhibition environment where the floor is expected to actively contribute to a high-end visitor experience.',
  },
  {
    q: 'Can velour carpet be supplied in a custom colour outside the standard range?',
    a: 'Our standard velour range covers 11 in-stock shades across the most commonly requested tones for premium exhibition environments. For custom colour requirements — exact Pantone or brand-matched specifications — our Designer Carpet service produces fully custom carpet to your supplied specification. Contact us to discuss whether a standard shade or a custom solution fits your project.',
  },
  {
    q: 'How does velour carpet compare to loop pile carpet for premium events?',
    a: 'Velour and loop pile are both premium products but serve different environments. Velour\'s cut-pile surface is softer underfoot and produces a richer visual finish — suited to brand activations, art environments, and hospitality areas where warmth is part of the experience. Loop pile\'s cut-loop construction creates a more structured, architectural surface — better suited to corporate conference spaces, long-duration installations, and professional environments where a more neutral floor character is preferred.',
  },
];
---

<Layout
  title="Velour Exhibition Carpet — Premium Event Flooring | Sanchi Enterprises"
  description="Velour exhibition carpet in 11 stocked shades. Soft cut-pile finish for premium pavilions, art fairs, brand activations, and upmarket events. Bulk supply and on-site installation across India."
  ogImage="https://www.sanchienterprises.com/images/catalogue/velour-black.webp"
  ogImageWidth="520"
  ogImageHeight="292"
  breadcrumbs={[
    { name: 'Products', item: 'https://www.sanchienterprises.com/products' },
    { name: 'Velour Carpet', item: 'https://www.sanchienterprises.com/products/velour-carpet' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://www.sanchienterprises.com/products/velour-carpet/#service",
          "name": "Velour Exhibition Carpet",
          "description": "Velour cut-pile exhibition carpet in 11 stocked shades. Premium soft-finish flooring for brand pavilions, art fairs, VIP areas, and upmarket event environments across India.",
          "serviceType": "Exhibition Carpet Supply and Installation",
          "provider": { "@id": "https://www.sanchienterprises.com/#organization" },
          "url": "https://www.sanchienterprises.com/products/velour-carpet",
          "image": "https://www.sanchienterprises.com/images/catalogue/velour-black.webp",
          "areaServed": { "@type": "Country", "name": "India" },
          "additionalProperty": [
            { "@type": "PropertyValue", "name": "Surface", "value": "Cut-pile velour" },
            { "@type": "PropertyValue", "name": "Shades in Stock", "value": "11 colours" },
            { "@type": "PropertyValue", "name": "Best Suited For", "value": "Premium and branded spaces" },
            { "@type": "PropertyValue", "name": "Coverage", "value": "Pan-India delivery" }
          ],
          "offers": {
            "@type": "Offer",
            "priceCurrency": "INR",
            "availability": "https://schema.org/InStock",
            "url": "https://www.sanchienterprises.com/products/velour-carpet",
            "seller": { "@type": "Organization", "name": "Sanchi Enterprises" },
            "priceSpecification": {
              "@type": "PriceSpecification",
              "priceCurrency": "INR",
              "price": "0",
              "description": "Custom quotation based pricing. Contact for pricing."
            }
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.q,
            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
          }))
        }
      ]
    })}></script>
  </Fragment>

  <Navbar />
  <main>

    <section class="prod-hero" aria-labelledby="velour-heading">
      <div class="container">
        <div class="prod-hero__inner">
          <a href="/products" class="prod-hero__back" data-animate>
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M11 4H1M5 1L1 4l4 3" stroke="currentColor" stroke-width="1.3"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All Products
          </a>
          <span class="eyebrow eyebrow--inverse eyebrow--line" data-animate data-delay="1">Velour Carpet</span>
          <h1 class="prod-hero__title" id="velour-heading" data-animate data-delay="2">
            Premium Finish for<br />Upmarket Exhibition Spaces.
          </h1>
          <p class="prod-hero__intro" data-animate data-delay="3">
            Velour carpet brings a soft, rich finish to exhibition pavilions and
            premium event environments. Its cut-pile surface reads as high-quality
            to visitors and photographs well under exhibition lighting. Available
            in 11 stocked shades, supplied in bulk rolls, and laid on-site by our team.
          </p>
        </div>
      </div>
    </section>

    <div class="shade-section" aria-labelledby="shades-heading">
      <div class="container">
        <div class="shade-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Shade Catalogue</span>
          <h2 class="shade-section__title" id="shades-heading">Available Shades</h2>
          <p class="shade-section__count">11 colours — all held in stock</p>
        </div>
        <div class="shade-grid">
          {shades.map((shade, i) => (
            <div class="shade-card" data-animate data-delay={String((i % 5) + 1)}>
              <div class="shade-card__img-wrap">
                <img
                  src={shade.img}
                  alt={`Velour Carpet — ${shade.name}`}
                  class="shade-card__img"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </div>
              <div class="shade-card__name">{shade.name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="prod-section prod-section--stone" aria-label="Product specifications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Specification</span>
          <h2 class="prod-section__title">Product Details</h2>
        </div>
        <p class="prod-section__body" data-animate data-delay="1">
          Velour carpet is specified where presentation quality matters. The
          cut-pile surface is denser and softer underfoot than ribbed alternatives,
          making it the right choice for brand pavilions, art fair stands, and
          environments where visual finish is a deliberate signal to visitors.
        </p>
        <div class="prod-features" data-animate data-delay="2">
          <div class="prod-feature">
            <div class="prod-feature__label">Surface</div>
            <div class="prod-feature__value">Cut-pile velour</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Supply Format</div>
            <div class="prod-feature__value">Bulk roll</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Shades in Stock</div>
            <div class="prod-feature__value">11 colours</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Installation</div>
            <div class="prod-feature__value">Supply & lay available</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Best Suited For</div>
            <div class="prod-feature__value">Premium & branded spaces</div>
          </div>
          <div class="prod-feature">
            <div class="prod-feature__label">Coverage</div>
            <div class="prod-feature__value">Pan-India delivery</div>
          </div>
        </div>
      </div>
    </div>

    <div class="prod-section" aria-label="Applications">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Applications</span>
          <h2 class="prod-section__title">Where Velour Carpet Works</h2>
        </div>
        <div class="prod-apps-grid" data-animate data-delay="1">
          {applications.map((app) => (
            <div class="prod-app-item">
              <div class="prod-app-item__dot"></div>
              <div class="prod-app-item__label">{app}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── INDUSTRY CONTEXT ──────────────────────────────────────────────── -->
    <div class="prod-section prod-section--dark" aria-labelledby="velour-context-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--inverse eyebrow--line">Exhibition Context</span>
          <h2 class="velour-context-title" id="velour-context-heading">The Premium Exhibition Floor Across India's High-End Events.</h2>
        </div>
        <p class="prod-section__body--inverse" data-animate data-delay="1">
          Velour carpet is the material that signals quality in Indian exhibition environments.
          When an international brand establishes its pavilion at a major industry trade fair,
          when a premium product is being launched to a curated audience, when an art fair opens
          to collectors and galleries — the floor covering is velour. The cut-pile surface
          maintains a consistent, rich appearance across the full event run and does not show
          footfall patterns the way lighter materials do under exhibition lighting.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="2">
          India Art Fair (New Delhi), design exhibitions, premium pharmaceutical conferences,
          luxury automobile presentations, and international corporate pavilions at events
          hosted at Pragati Maidan, Yashobhoomi, and Jio World Convention Centre all draw
          on velour carpet as the standard for premium exhibition floor coverage.
          When the floor needs to communicate an environment of quality to every visitor
          who enters the space, velour is the specification.
        </p>
        <p class="prod-section__body--inverse" data-animate data-delay="3">
          For exhibition contractors specifying flooring for premium spaces, velour carpet
          occupies a practical and commercially important position: significantly better
          presentation than non woven alternatives, available in bulk quantities at short
          notice, and installable by the same team managing the full exhibition flooring scope.
          It is the upgrade that exhibition organisers and premium brand teams reach for when
          the standard material is not the right signal.
        </p>
      </div>
    </div>

    <!-- ─── FAQ ────────────────────────────────────────────────────────────── -->
    <div class="prod-section prod-section--stone" aria-labelledby="velour-faq-heading">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">FAQ</span>
          <h2 class="prod-section__title" id="velour-faq-heading">Common Questions</h2>
        </div>
        <dl class="prod-faq" data-animate data-delay="1">
          {faqs.map((faq) => (
            <div class="prod-faq__item">
              <dt class="prod-faq__q">{faq.q}</dt>
              <dd class="prod-faq__a">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- ─── RELATED PRODUCTS ──────────────────────────────────────────────── -->
    <div class="prod-section" aria-label="Related products">
      <div class="container">
        <div class="prod-section__header" data-animate>
          <span class="eyebrow eyebrow--line">Also Available</span>
          <h2 class="prod-section__title">Explore Our Range</h2>
        </div>
        <div class="prod-related" data-animate data-delay="1">
          <a href="/products/non-woven-carpet" class="prod-related__link">
            <span class="prod-related__name">Non Woven Carpet</span>
            <span class="prod-related__desc">29 shades — industry standard floor coverage</span>
          </a>
          <a href="/products/ribbed-carpet" class="prod-related__link">
            <span class="prod-related__name">Ribbed Carpet</span>
            <span class="prod-related__desc">High-footfall loop-pile in 7 shades</span>
          </a>
          <a href="/products/designer-carpet" class="prod-related__link">
            <span class="prod-related__name">Designer Carpet</span>
            <span class="prod-related__desc">Fully custom printed to your brief</span>
          </a>
          <a href="/products/caution-carpet" class="prod-related__link">
            <span class="prod-related__name">Caution Carpet</span>
            <span class="prod-related__desc">Safety flooring for cable trays and access zones</span>
          </a>
        </div>
      </div>
    </div>

    <div class="prod-cta">
      <div class="container">
        <div class="prod-cta__inner">
          <div class="prod-cta__text" data-animate>
            <div class="prod-cta__title">Enquire about Velour Carpet</div>
            <p class="prod-cta__sub">Share your floor area, shade preference, and event dates. We'll confirm availability and pricing within 24 hours.</p>
          </div>
          <div class="prod-cta__actions" data-animate data-delay="1">
            <a href="/contact" class="btn btn--ghost-light">Send Enquiry</a>
            <a
              href="https://wa.me/919958132189"
              class="btn btn--whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .velour-context-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 42px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-inverse);
    margin-top: var(--sp-3);
  }
  .prod-section__body--inverse {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.2vw, 16px);
    line-height: 1.80;
    color: rgba(247, 246, 243, 0.65);
    max-width: 760px;
    margin-bottom: var(--sp-4);
  }
  .prod-section__body--inverse:last-child { margin-bottom: 0; }

  .prod-faq {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .prod-faq__item {
    border-top: 1px solid var(--color-border-light, rgba(0,0,0,0.08));
    padding-top: var(--sp-4);
  }
  .prod-faq__q {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-navy-dark);
    margin-bottom: var(--sp-2);
    line-height: 1.4;
  }
  .prod-faq__a {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .prod-related {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
  }
  .prod-related__link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-4);
    border: 1px solid var(--color-border-light, rgba(0,0,0,0.08));
    border-radius: 4px;
    transition: border-color 0.22s var(--ease-out), background 0.22s var(--ease-out);
    text-decoration: none;
  }
  .prod-related__link:hover {
    border-color: var(--color-navy);
    background: var(--color-stone, #EFEDE8);
  }
  .prod-related__name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-navy-dark);
    letter-spacing: -0.01em;
  }
  .prod-related__desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  @media (max-width: 1024px) { .prod-related { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .prod-related { grid-template-columns: 1fr; } }
</style>
